#!/usr/bin/env bash

# codespace-stack-ls: list/filter/prune stack codespaces.
#
# usable two ways:
#   1. sourced (CS_STACK_LS_NO_RUN=1) by `codespace` / `codespace-stack` — only
#      defines cs_stack_ls, cs_stack_remove, and their helpers.
#   2. executed directly: `./codespace-stack-ls [flags]` — same UX as
#      `codespace stack ls`.
#
# dependencies:
#   - codespace-utils      (cs_get_default_branch, cs_clone_marker_path, ...)
#   - codespace-worktree   (cs_remove_safety_check)
#   - codespace-stack      (cs_stack_get_org_dir, $STACK_HELP)
# loaded below; circular-source-safe via a per-file load sentinel.

set -euo pipefail

DIRNAME="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"

# include-guard mirrors codespace-stack's: avoids infinite recursion when
# both files end up sourcing each other.
if [ -n "${_CS_STACK_LS_LOADED:-}" ]; then
	return 0 2>/dev/null || true
fi
_CS_STACK_LS_LOADED=1

# pull in cs_stack_get_org_dir + $STACK_HELP. when codespace-stack is the
# entry point it has already sourced us with CS_STACK_LS_NO_RUN=1; the
# guard above short-circuits this re-source.
CS_STACK_NO_RUN=1 source "$DIRNAME/codespace-stack"

# Parse args for `cs_stack_ls`. Sets globals:
#   flag_global, flag_integrated, older_than_secs, flag_by_commit_age,
#   flag_rm, flag_quiet, flag_size, flag_no_gh, flag_no_cache
cs_stack_ls_parse_args() {
	flag_global=""
	flag_integrated=""
	older_than_secs=""
	flag_by_commit_age=""
	flag_rm=""
	flag_quiet=""
	flag_size=""
	flag_no_gh=""
	flag_no_cache=""

	while [ $# -gt 0 ]; do
		case "$1" in
			-g|--global) flag_global=1 ;;
			-i|--integrated) flag_integrated=1 ;;
			-S|--size) flag_size=1 ;;
			--no-gh) flag_no_gh=1 ;;
			--no-cache) flag_no_cache=1 ;;
			--older-than)
				shift
				test -n "${1:-}" || { >&2 echo "err: --older-than requires a duration"; exit 1; }
				# explicit `|| exit` because bats' run sets +e, defeating
				# command-substitution exit propagation.
				older_than_secs="$(cs_stack_ls_parse_duration "$1")" || exit 1
				;;
			--by-commit-age) flag_by_commit_age=1 ;;
			--rm) flag_rm=1 ;;
			-q|--quiet) flag_quiet=1 ;;
			-h|--help) echo "$STACK_HELP"; exit 0 ;;
			*)
				>&2 echo "err: unknown argument: $1"
				exit 1
				;;
		esac
		shift
	done
}

# Convert a duration string like 30d|2w|6h|45m|3600s into seconds.
cs_stack_ls_parse_duration() {
	local s="$1"
	[[ "$s" =~ ^([0-9]+)([smhdw])$ ]] || {
		>&2 echo "err: invalid duration: $s (expected e.g. 30d, 2w, 6h, 45m, 3600s)"
		exit 1
	}
	local n="${BASH_REMATCH[1]}" u="${BASH_REMATCH[2]}"
	case "$u" in
		s) echo "$n" ;;
		m) echo "$((n * 60))" ;;
		h) echo "$((n * 3600))" ;;
		d) echo "$((n * 86400))" ;;
		w) echo "$((n * 604800))" ;;
	esac
}

# Get mtime of a path in seconds-since-epoch.
# Uses `date -r FILE +%s` which works on both BSD (macOS) and GNU coreutils.
cs_mtime_secs() {
	date -r "$1" +%s
}

# Format seconds into a short, human-friendly age (3w, 5d, 2h, 30m, 45s).
cs_stack_ls_format_age() {
	local s="$1"
	if   [ "$s" -ge 604800 ]; then echo "$((s / 604800))w"
	elif [ "$s" -ge 86400  ]; then echo "$((s / 86400))d"
	elif [ "$s" -ge 3600   ]; then echo "$((s / 3600))h"
	elif [ "$s" -ge 60     ]; then echo "$((s / 60))m"
	else                            echo "${s}s"
	fi
}

# Number of logical CPUs (portable: GNU nproc, else BSD sysctl, else 4).
cs_ncpu() {
	local n
	n="$(nproc 2>/dev/null)" || n="$(sysctl -n hw.ncpu 2>/dev/null)" || n=4
	[ "${n:-0}" -ge 1 ] 2>/dev/null && echo "$n" || echo 4
}

# Concurrency for the local per-(stack,repo) integration checks. Defaults to the
# CPU count capped at 8; override with CS_STACK_LS_JOBS.
cs_stack_ls_jobs() {
	local j="${CS_STACK_LS_JOBS:-}"
	[ -n "$j" ] || { j="$(cs_ncpu)"; [ "$j" -gt 8 ] && j=8; }
	[ "${j:-0}" -ge 1 ] 2>/dev/null && echo "$j" || echo 1
}

# Concurrency for bulk gh queries (network). Lower than the local cap to avoid
# spamming the API; defaults to min(jobs, 6), override with CS_GH_JOBS.
cs_gh_jobs() {
	local j="${CS_GH_JOBS:-}"
	if [ -z "$j" ]; then
		j="$(cs_stack_ls_jobs)"
		[ "$j" -gt 6 ] && j=6
	fi
	[ "${j:-0}" -ge 1 ] 2>/dev/null && echo "$j" || echo 1
}

# Echo the org dirs to scan (deduped, sorted). Honors --global.
# Stdout: one org dir per line.
cs_stack_ls_collect_org_dirs() {
	if [ -z "${flag_global:-}" ]; then
		cs_stack_get_org_dir
		return 0
	fi

	test -n "${CODESPACE_CONFIG_ROOT:-}" || {
		>&2 echo "warn: --global requires \$CODESPACE_CONFIG_ROOT; falling back to current org"
		cs_stack_get_org_dir
		return 0
	}
	test -d "$CODESPACE_CONFIG_ROOT" || return 0

	# every dir under the config root that contains stacks.json maps back to
	# a real org dir at $HOME/<rel>. .codespace/stacks.json -> strip .codespace.
	find "$CODESPACE_CONFIG_ROOT" -name 'stacks.json' -type f 2>/dev/null \
	| while IFS= read -r cfg; do
		local cfg_dir
		cfg_dir="$(dirname "$cfg")"
		[ "$(basename "$cfg_dir")" = ".codespace" ] && cfg_dir="$(dirname "$cfg_dir")"
		local rel
		rel="$(realpath "$cfg_dir" --relative-to="$CODESPACE_CONFIG_ROOT" 2>/dev/null)" || continue
		local org_dir="$HOME/$rel"
		[ -d "$org_dir" ] || continue
		echo "$org_dir"
	done | sort -u
}

# Echo the actual git branch for a stack. All repos in the stack should agree;
# we read it from the first repo and fall back to the dir name if we have to.
cs_stack_ls_stack_branch() {
	local stack_dir="$1"
	for repo_dir in "$stack_dir"/*; do
		# .git is a directory in clones, a file in worktrees -> use -e
		[ -e "$repo_dir/.git" ] || continue
		local b
		b="$(git -C "$repo_dir" branch --show-current 2>/dev/null)"
		[ -n "$b" ] && { echo "$b"; return 0; }
	done
	# fallback: strip stack_ prefix from dir basename (cleanpath, may not match)
	local dn
	dn="$(basename "$stack_dir")"
	echo "${dn#stack_}"
}

# Echo the most-recent commit timestamp (epoch s) across all repo branches in the stack.
cs_stack_ls_branch_commit_age_secs() {
	local stack_dir="$1" branch="$2"
	local newest=0
	for repo_dir in "$stack_dir"/*; do
		# .git is a directory in clones, a file in worktrees -> use -e
		[ -e "$repo_dir/.git" ] || continue
		local ts
		ts="$(git -C "$repo_dir" log -1 --format=%ct "refs/heads/$branch" 2>/dev/null)" || continue
		[ -n "$ts" ] || continue
		[ "$ts" -gt "$newest" ] && newest="$ts"
	done
	echo "$newest"
}

# Resolve a repo's default branch, cached per git common-dir for the duration
# of a single `cs_stack_ls` run. No network: GitHub (via gh) is the source of
# truth for integration, so a possibly-stale origin/<default> is fine here
# (merge-base is insensitive to how far origin/<default> has advanced).
declare -gA _cs_stack_ls_default_cache=()
cs_stack_ls_default_branch() {
	local repo_dir="$1"
	local common_dir
	common_dir="$(git -C "$repo_dir" rev-parse --git-common-dir 2>/dev/null)" || return 1
	# rev-parse may print a relative path; resolve it for stable cache keys.
	common_dir="$(cd "$repo_dir" && realpath "$common_dir" 2>/dev/null)" || return 1

	if [ -n "${_cs_stack_ls_default_cache[$common_dir]+x}" ]; then
		echo "${_cs_stack_ls_default_cache[$common_dir]}"
		return 0
	fi

	local default_branch=""
	default_branch="$(cd "$repo_dir" && cs_get_default_branch 2>/dev/null)" || true
	_cs_stack_ls_default_cache[$common_dir]="$default_branch"
	echo "$default_branch"
}

# --- gh-backed merged-PR lookup ---------------------------------------------
#
# GitHub is the source of truth for "is this branch integrated": it catches
# squash/rebase merges (where the branch commits never become ancestors of the
# default branch) and branches that were merged then auto-deleted on the remote
# — both of which the local ancestor check silently misses.

# Print a status line to stderr unless --quiet (machine-friendly) is set. Used
# for progress so a slow `-i`/`--size` run never looks stuck.
cs_stack_ls_note() {
	[ -n "${flag_quiet:-}" ] && return 0
	>&2 echo "$@"
}

# Whether to consult gh. --no-gh / CS_NO_GH opt out; a missing binary degrades
# (with a one-time warning) to the local ancestor check.
_cs_gh_warned=""
cs_gh_available() {
	[ -z "${flag_no_gh:-}" ] || return 1
	[ -z "${CS_NO_GH:-}" ] || return 1
	if ! command -v gh >/dev/null 2>&1; then
		if [ -z "$_cs_gh_warned" ]; then
			>&2 echo "warn: gh not found; integration falls back to the local ancestor check"
			>&2 echo "      (squash-merges may be missed). install gh, or pass --no-gh to silence."
			_cs_gh_warned=1
		fi
		return 1
	fi
	return 0
}

# Bulk merged-PR window. A merge older than this is not in the bulk list;
# cs_gh_branch_merged_pr recovers it with a targeted per-branch query. Bump
# CS_GH_PR_LIMIT for repos with very deep merge history.
cs_gh_pr_limit() { echo "${CS_GH_PR_LIMIT:-1000}"; }

# Merged PRs for a repo slug as "<headRefName>\t<number>" lines, cached per slug
# for the run. One bulk query covers the common (recent) case cheaply.
# _cs_gh_merged_trunc[slug]=1 marks a slug whose bulk list hit the limit (so it
# may be hiding older merges and the per-branch fallback is allowed).
declare -gA _cs_gh_merged_cache=()
declare -gA _cs_gh_merged_trunc=()

# Read-only view of the warmed bulk list (empty for an unwarmed slug). Never
# queries gh -- warming is cs_stack_ls_fetch_slugs' job (so the parallel compute
# phase only READS the cache and never triggers a network call of its own).
cs_gh_merged_list() {
	printf '%s' "${_cs_gh_merged_cache[${1}]:-}"
}

# Persistent positive cache. A merged PR never un-merges, so once we learn
# <slug>:<branch> -> #N we can answer from disk forever and skip gh entirely.
# Stored as "<slug>\t<branch>\t<number>" lines under $CODESPACE_CONFIG_ROOT/.cache;
# negatives are never cached (an open PR can still merge). --no-cache disables it,
# as does an unset $CODESPACE_CONFIG_ROOT (no place to persist -> in-memory only).
# Loaded once per run into an assoc array that command-substitution subshells
# inherit (so per-stack lookups stay in-memory); stores append to the file.
declare -gA _cs_gh_pcache=()
_cs_gh_pcache_loaded=""

_cs_gh_cache_file() {
	[ -n "${flag_no_cache:-}" ] && return 1
	local dir
	dir="$(cs_cache_dir)" || return 1
	echo "$dir/gh-merged.tsv"
}

cs_gh_cache_load() {
	_cs_gh_pcache=()
	_cs_gh_pcache_loaded=1
	local f
	f="$(_cs_gh_cache_file)" || return 0
	[ -f "$f" ] || return 0
	local s b n key
	while IFS=$'\t' read -r s b n; do
		[ -n "$s" ] && [ -n "$b" ] || continue
		printf -v key '%s\t%s' "$s" "$b"
		_cs_gh_pcache["$key"]="$n"
	done < "$f"
}

# Echo the cached merged PR number for <slug>:<branch>; return 1 on miss.
cs_gh_cache_lookup() {
	[ -n "$_cs_gh_pcache_loaded" ] || cs_gh_cache_load
	local key
	printf -v key '%s\t%s' "$1" "$2"
	[ -n "${_cs_gh_pcache[$key]+x}" ] || return 1
	printf '%s' "${_cs_gh_pcache[$key]}"
}

# Persist <slug>:<branch> -> <number>. Idempotent against the in-memory view.
cs_gh_cache_store() {
	local f
	f="$(_cs_gh_cache_file)" || return 0
	local key
	printf -v key '%s\t%s' "$1" "$2"
	[ -n "${_cs_gh_pcache[$key]+x}" ] && return 0
	_cs_gh_pcache["$key"]="$3"
	mkdir -p "$(dirname "$f")" 2>/dev/null || return 0
	printf '%s\t%s\t%s\n' "$1" "$2" "$3" >> "$f"
}

# --- TTL negative cache for open branches -----------------------------------
#
# An open PR can still merge, so "open" can never be cached permanently like a
# merge. But a branch missing from the bulk window triggers a targeted per-branch
# query (below); without a guard, a genuinely-open branch would re-fire that
# query on every run. So we remember "<slug>:<branch> at <sha> looked open at
# <epoch>" and skip the targeted query while the sha is unchanged AND the entry
# is younger than CS_GH_OPEN_TTL. A new commit (sha change) or TTL expiry forces
# a re-check, so an open->merged transition is still caught. Stored as
# "<slug>\t<branch>\t<sha>\t<epoch>" under the cache dir; --no-cache / no
# $CODESPACE_CONFIG_ROOT keep it in-memory only.
cs_gh_open_ttl() { echo "${CS_GH_OPEN_TTL:-21600}"; }

declare -gA _cs_gh_open=()
_cs_gh_open_loaded=""

_cs_gh_open_file() {
	[ -n "${flag_no_cache:-}" ] && return 1
	local dir
	dir="$(cs_cache_dir)" || return 1
	echo "$dir/gh-open.tsv"
}

cs_gh_open_load() {
	_cs_gh_open=()
	_cs_gh_open_loaded=1
	local f
	f="$(_cs_gh_open_file)" || return 0
	[ -f "$f" ] || return 0
	local s b sha ts key
	while IFS=$'\t' read -r s b sha ts; do
		[ -n "$s" ] && [ -n "$b" ] || continue
		printf -v key '%s\t%s' "$s" "$b"
		_cs_gh_open["$key"]="$sha"$'\t'"$ts"
	done < "$f"
}

# Return 0 when <slug>:<branch> was recently confirmed open at this exact sha
# (so the targeted query can be skipped). Args: slug, branch, sha.
cs_gh_open_is_fresh() {
	[ -n "$_cs_gh_open_loaded" ] || cs_gh_open_load
	local key
	printf -v key '%s\t%s' "$1" "$2"
	local v="${_cs_gh_open[$key]:-}"
	[ -n "$v" ] || return 1
	local csha cts
	csha="${v%%$'\t'*}"; cts="${v#*$'\t'}"
	[ "$csha" = "$3" ] || return 1
	local now; now="$(date +%s)"
	[ $(( now - cts )) -lt "$(cs_gh_open_ttl)" ]
}

# Record that <slug>:<branch> at <sha> looked open just now. Args: slug, branch, sha.
cs_gh_open_store() {
	local f
	f="$(_cs_gh_open_file)" || return 0
	mkdir -p "$(dirname "$f")" 2>/dev/null || return 0
	printf '%s\t%s\t%s\t%s\n' "$1" "$2" "$3" "$(date +%s)" >> "$f"
}

# Echo the merged PR number for <slug>:<branch> and return 0 if one exists.
# Order: persistent positive cache -> warmed per-slug bulk list -> (only when
# the bulk window was full, so older merges may be hidden) a targeted per-branch
# query, which also recovers branches deleted on the remote after merge. The
# targeted query is TTL-guarded by the open cache so a genuinely-open branch in a
# deep-history repo is not re-queried every run. Positives persist forever;
# still-open results refresh the TTL negative cache. Args: slug, branch, [sha].
# Returns non-zero when no merged PR is found.
cs_gh_branch_merged_pr() {
	local slug="$1" branch="$2" sha="${3:-}" num
	if num="$(cs_gh_cache_lookup "$slug" "$branch")"; then
		echo "$num"; return 0
	fi
	num="$(cs_gh_merged_list "$slug" | awk -F'\t' -v b="$branch" '$1 == b { print $2; exit }')"
	if [ -n "$num" ]; then cs_gh_cache_store "$slug" "$branch" "$num"; echo "$num"; return 0; fi

	# bulk list complete (not truncated) -> it is authoritative, branch is open.
	[ -n "${_cs_gh_merged_trunc[$slug]:-}" ] || return 1

	# deep-history repo: verify directly unless a fresh negative says open.
	if [ -n "$sha" ] && cs_gh_open_is_fresh "$slug" "$branch" "$sha"; then
		return 1
	fi
	num="$(gh pr list -R "$slug" --head "$branch" --state merged --limit 1 \
		--json number --jq '.[0].number // empty' 2>/dev/null)" || num=""
	if [ -n "$num" ]; then cs_gh_cache_store "$slug" "$branch" "$num"; echo "$num"; return 0; fi
	[ -n "$sha" ] && cs_gh_open_store "$slug" "$branch" "$sha"
	return 1
}

# owner/repo slug for a repo's origin remote (empty for non-github remotes).
cs_stack_ls_repo_slug() {
	local url
	url="$(git -C "$1" remote get-url origin 2>/dev/null)" || return 1
	cs_gh_slug_from_url "$url"
}

# --- stack-level "already integrated" cache ---------------------------------
#
# The per-(slug,branch) cache above stops us re-hitting gh, but the local git
# work (rev-parse/merge-base/rev-list per repo) still re-ran on every pass, so a
# cancelled `--rm` re-checked everything. This caches the whole-stack verdict
# keyed on the current branch-head shas: if the shas are unchanged, the verdict
# cannot have changed (a merge never un-merges, an empty branch at a fixed sha
# stays empty), so we skip ALL per-repo work. Any new commit changes the hash
# and forces a re-check. Only fully-integrated stacks are stored (positives-only,
# like the gh cache); partial/open stacks are always re-checked. Stored as
# "<stack_dir>\t<state_hash>" under the cache dir.

# Stable hash of a stack's state: each git repo's <basename>:<branch-head-sha>,
# sorted, hashed with cksum. Reading refs is far cheaper than the full check.
cs_stack_ls_stack_state_hash() {
	local stack_dir="$1" branch="$2" repo_dir sha lines=""
	for repo_dir in "$stack_dir"/*; do
		[ -e "$repo_dir/.git" ] || continue
		sha="$(git -C "$repo_dir" rev-parse --verify --quiet "refs/heads/$branch" 2>/dev/null)" || sha="-"
		lines="$lines$(basename "$repo_dir"):$sha"$'\n'
	done
	printf '%s' "$lines" | LC_ALL=C sort | cksum | awk '{print $1"-"$2}'
}

declare -gA _cs_stack_cache=()
_cs_stack_cache_loaded=""

_cs_stack_cache_file() {
	[ -n "${flag_no_cache:-}" ] && return 1
	local dir
	dir="$(cs_cache_dir)" || return 1
	echo "$dir/stack-integrated.tsv"
}

cs_stack_cache_load() {
	_cs_stack_cache=()
	_cs_stack_cache_loaded=1
	local f
	f="$(_cs_stack_cache_file)" || return 0
	[ -f "$f" ] || return 0
	local d h
	while IFS=$'\t' read -r d h; do
		[ -n "$d" ] || continue
		_cs_stack_cache["$d"]="$h"
	done < "$f"
}

# Return 0 if <stack_dir> was last seen fully integrated at <state_hash>.
cs_stack_cache_is_integrated() {
	[ -n "$_cs_stack_cache_loaded" ] || cs_stack_cache_load
	[ -n "${_cs_stack_cache[$1]+x}" ] || return 1
	[ "${_cs_stack_cache[$1]}" = "$2" ]
}

# Persist <stack_dir> -> <state_hash> as fully integrated. Idempotent in-memory.
cs_stack_cache_store() {
	[ "${_cs_stack_cache[$1]:-}" = "$2" ] && return 0
	[ -n "$_cs_stack_cache_loaded" ] || cs_stack_cache_load
	_cs_stack_cache["$1"]="$2"
	local f
	f="$(_cs_stack_cache_file)" || return 0
	mkdir -p "$(dirname "$f")" 2>/dev/null || return 0
	printf '%s\t%s\n' "$1" "$2" >> "$f"
}

# Best-effort offline signal: branch was pushed (has upstream config) but no
# longer exists on origin -> likely merged and auto-deleted. NOT proof (a closed-
# unmerged PR also deletes the branch), so this is only used as a last resort
# when gh cannot confirm. The config check (not @{upstream}) survives the remote-
# tracking ref being pruned. Issues a remote query; degrades to "not gone" on any
# failure. Args: repo_dir, branch.
cs_stack_ls_branch_remote_gone() {
	local repo_dir="$1" branch="$2"
	git -C "$repo_dir" config --get "branch.$branch.merge" >/dev/null 2>&1 || return 1
	local ls
	ls="$(git -C "$repo_dir" ls-remote --heads origin "$branch" 2>/dev/null)" || return 1
	[ -z "$ls" ]
}

# Pre-warm the per-slug merged-PR cache in the *parent* shell, in parallel. The
# per-stack integration checks run in subshells that cannot write back to
# _cs_gh_merged_cache; warming here means those subshells inherit a populated
# cache (hit) instead of re-querying gh.
#
# A slug is bulk-queried only when it has at least one branch that is neither in
# the persistent positive cache nor freshly known-open (TTL), and whose stack is
# not already cached integrated -- so repeat runs over settled stacks hit gh zero
# times. Bulk queries run concurrently, capped at CS_GH_JOBS, to avoid spamming.
# Args: org_dir, [repo_filter]  (repo_filter restricts to stacks holding it)
cs_stack_ls_warm_gh() {
	local org_dir="$1" repo_filter="${2:-}"
	# -i filters on integration; --rm computes it for the rm/keep default.
	{ [ -n "${flag_integrated:-}" ] || [ -n "${flag_rm:-}" ]; } || return 0
	cs_gh_available || return 0
	local stack_dir repo_dir url slug branch hash need=" "
	for stack_dir in "$org_dir"/stack_*; do
		[ -d "$stack_dir" ] || continue
		[ -z "$repo_filter" ] || [ -e "$stack_dir/$repo_filter/.git" ] || continue
		branch="$(cs_stack_ls_stack_branch "$stack_dir")"
		hash="$(cs_stack_ls_stack_state_hash "$stack_dir" "$branch")"
		cs_stack_cache_is_integrated "$stack_dir" "$hash" && continue
		for repo_dir in "$stack_dir"/*; do
			[ -e "$repo_dir/.git" ] || continue
			url="$(git -C "$repo_dir" remote get-url origin 2>/dev/null)" || continue
			slug="$(cs_gh_slug_from_url "$url")" || continue
			case "$need" in *" $slug "*) continue ;; esac
			# a positive is permanent; an open branch still needs the (cheap) bulk
			# query each run so a fresh merge is caught promptly.
			cs_gh_cache_lookup "$slug" "$branch" >/dev/null && continue
			need="$need$slug "
		done
	done
	cs_stack_ls_fetch_slugs $need
}

# Fetch each given slug's bulk merged-PR list concurrently (capped at CS_GH_JOBS)
# into files, then load them into the in-memory cache the parent owns (subshells
# can't write back). Args: slug...
cs_stack_ls_fetch_slugs() {
	local slugs=() slug
	for slug in "$@"; do [ -n "$slug" ] && slugs+=("$slug"); done
	[ ${#slugs[@]} -gt 0 ] || return 0
	local tmp
	tmp="$(mktemp -d -t codespace-warm.XXXXXX)"
	local jobs running=0
	jobs="$(cs_gh_jobs)"
	for slug in "${slugs[@]}"; do
		(
			out="$(gh pr list -R "$slug" --state merged --limit "$(cs_gh_pr_limit)" \
				--json number,headRefName --jq '.[] | "\(.headRefName)\t\(.number)"' 2>/dev/null)" || out=""
			printf '%s' "$out" > "$tmp/$(cs_cleanpath "$slug")"
		) &
		running=$((running + 1))
		if [ "$running" -ge "$jobs" ]; then wait -n 2>/dev/null || true; running=$((running - 1)); fi
	done
	wait
	local content cnt limit
	limit="$(cs_gh_pr_limit)"
	for slug in "${slugs[@]}"; do
		cs_stack_ls_note "    querying merged PRs via gh: $slug ..."
		content="$(cat "$tmp/$(cs_cleanpath "$slug")" 2>/dev/null)"
		_cs_gh_merged_cache["$slug"]="$content"
		# a full window may be hiding older merges -> mark truncated so the
		# per-branch fallback is allowed for this slug.
		cnt="$(printf '%s' "$content" | awk 'END{print NR}')"
		if [ "${cnt:-0}" -ge "$limit" ]; then _cs_gh_merged_trunc["$slug"]=1; fi
	done
	rm -rf "$tmp"
}

# Decide whether a repo's branch is integrated. Echoes a short reason
# (empty|merged #N|ancestor|remote-gone|open|no-branch) on stdout and returns 0
# when integrated, 1 otherwise.
#
# Order: cheap local shortcut (no commits beyond base -> nothing to merge) ->
# gh merged-PR check, incl. a targeted query for merges beyond the bulk window /
# branches deleted after merge (source of truth) -> offline fallbacks (local
# ancestor check, then the remote-gone heuristic).
cs_stack_ls_repo_integrated() {
	local repo_dir="$1" branch="$2"

	local sha
	sha="$(git -C "$repo_dir" rev-parse --verify --quiet "refs/heads/$branch" 2>/dev/null)" || {
		echo "no-branch"; return 1
	}

	local default_branch target=""
	default_branch="$(cs_stack_ls_default_branch "$repo_dir")" || default_branch=""
	if [ -n "$default_branch" ]; then
		target="refs/remotes/origin/$default_branch"
		git -C "$repo_dir" rev-parse --verify --quiet "$target" >/dev/null 2>&1 \
			|| target="refs/heads/$default_branch"
	fi

	# tag-along repo: branch carries no commits beyond base, so there is nothing
	# to merge -> treat as integrated regardless of PR state.
	if [ -n "$target" ]; then
		local mb ahead
		mb="$(git -C "$repo_dir" merge-base "refs/heads/$branch" "$target" 2>/dev/null)" || mb=""
		if [ -n "$mb" ]; then
			ahead="$(git -C "$repo_dir" rev-list --count "$mb..refs/heads/$branch" 2>/dev/null)" || ahead=1
			if [ "${ahead:-1}" -eq 0 ] 2>/dev/null; then
				echo "empty"; return 0
			fi
		fi
	fi

	# gh: the source of truth (handles squash/rebase merges + deleted remotes).
	local slug=""
	slug="$(cs_stack_ls_repo_slug "$repo_dir")" || slug=""
	if [ -n "$slug" ] && cs_gh_available; then
		local pr
		if pr="$(cs_gh_branch_merged_pr "$slug" "$branch" "$sha")"; then
			echo "merged #$pr"; return 0
		fi
		echo "open"; return 1
	fi

	# offline / no gh / non-github remote: best-effort local ancestor check.
	if [ -n "$target" ] && git -C "$repo_dir" merge-base --is-ancestor "refs/heads/$branch" "$target" 2>/dev/null; then
		echo "ancestor"; return 0
	fi
	# last resort: branch was pushed but is gone from origin -> likely merged.
	if cs_stack_ls_branch_remote_gone "$repo_dir" "$branch"; then
		echo "remote-gone"; return 0
	fi
	echo "open"; return 1
}

# Compute the integration breakdown for a stack. Stdout:
#   line 1:  "<integrated>/<total>"     (total counts only dirs that look like
#                                        git repos)
#   line 2+: "<repo>|yes|<reason>" / "<repo>|no|<reason>"  (per-repo detail)
# It runs in a subshell at the call site, so we return everything via stdout
# rather than a global (which a subshell could not export back).
cs_stack_ls_stack_integration_count() {
	local stack_dir="$1" branch="$2"
	local total=0 integrated=0
	local detail=()
	for repo_dir in "$stack_dir"/*; do
		# .git is a directory in clones, a file in worktrees -> use -e
		[ -e "$repo_dir/.git" ] || continue
		total=$((total + 1))
		local reason rc mark
		reason="$(cs_stack_ls_repo_integrated "$repo_dir" "$branch")"; rc=$?
		if [ "$rc" -eq 0 ]; then integrated=$((integrated + 1)); mark="yes"; else mark="no"; fi
		detail+=("$(basename "$repo_dir")|$mark|$reason")
	done
	echo "$integrated/$total"
	[ ${#detail[@]} -gt 0 ] && printf '%s\n' "${detail[@]}"
	return 0
}

# Print the per-repo integration breakdown captured by the most recent
# cs_stack_ls_stack_integration_count call. Arg: newline-joined "repo|mark|reason".
cs_stack_ls_print_integration_detail() {
	local packed="$1" line repo mark reason sym
	while IFS= read -r line; do
		[ -n "$line" ] || continue
		repo="${line%%|*}"; line="${line#*|}"
		mark="${line%%|*}"; reason="${line#*|}"
		if [ "$mark" = "yes" ]; then sym="+"; else sym="x"; fi
		printf '          %s %-14s %s\n' "$sym" "$repo" "$reason"
	done <<< "$packed"
}

# Print the column-header row (AGE, then optional INT/SIZE, then BRANCH),
# matching the column layout cs_stack_ls_print_row emits.
cs_stack_ls_print_col_header() {
	if [ -n "${flag_integrated:-}" ] && [ -n "${flag_size:-}" ]; then
		printf '  %4s  %4s  %6s  %s\n' "AGE" "INT" "SIZE" "BRANCH"
	elif [ -n "${flag_integrated:-}" ]; then
		printf '  %4s  %4s  %s\n' "AGE" "INT" "BRANCH"
	elif [ -n "${flag_size:-}" ]; then
		printf '  %4s  %6s  %s\n' "AGE" "SIZE" "BRANCH"
	else
		printf '  %4s  %s\n' "AGE" "BRANCH"
	fi
}

# Print the per-org block header: `in <org>` and the column header row.
# Skipped when --quiet (machine-friendly output).
cs_stack_ls_print_org_header() {
	local org_dir="$1"
	echo "in $org_dir"
	cs_stack_ls_print_col_header
}

# Print one row of the listing. The INT/SIZE columns are emitted whenever the
# corresponding argument is non-empty (so callers control them via the flags).
# Args: stack_dir, branch, age_secs, [integrated_str], [size_str]
cs_stack_ls_print_row() {
	local stack_dir="$1" branch="$2" age_secs="$3" integrated_str="${4:-}" size_str="${5:-}"

	if [ -n "${flag_quiet:-}" ]; then
		echo "$stack_dir"
		return 0
	fi

	local age_str
	age_str="$(cs_stack_ls_format_age "$age_secs")"

	# stack dir name is built as `stack_<cleanpath(branch)>` at create time;
	# annotate the row only when the current branch diverges from that
	# (e.g. the worktree was switched to a different branch after creation).
	local stack_basename branch_norm branch_display
	stack_basename="$(basename "$stack_dir")"
	branch_norm="stack_$(cs_cleanpath "$branch")"
	branch_display="$branch"
	if [ "$branch_norm" != "$stack_basename" ]; then
		branch_display="$branch  [$stack_basename]"
	fi

	if [ -n "$integrated_str" ] && [ -n "$size_str" ]; then
		printf '  %4s  %4s  %6s  %s\n' "$age_str" "$integrated_str" "$size_str" "$branch_display"
	elif [ -n "$integrated_str" ]; then
		printf '  %4s  %4s  %s\n' "$age_str" "$integrated_str" "$branch_display"
	elif [ -n "$size_str" ]; then
		printf '  %4s  %6s  %s\n' "$age_str" "$size_str" "$branch_display"
	else
		printf '  %4s  %s\n' "$age_str" "$branch_display"
	fi
}

# Safely remove a stack. Preflight: every child repo must pass
# cs_remove_safety_check. If any fail, prints which repos and returns non-zero
# without touching anything. Otherwise removes each repo (worktree or clone)
# and the stack dir + leftover .stack-*-logs.
#
# Remote stacks (stub_dir/.codespace-remote present) dispatch to
# cs_remove_remote, which handles per-repo cleanup over ssh.
cs_stack_remove() {
	local stack_dir="$1"

	# Remote stack stub: delegate fully (per-repo safety checks happen on remote).
	if cs_remote_marker "$stack_dir"; then
		# walk children with .codespace-remote markers and remove each, then the stack dir
		local repo_dir
		for repo_dir in "$stack_dir"/*; do
			[ -d "$repo_dir" ] || continue
			cs_remote_marker "$repo_dir" || continue
			cs_remove_remote "$repo_dir" || return 1
		done
		rm -rf "$stack_dir"
		return 0
	fi

	local unsafe_repos=()
	for repo_dir in "$stack_dir"/*; do
		# .git is a directory in clones, a file in worktrees -> use -e
		[ -e "$repo_dir/.git" ] || continue
		if ! cs_remove_safety_check "$repo_dir" 2>/dev/null; then
			unsafe_repos+=("$(basename "$repo_dir")")
		fi
	done

	if [ ${#unsafe_repos[@]} -gt 0 ]; then
		>&2 echo "  skip (unsafe repos): ${unsafe_repos[*]}"
		>&2 echo "  hint: remove individually with 'codespace rm <path> [-f]'"
		return 1
	fi

	for repo_dir in "$stack_dir"/*; do
		# .git is a directory in clones, a file in worktrees -> use -e
		[ -e "$repo_dir/.git" ] || continue
		if [ -f "$(cs_clone_marker_path "$repo_dir")" ]; then
			rm -rf "$repo_dir"
		else
			# -C "$repo_dir" makes git resolve the worktree without relying on cwd.
			git -C "$repo_dir" worktree remove "$repo_dir" 2>/dev/null \
				|| rm -rf "$repo_dir"
		fi
	done

	rm -rf "$stack_dir"
}

# Append the instructional footer of the --rm review file. Like git-rebase-todo,
# the actionable lines come first and the help sits at the bottom.
cs_stack_ls_rm_todo_footer() {
	cat >> "$1" <<'EOF'
#
# codespace stack removal -- review, edit, then save & close.
#
# one stack per line. set each action:
#     rm     remove the stack (its worktrees/clones + the stack dir)
#     keep   leave it untouched
#
# integrated stacks (merged PR, or no commits beyond base) default to 'rm' and
# are listed first; everything else defaults to 'keep'. flip any line as you
# like. text after '#' is informational (INT  [SIZE]  AGE) and is ignored;
# blank/comment lines are skipped, and deleting a line keeps that stack.
# stacks with uncommitted/unpushed work are skipped even if marked 'rm'.
EOF
}

# Render the --rm review file from the global rm_* buffers: 'rm' (integrated)
# entries first, then 'keep', with aligned path + info columns for easy scanning,
# and the instructions appended at the bottom. Reads rm_dir/rm_age/rm_int/
# rm_szb/rm_szs/rm_done via dynamic scope from cs_stack_ls. Arg: file.
cs_stack_ls_rm_render() {
	local file="$1" idx base
	: > "$file"

	# within each action group, sort by size desc under --size, else keep the
	# collection (alpha) order.
	if [ -n "${flag_size:-}" ]; then
		base="$(for idx in "${!rm_dir[@]}"; do printf '%s\t%s\n' "${rm_szb[$idx]}" "$idx"; done | sort -k1,1nr -k2,2n | awk '{print $2}')"
	else
		base="$(for idx in "${!rm_dir[@]}"; do echo "$idx"; done)"
	fi

	local order_rm="" order_keep=""
	for idx in $base; do
		if [ -n "${rm_done[$idx]}" ]; then order_rm="$order_rm $idx"; else order_keep="$order_keep $idx"; fi
	done
	local order="$order_rm $order_keep"

	# column widths for aligned info comments
	local wpath=0 wint=0 wsize=0 wage=0 age_str
	for idx in $order; do
		[ ${#rm_dir[$idx]} -gt "$wpath" ] && wpath=${#rm_dir[$idx]}
		[ ${#rm_int[$idx]} -gt "$wint" ]  && wint=${#rm_int[$idx]}
		[ ${#rm_szs[$idx]} -gt "$wsize" ] && wsize=${#rm_szs[$idx]}
		age_str="$(cs_stack_ls_format_age "${rm_age[$idx]}")"
		[ ${#age_str} -gt "$wage" ] && wage=${#age_str}
	done

	local action info
	for idx in $order; do
		if [ -n "${rm_done[$idx]}" ]; then action="rm"; else action="keep"; fi
		age_str="$(cs_stack_ls_format_age "${rm_age[$idx]}")"
		printf -v info '%-*s' "$wint" "${rm_int[$idx]}"
		[ -n "${flag_size:-}" ] && printf -v info '%s  %-*s' "$info" "$wsize" "${rm_szs[$idx]}"
		printf -v info '%s  %-*s' "$info" "$wage" "$age_str"
		printf '%-4s %-*s  # %s\n' "$action" "$wpath" "${rm_dir[$idx]}" "$info" >> "$file"
	done

	cs_stack_ls_rm_todo_footer "$file"
}

# Worker: compute one repo's integration verdict and persist it to the per-run
# temp tree (the parent reduces these into per-stack counts). Runs as a bounded
# background subshell, so it inherits the warmed in-memory caches for reads and
# writes its result to a file. Arg: TAB-joined "sidx ridx repo_dir branch".
cs_stack_ls_compute_unit() {
	local rec="$1" sidx ridx repo_dir branch
	IFS=$'\t' read -r sidx ridx repo_dir branch <<< "$rec"
	local reason rc mark
	reason="$(cs_stack_ls_repo_integrated "$repo_dir" "$branch")" && rc=0 || rc=$?
	[ "$rc" -eq 0 ] && mark="yes" || mark="no"
	printf '%s|%s|%s\n' "$(basename "$repo_dir")" "$mark" "$reason" > "$RUNDIR/$sidx/$ridx"
}

# Process one org: collect its stacks (applying --older-than), warm gh, compute
# integration per (stack,repo) in parallel, reduce to per-stack entries, then
# either emit display rows (here) or append to the global rm_* review buffers
# (rendered once at the end). Reads now/need_int/slow/flags and the rm_* buffers
# via dynamic scope from cs_stack_ls. Arg: org_dir.
cs_stack_ls_process_org() {
	local org_dir="$1"

	local -a s_dir=() s_branch=() s_age=() s_hash=() s_cached=() s_nrepo=()
	local stack_dir branch age_secs hash cached commit_ts
	for stack_dir in "$org_dir"/stack_*; do
		[ -d "$stack_dir" ] || continue
		branch="$(cs_stack_ls_stack_branch "$stack_dir")"

		if [ -n "${flag_by_commit_age:-}" ]; then
			commit_ts="$(cs_stack_ls_branch_commit_age_secs "$stack_dir" "$branch")"
			if [ "$commit_ts" -le 0 ] 2>/dev/null; then
				age_secs=$((now - $(cs_mtime_secs "$stack_dir")))
			else
				age_secs=$((now - commit_ts))
			fi
		else
			age_secs=$((now - $(cs_mtime_secs "$stack_dir")))
		fi

		if [ -n "${older_than_secs:-}" ] && [ "$age_secs" -lt "$older_than_secs" ]; then
			continue
		fi

		hash=""; cached=""
		if [ -n "$need_int" ]; then
			hash="$(cs_stack_ls_stack_state_hash "$stack_dir" "$branch")"
			cs_stack_cache_is_integrated "$stack_dir" "$hash" && cached=1
		fi

		if [ -n "$slow" ]; then
			if [ -n "$cached" ]; then
				cs_stack_ls_note "  $(basename "$stack_dir") (cached integrated)"
			else
				cs_stack_ls_note "  $(basename "$stack_dir") ..."
			fi
		fi

		s_dir+=("$stack_dir"); s_branch+=("$branch"); s_age+=("$age_secs")
		s_hash+=("$hash"); s_cached+=("$cached"); s_nrepo+=("0")
	done
	[ ${#s_dir[@]} -gt 0 ] || return 0

	cs_stack_ls_warm_gh "$org_dir"

	local RUNDIR="" i j repo_dir
	if [ -n "$need_int" ]; then
		RUNDIR="$(mktemp -d -t codespace-ls.XXXXXX)"
		local work="$RUNDIR/work"; : > "$work"
		for i in "${!s_dir[@]}"; do
			[ -n "${s_cached[$i]}" ] && continue
			mkdir -p "$RUNDIR/$i"
			j=0
			for repo_dir in "${s_dir[$i]}"/*; do
				[ -e "$repo_dir/.git" ] || continue
				printf '%s\t%s\t%s\t%s\0' "$i" "$j" "$repo_dir" "${s_branch[$i]}" >> "$work"
				j=$((j + 1))
			done
			s_nrepo[$i]=$j
		done
		cs_run_bounded "$(cs_stack_ls_jobs)" cs_stack_ls_compute_unit < "$work"
	fi

	local -a e_dir=() e_branch=() e_age=() e_int=() e_szb=() e_szs=() e_detail=()
	for i in "${!s_dir[@]}"; do
		local int_str="" detail_packed="" is_done=""
		if [ -n "$need_int" ]; then
			if [ -n "${s_cached[$i]}" ]; then
				local total=0 d=""
				for repo_dir in "${s_dir[$i]}"/*; do
					[ -e "$repo_dir/.git" ] || continue
					total=$((total + 1))
					d="$d$(basename "$repo_dir")|yes|cached"$'\n'
				done
				int_str="$total/$total"; detail_packed="${d%$'\n'}"; is_done=1
			else
				local total="${s_nrepo[$i]}" integrated=0 d="" repo mark reason
				for ((j=0; j<total; j++)); do
					IFS='|' read -r repo mark reason < "$RUNDIR/$i/$j"
					[ "$mark" = "yes" ] && integrated=$((integrated + 1))
					d="$d$repo|$mark|$reason"$'\n'
				done
				int_str="$integrated/$total"; detail_packed="${d%$'\n'}"
				[ "$total" -gt 0 ] && [ "$integrated" -eq "$total" ] && is_done=1
				[ -n "$is_done" ] && cs_stack_cache_store "${s_dir[$i]}" "${s_hash[$i]}"
			fi

			# -i (without --rm) hard-filters to fully-integrated stacks.
			if [ -n "${flag_integrated:-}" ] && [ -z "${flag_rm:-}" ] && [ -z "$is_done" ]; then
				continue
			fi
		fi

		local size_bytes=0 size_str=""
		if [ -n "${flag_size:-}" ]; then
			size_bytes="$(cs_dir_size_bytes "${s_dir[$i]}")"
			size_str="$(cs_format_size "$size_bytes")"
		fi

		if [ -n "${flag_rm:-}" ]; then
			rm_dir+=("${s_dir[$i]}"); rm_age+=("${s_age[$i]}")
			rm_int+=("$int_str"); rm_szb+=("$size_bytes"); rm_szs+=("$size_str")
			rm_done+=("$is_done")
		else
			e_dir+=("${s_dir[$i]}"); e_branch+=("${s_branch[$i]}"); e_age+=("${s_age[$i]}")
			e_int+=("$int_str"); e_szb+=("$size_bytes"); e_szs+=("$size_str")
			e_detail+=("$detail_packed")
		fi
	done

	[ -n "$RUNDIR" ] && rm -rf "$RUNDIR"

	[ -n "${flag_rm:-}" ] && return 0
	[ ${#e_dir[@]} -gt 0 ] || return 0

	local order idx
	if [ -n "${flag_size:-}" ]; then
		order="$(for idx in "${!e_dir[@]}"; do printf '%s %s\n' "${e_szb[$idx]}" "$idx"; done | sort -k1,1nr -k2,2n | awk '{print $2}')"
	else
		order="$(for idx in "${!e_dir[@]}"; do echo "$idx"; done)"
	fi
	_cs_print_org_dir="$org_dir"; _cs_printed_header=""
	for idx in $order; do
		cs_stack_ls_emit_row "${e_dir[$idx]}" "${e_branch[$idx]}" "${e_age[$idx]}" "${e_int[$idx]}" "${e_szs[$idx]}" "${e_detail[$idx]}"
	done
}

# Open the review file in the user's git editor and block until it's closed
# (same resolution git uses: $GIT_EDITOR, core.editor, $VISUAL, $EDITOR, vi).
# Returns the editor's exit status.
cs_stack_ls_rm_open_editor() {
	local file="$1" editor
	editor="$(git var GIT_EDITOR 2>/dev/null)" || editor=""
	[ -n "$editor" ] || editor="${VISUAL:-${EDITOR:-vi}}"
	>&2 echo "==> review removals in your editor (mark rm/keep), then save & close"
	# via the shell so editors carrying args (e.g. 'code --wait') work, like git.
	sh -c "$editor \"\$1\"" sh "$file"
}

# Parse the (possibly edited) review file and remove every stack marked 'rm'.
# Skips comments, 'keep' lines, and anything that is not an existing stack_*
# directory. Per-repo safety checks happen inside cs_stack_remove.
cs_stack_ls_rm_apply() {
	local file="$1" removed=0 skipped=0 kept=0 line action path base
	while IFS= read -r line || [ -n "$line" ]; do
		line="${line#"${line%%[![:space:]]*}"}"   # ltrim
		[ -n "$line" ] || continue
		case "$line" in '#'*) continue ;; esac
		action="${line%%[[:space:]]*}"
		path="${line#"$action"}"
		path="${path#"${path%%[![:space:]]*}"}"     # ltrim path
		path="${path%% #*}"                          # drop trailing '# info' comment
		path="${path%"${path##*[![:space:]]}"}"      # rtrim path
		case "$action" in
			keep) kept=$((kept + 1)); continue ;;
			rm) ;;
			*) >&2 echo "warn: ignoring line with unknown action '$action'"; continue ;;
		esac
		[ -n "$path" ] || continue
		base="$(basename "$path")"
		if [ ! -d "$path" ] || [ "${base#stack_}" = "$base" ]; then
			>&2 echo "warn: skipping non-stack path: $path"
			continue
		fi
		>&2 echo "==> removing: $path"
		if cs_stack_remove "$path"; then removed=$((removed + 1)); else skipped=$((skipped + 1)); fi
	done < "$file"
	>&2 echo "==> removed: $removed, skipped: $skipped, kept: $kept"
}

# Emit one stack row, lazily printing the org header first, then the per-repo
# integration breakdown (under -i). Reads the dynamically-scoped
# _cs_print_org_dir / _cs_printed_header from cs_stack_ls.
# Args: stack_dir, branch, age_secs, integrated_str, size_str, detail_packed
cs_stack_ls_emit_row() {
	if [ -z "${flag_quiet:-}" ] && [ -z "${_cs_printed_header:-}" ]; then
		cs_stack_ls_print_org_header "$_cs_print_org_dir"
		_cs_printed_header=1
	fi
	cs_stack_ls_print_row "$1" "$2" "$3" "$4" "$5"
	if [ -n "${flag_integrated:-}" ] && [ -z "${flag_quiet:-}" ] && [ -n "$6" ]; then
		cs_stack_ls_print_integration_detail "$6"
	fi
}

# `codespace stack ls` orchestrator.
cs_stack_ls() {
	cs_stack_ls_parse_args "$@"

	local now
	now="$(date +%s)"

	# reset per-run caches (cs_stack_ls may be called repeatedly from a
	# long-lived shell that sourced us). persistent caches are reloaded from disk
	# on first lookup.
	_cs_stack_ls_default_cache=()
	_cs_gh_merged_cache=()
	_cs_gh_merged_trunc=()
	_cs_gh_warned=""
	_cs_gh_pcache_loaded=""
	_cs_gh_open_loaded=""
	_cs_stack_cache_loaded=""

	# slow modes (-i hits gh, --size walks the tree, --rm computes integration)
	# report progress to stderr so the run never looks stuck.
	local slow=""
	{ [ -n "${flag_integrated:-}" ] || [ -n "${flag_size:-}" ] || [ -n "${flag_rm:-}" ]; } && slow=1

	# integration is needed for -i (hard filter) and --rm (default rm/keep mark).
	local need_int=""
	{ [ -n "${flag_integrated:-}" ] || [ -n "${flag_rm:-}" ]; } && need_int=1

	# global review buffers, filled across orgs and rendered once at the end so
	# the file can be ordered rm-first regardless of which org a stack is in.
	local -a rm_dir=() rm_age=() rm_int=() rm_szb=() rm_szs=() rm_done=()

	local org_dirs
	org_dirs="$(cs_stack_ls_collect_org_dirs)"

	local _cs_print_org_dir _cs_printed_header org_dir
	while IFS= read -r org_dir; do
		[ -n "$org_dir" ] || continue
		cs_stack_ls_process_org "$org_dir"
	done <<< "$org_dirs"

	[ -n "${flag_rm:-}" ] || return 0

	if [ ${#rm_dir[@]} -eq 0 ]; then
		>&2 echo "==> nothing to remove"
		return 0
	fi

	local rm_todo
	rm_todo="$(mktemp -t codespace-rm-todo.XXXXXX)"
	cs_stack_ls_rm_render "$rm_todo"

	if [ -z "${CS_NO_INTERACTIVE:-}" ]; then
		if ! cs_stack_ls_rm_open_editor "$rm_todo"; then
			>&2 echo "==> editor exited non-zero; aborted (nothing removed)"
			rm -f "$rm_todo"
			return 0
		fi
	else
		>&2 echo "==> CS_NO_INTERACTIVE: removing integrated stacks (no editor)"
	fi

	cs_stack_ls_rm_apply "$rm_todo"
	rm -f "$rm_todo"
	return 0
}

test -n "${CS_STACK_LS_NO_RUN:-}" || {
	cs_stack_ls "$@"
	exit $?
}
