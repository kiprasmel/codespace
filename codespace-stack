#!/usr/bin/env bash

set -euo pipefail

DIRNAME="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"

# include-guard: codespace-stack <-> codespace-stack-ls source each other.
# returns when sourced (no-op for the second include); falls through when
# executed and the sentinel was somehow pre-set (unusual but harmless).
if [ -n "${_CS_STACK_LOADED:-}" ]; then
	return 0 2>/dev/null || true
fi
_CS_STACK_LOADED=1

# shellcheck source=codespace-utils
source "$DIRNAME/codespace-utils"

# shellcheck source=codespace-worktree
# `cs_stack_ls --rm` reuses cs_remove_safety_check / cs_remove_clone from here.
CS_WORKTREE_NO_RUN=1 source "$DIRNAME/codespace-worktree"

# shellcheck source=codespace-stack-ls
# defines cs_stack_ls + cs_stack_remove (sourced after utils/worktree because
# it references their helpers).
CS_STACK_LS_NO_RUN=1 source "$DIRNAME/codespace-stack-ls"

# codespace-stack: multi-repo codespace management

REPO_VALUES_INFO="\
- repo names (siblings in org directory)
- clone URLs
- objects: { \"name\": \"repo\", \"cloneURL\": \"url\" }"

STACK_HELP="\
Usage:
codespace stack [create] <branch> [-s stack_name] [-b base] [-r [host]] [--clone|--worktree] [--no-edit] [--dev]
codespace stack init [<path>]
codespace stack extend <name>[,<name2>]...
codespace stack ls [-g|--global] [-i|--integrated] [-S|--size] [--no-gh]
                   [--no-cache] [--older-than <duration>] [--by-commit-age]
                   [--rm] [-q|--quiet]

  <branch>       branch name to create across all repos in the stack.
  <name>         stack config name from stacks.json, or repo name from org directory.

optional flags:
  -b, --base <branch>
                 base branch to create from (default: remote HEAD).
  -s, --stack <stack_name>
                 stack preset from stacks.json. when omitted, inferred from
                 context: inside a stack_* dir by repo fingerprint; in a
                 standalone repo by preset key, repo membership (catch-all
                 presets all/default skipped when a specific preset also matches),
                 optional \"defaults\" map, or the \"default\" preset.
                 if ambiguous, prompts to pick (a to abort) unless
                 CS_NO_INTERACTIVE is set.
  -r, --remote [host]
                 create the stack on a remote ssh host instead of locally
                 (remote-only: no local worktrees, provisioned in parallel).
                 if [host] is omitted, resolves from \$CS_DEFAULT_REMOTE / config.
                 layout mirror: \$HOME/X -> remote:\$HOME/codespace/X.
                 a thin local stub at the usual local path tracks the remote stack.
                 run 'codespace sync' on it later to bring it local (materializes
                 + seeds the local worktrees from the remote).
  --clone        force clone mode (fresh clones for all repos).
  --worktree     force worktree mode (create worktrees from local repos).
  --no-edit      skip opening the new stack in an editor.
                 (also implied by \$CS_NO_EDIT or \$CS_NO_INTERACTIVE)
  --dev          after a successful remote (-r) create, run 'codespace dev' to
                 bring the stack's services up in its sandbox and forward them
                 to your laptop. no-op for local stacks (dev runs remotely).


env vars:
  CS_STACK_DEFAULT_CREATE_MODE
                 default creation mode: \"worktree\" (default) or \"clone\".
  CS_DEFAULT_REMOTE
                 default ssh target for -r/--remote when no host given.
                 overridden by explicit host or .codespace/remote file.
  CS_NO_INTERACTIVE
                 if set, skip interactive prompts and use defaults.
                 inferred if CURSOR_AGENT, CI, other vars are set.
                 implies CS_NO_EDIT.
  CS_NO_EDIT     if set, skip opening the new stack in an editor.
                 same effect as --no-edit.


config:
  stacks.json    lookup order at each walk-up level (first hit wins):
                   1. \$CODESPACE_CONFIG_ROOT/<rel>/.codespace/stacks.json
                   2. \$CODESPACE_CONFIG_ROOT/<rel>/stacks.json
                   3. <org_dir>/.codespace/stacks.json   (committed in org dir)
                   4. <org_dir>/stacks.json              (committed in org dir)
                 user-level (1-2) wins over org-committed (3-4).
                 the tool prints a note with the path used (and any ignored).
                 stack-post-create.sh is looked up next to the winning stacks.json
                 (runs when present and executable; per-preset customPostCreateScript
                 overrides; skipped when missing). -r/--remote ships it from the
                 user-level config dir (same path as stacks.json under
                 \$CODESPACE_CONFIG_ROOT). format: { \"version\": \"0\", \"stacks\": { ... } }
                 optional \"mixedProjects\": true for shared org dirs with unrelated
                 presets — stack dirs become stack_<preset>_<branch> (default false).
                 optional \"defaults\": { \"anchor-repo\": \"preset-id\" } maps repo
                 basenames to presets when the preset key differs from the repo name.
                 repo membership skips catch-all presets (all, default) when a more
                 specific preset also lists the repo.
                 preset inference (when -s omitted): inside stack_* -> repo fingerprint;
                 standalone repo -> preset key, repo membership, defaults map, \"default\".
                 if inference fails, prompts to pick a stack config (a to abort).
                 repo values:
$(echo "$REPO_VALUES_INFO" | sed 's/^/                   /')


sub-commands:
  create <branch> [-s stack_name] [-b base] [-r [host]] [--clone|--worktree] [--no-edit] [--dev]
                  create a new stack with repos from a stack configuration.
                  \"create\" is implied if omitted.
                  if no stacks.json is found, creates a single worktree instead
                  (with a note) rather than failing.
                  -r/--remote: provision the stack on a remote ssh host.
                  layout mirror: \$HOME/X -> remote:\$HOME/codespace/X.
                  remote-bootstrap.sh (per-repo, host-level) runs before
                  each repo's post-create.

  post-create [-s stack_name]
                  run the stack post-create script in an existing stack.
                  must be run from within a stack directory (or child).
                  [-s stack_name] specifies which stack config to use (default: \"default\").

  extend <name>[,<name2>]...
                  extend current stack with repos from stack configs or repo names.
                  first checks stacks.json, then falls back to repos in <org> directory.
                  must be run from within an existing stack directory (or child).
                  uses the same creation mode (clone/worktree) as existing repos.

  init [<path>]   create a stacks.json configuration file in CODESPACE_CONFIG_ROOT.
				  <path> is the directory where stacks will be held.
                  if <path> is provided, uses that directory.
                  otherwise, prompts to select current or parent directory.

  ls [-g|--global] [-i|--integrated] [-S|--size] [--no-gh] [--no-cache]
     [--older-than <duration>] [--by-commit-age] [--rm] [-q|--quiet]
                  list stacks in the current org (or all orgs with -g).
                  progress is reported on stderr for the slow modes (-i/--size);
                  integration checks run in parallel across stacks and repos.
                  filters:
                    -i, --integrated      keep only fully-integrated stacks. a
                                          repo's branch counts as integrated if
                                          it has a merged PR (looked up via gh,
                                          so squash/rebase merges are detected)
                                          or carries no commits beyond its base
                                          (tag-along repos don't block a stack).
                                          prints a per-repo breakdown (merged #N
                                          / empty / open / remote-gone) under
                                          each stack.
                                          merged PRs are cached (a merge is
                                          permanent) under
                                          \$CODESPACE_CONFIG_ROOT/.cache so
                                          repeat runs skip gh; a fully-integrated
                                          stack is also cached whole (keyed on its
                                          branch heads) and skipped entirely until
                                          it changes. no cache is kept if that var
                                          is unset.
                                          falls back to a local ancestor check
                                          (and a deleted-remote-branch heuristic)
                                          when gh is unavailable.
                    --no-gh               skip gh; use the local ancestor check
                                          only (offline; misses squash-merges).
                                          same as CS_NO_GH=1.
                    --no-cache            ignore the merged-PR and stack-level
                                          caches and recompute everything.
                    -S, --size            show a SIZE column (disk usage) and
                                          sort each org's stacks largest-first.
                    --older-than <dur>    keep only stacks older than <dur>.
                                          <dur> = 30d|2w|6h|45m|3600s.
                                          age = stack dir mtime by default.
                    --by-commit-age       use most recent commit timestamp across
                                          all repo branches as age, not dir mtime.
                    -g, --global          scan every org registered under
                                          \$CODESPACE_CONFIG_ROOT (deduped).
                    --rm                  review + delete stacks. opens a
                                          git-rebase-todo-style file listing
                                          every stack (integrated ones default
                                          'rm' and are listed first, the rest
                                          'keep'), with aligned info columns
                                          (INT [SIZE] AGE) and the instructions
                                          at the bottom; edit the actions, save
                                          and close, and the 'rm' ones are
                                          deleted. each repo is safety-checked
                                          (uncommitted/unpushed) and unsafe
                                          stacks are skipped with a warning; for
                                          force-delete use 'codespace rm -f'.
                                          with \$CS_NO_INTERACTIVE there's no
                                          editor: the integrated stacks are
                                          removed directly.
                    -q, --quiet           print only stack paths (pipe-friendly).
                  tuning (env vars):
                    CS_STACK_LS_JOBS      max parallel integration checks
                                          (default: CPU count, capped at 8).
                    CS_GH_JOBS            max parallel gh queries
                                          (default: min(jobs, 6)).
                    CS_GH_PR_LIMIT        fixed bulk merged-PR window per repo;
                                          default adapts to repo count queried
                                          (100-1000, ~constant total fetch). a
                                          merge beyond it is recovered with a
                                          targeted query for branches deleted
                                          on the remote.
                    CS_GH_OPEN_TTL        seconds an open branch is trusted before
                                          re-querying gh (default: 21600 = 6h).


examples:
  codespace stack create feature1              # create stack \"feature1\",
                                               # add repos defined in \"default\" stack config in stacks.json,
                                               # checkout each repo into \"feature1\" branch.

  codespace stack create feature1 -s config2    # create stack from \"config2\" config in stacks.json.
  codespace stack create feature1 -b develop   # base the stack off of the \"develop\" branch,
                                               # instead of repository's default branch.
  codespace stack create feature1 --clone      # create clones, instead of worktrees.
  codespace stack create feature1 -r myhost    # provision on remote myhost (no local copy).

  codespace stack post-create            # run stack post-create script (uses \"default\" config)
  codespace stack post-create -s full    # run post-create using \"full\" stack config

  codespace stack extend be              # add repos from \"be\" stack config
  codespace stack extend be,infra        # add repos from \"be\" and \"infra\" stack configs
  codespace stack extend backend         # add \"backend\" repo directly

  codespace stack init                   # create stacks.json config file (interactive)
  codespace stack init ~/projects/myorg  # create config for stacks held in specified path

  codespace stack ls                              # list stacks in current org
  codespace stack ls --integrated                 # only stacks merged into default
  codespace stack ls --older-than 30d             # only stacks older than 30 days
  codespace stack ls --integrated --rm            # delete merged stacks (safety-checked)
  codespace stack ls -g -q | xargs -I{} echo {}   # all stacks across orgs (paths only)

see also:
  codespace sync                         # mirror an existing local stack to a
                                         # remote ssh host, re-runnably (run it
                                         # from inside the stack dir).
"

cs_stack_main() {
	# handle help
	case "${1:-}" in
		-h|--help)
			echo "$STACK_HELP"
			exit 0
			;;
		"")
			>&2 echo "$STACK_HELP"
			exit 1
			;;
	esac

	# dispatch subcommands
	cmd="$1"
	shift

	case "$cmd" in
		create)
			cs_stack_create "$@"
			;;
		init)
			cs_stack_init "$@"
			;;
		init-repo)
			# internal subcommand used by cs_stack_create for parallel repo init
			cs_stack_init_repo "$@"
			;;
		run-remote-stack-post-create)
			# internal subcommand used by cs_stack_spawn_stack_post_create when remote
			cs_stack_run_remote_stack_post_create "$@"
			;;
		extend)
			cs_stack_extend "$@"
			;;
		post-create)
			cs_stack_post_create "$@"
			;;
		ls|list)
			cs_stack_ls "$@"
			;;
		*)
			# implied create
			cs_stack_create "$cmd" "$@"
			;;
	esac
}

# Parse and validate create arguments
# Sets globals: branch, stack_name, create_mode, base_branch, remote_host
cs_stack_create_parse_args() {
	branch=""
	stack_name=""
	base_branch=""
	remote_host=""
	stack_run_dev=""
	local mode_flag=""
	local remote_arg=""

	while [ $# -gt 0 ]; do
		case "$1" in
			-s|--stack)
				shift
				stack_name="${1:-}"
				test -n "$stack_name" || {
					>&2 echo "err: -s requires a stack name"
					exit 1
				}
				;;
			-b|--base)
				shift
				base_branch="${1:-}"
				test -n "$base_branch" || {
					>&2 echo "err: -b requires a base branch"
					exit 1
				}
				;;
		-r|--remote)
			if [ $# -gt 1 ] && [ "${2:0:1}" != "-" ] && [ -n "${2:-}" ]; then
				shift
				remote_arg="$1"
			else
				remote_arg="$CS_REMOTE_USE_DEFAULT"
			fi
			;;
		--clone)
			mode_flag="clone"
			;;
		--worktree)
			mode_flag="worktree"
			;;
		--no-edit)
			export CS_NO_EDIT=1
			;;
		--dev)
			stack_run_dev=1
			;;
		-*)
			>&2 echo "err: unknown option: $1"
			exit 1
			;;
			*)
				if [ -z "$branch" ]; then
					branch="$1"
				else
					>&2 echo "err: unexpected argument: $1"
					exit 1
				fi
				;;
		esac
		shift
	done

	test -n "$branch" || {
		>&2 echo "err: <branch> is required"
		>&2 echo "usage: codespace stack [create] <branch> [-s stack_name] [-r [host]]"
		exit 1
	}

	if [ -n "$mode_flag" ]; then
		create_mode="$mode_flag"
	elif [ -n "${CS_STACK_DEFAULT_CREATE_MODE:-}" ]; then
		create_mode="$CS_STACK_DEFAULT_CREATE_MODE"
	else
		create_mode="worktree"
	fi

	if [ -n "$remote_arg" ]; then
		remote_host="$(cs_resolve_remote "$remote_arg")" || {
			>&2 echo "err: -r/--remote: no ssh target resolved"
			>&2 echo "  pass an explicit host, set \$CS_DEFAULT_REMOTE,"
			>&2 echo "  or place an ssh target in \$CODESPACE_CONFIG_ROOT/<repo-id>/.codespace/remote"
			exit 1
		}
	fi
}

# Setup stack directory structure.
# Uses globals: branch, org_dir, stack_name, stacks_json, [remote_host]
# Sets globals: stack_dir, logs_dir, [stack_dest_rel]
cs_stack_create_setup_dirs() {
	stack_dir="$org_dir/$(cs_stack_format_dir_basename "$stack_name" "$branch" "$stacks_json")"
	if [ -d "$stack_dir" ]; then
		>&2 echo "err: stack directory already exists: $stack_dir"
		exit 1
	fi
	mkdir -p "$stack_dir"

	# logs always live locally (we orchestrate from local)
	logs_dir="$stack_dir/.stack-init-logs"
	mkdir -p "$logs_dir"

	if [ -n "${remote_host:-}" ]; then
		stack_dest_rel="$(cs_remote_relpath_for_local "$stack_dir")"
		>&2 echo "==> [$remote_host] creating remote stack dir ~/$stack_dest_rel"
		cs_ssh_script "$remote_host" "$stack_dest_rel" <<'REMOTE'
set -eu
mkdir -p "$(cs_rref "$1")"
REMOTE
	fi
}

# Setup tmux session if available
# Uses globals: branch, logs_dir
# Sets globals: use_tmux, tmux_session
cs_stack_create_setup_tmux() {
	use_tmux=""
	tmux_session=""
	if [ -z "${CS_NO_INTERACTIVE:-}" ] && command -v tmux >/dev/null 2>&1; then
		use_tmux=1
		tmux_session="stack-init-$(cs_cleanpath "$branch")"
		# kill existing session if present (e.g. from previous extend that was interrupted)
		tmux kill-session -t "$tmux_session" 2>/dev/null || true
		# create session with placeholder window (will be killed after repo windows are created)
		tmux new-session -d -s "$tmux_session" -n "_placeholder"
		# increase scrollback buffer so user can see all init logs
		tmux set-option -t "$tmux_session" history-limit 50000
		# enable mouse mode for terminal scrolling
		tmux set-option -t "$tmux_session" mouse on
	fi
}

# Pre-parse all repos into arrays
# Args: $1 = repos (newline-separated JSON entries)
# Uses globals: stack_dir, org_dir
# Sets globals: repo_names[], repo_clone_urls[], repo_dests[], repo_base_repos[]
cs_stack_create_prepare_repos() {
	local repos="$1"

	repo_names=()
	repo_clone_urls=()
	repo_dests=()
	repo_base_repos=()

	while IFS= read -r repo_entry; do
		test -n "$repo_entry" || continue

		cs_stack_parse_repo_entry "$repo_entry"
		# repo_name and clone_url are set by cs_stack_parse_repo_entry

		local local_repo_name="$repo_name"
		local local_clone_url="$clone_url"
		local repo_dest="$stack_dir/$local_repo_name"
		local base_repo="$org_dir/$local_repo_name"

		# Resolve clone URL if needed (repo doesn't exist locally and no URL provided)
		if [ -z "$local_clone_url" ] && [ ! -d "$base_repo/.git" ]; then
			local_clone_url="$(cs_infer_clone_url "$local_repo_name" "$org_dir")" || {
				>&2 echo "err: repo '$local_repo_name' not found locally and couldn't infer clone URL"
				>&2 echo "options:"
				>&2 echo "  a) clone the repo: git clone <url> $base_repo"
				>&2 echo "  b) add clone URL to stacks.json"
				exit 1
			}
		fi

		repo_names+=("$local_repo_name")
		repo_clone_urls+=("$local_clone_url")
		repo_dests+=("$repo_dest")
		repo_base_repos+=("$base_repo")
	done <<< "$repos"
}

# Spawn parallel repo init jobs.
# Uses globals: create_mode, repo_names[], repo_clone_urls[], repo_dests[],
#               repo_base_repos[], logs_dir, use_tmux, tmux_session, branch,
#               base_branch, [remote_host]
# Sets globals: repo_pids[]
cs_stack_create_spawn_jobs() {
	>&2 echo "==> initializing repos (${#repo_names[@]} repos, mode: $create_mode${remote_host:+, remote: $remote_host})"
	>&2 echo "  logs: \"$logs_dir\""
	if [ -n "$use_tmux" ]; then
		>&2 echo "  preview with:"
		echo "  tmux attach -t $tmux_session"
	fi

	repo_pids=()
	for i in "${!repo_names[@]}"; do
		local r_name="${repo_names[$i]}"
		local r_clone_url="${repo_clone_urls[$i]}"
		local r_dest="${repo_dests[$i]}"
		local r_base="${repo_base_repos[$i]}"
		local log_file="$logs_dir/$r_name.log"

		if [ -n "$use_tmux" ]; then
			tmux new-window -t "$tmux_session" -n "$r_name"
			tmux send-keys -t "$tmux_session:$r_name" \
				"$(cs_remote_child_env_prefix)'$DIRNAME/codespace-stack' init-repo '$create_mode' '$r_name' '$r_clone_url' '$r_dest' '$r_base' '$branch' '$base_branch' '${remote_host:-}' '${cs_init_no_stub:-}' 2>&1 | tee '$log_file' && { echo '=== [$r_name] Init complete. Press q to exit, or scroll with mouse ==='; col -b < '$log_file' | less -R --mouse +G; }" Enter
			tmux kill-window -t "$tmux_session:_placeholder" 2>/dev/null || true
		else
			(
				"$DIRNAME/codespace-stack" init-repo "$create_mode" "$r_name" "$r_clone_url" "$r_dest" "$r_base" "$branch" "$base_branch" "${remote_host:-}" "${cs_init_no_stub:-}"
			) >"$log_file" 2>&1 &
			repo_pids+=($!)
		fi
	done
}

# Run the stack-level post-create script remotely.
# Args: host, stack_name, branch, stack_dest_rel, rel_org, repos_csv, create_mode, script_basename
cs_stack_run_remote_stack_post_create() {
	local host="$1" sname="$2" br="$3" sdest_rel="$4" rorg="$5" rcsv="$6" cmode="$7" sbase="$8"
	cs_ssh_script "$host" "$sname" "$br" "$sdest_rel" "$rorg" "$rcsv" "$cmode" "$sbase" <<'REMOTE'
set -eu
export STACK_NAME="$1"
export STACK_BRANCH="$2"
export STACK_ROOT="$(cs_rref "$3")"
export STACK_CONFIG_ROOT="$(cs_rref "codespace-config/$4")"
export STACK_REPOS="$5"
export STACK_CREATE_MODE="$6"
export STACK_ORG_DIR="$(cs_rref "codespace/$4")"
script="$STACK_CONFIG_ROOT/$7"
[ -f "$script" ] && [ -x "$script" ] || exit 0
"$script"
REMOTE
}

# Spawn stack-level post-create script (runs in parallel with repo init jobs).
# When remote_host is set, runs the script on the remote (config dir already
# rsynced by cs_stack_remote_setup_host).
# Uses globals: stacks_json, stack_name, branch, stack_dir, create_mode, org_dir,
#               repo_names[], logs_dir, use_tmux, tmux_session, [remote_host],
#               [stack_dest_rel]
# Sets globals: stack_post_create_spawned, stack_post_create_pid
cs_stack_spawn_stack_post_create() {
	stack_post_create_spawned=""
	stack_post_create_pid=""

	if [ -z "${stacks_json:-}" ]; then
		return 0
	fi

	local script_path
	script_path="$(cs_stack_get_post_create_config "$stack_name" "$stacks_json")"
	[ -n "$script_path" ] || return 0

	local repos_csv log_file
	repos_csv="$(IFS=,; echo "${repo_names[*]}")"
	log_file="$logs_dir/stack-post-create.log"

	>&2 echo "==> running stack post-create script"
	>&2 echo "  script: $script_path"

	# build a single inline command for tmux/background to invoke
	local cmd
	if [ -n "${remote_host:-}" ]; then
		local config_rel script_basename
		config_rel="$(cs_stack_config_rel "$stacks_json" 2>/dev/null)" || config_rel=""
		[ -n "$config_rel" ] || return 0
		script_basename="$(basename "$script_path")"
		# Re-invoke this script (codespace-stack) so the helper is in scope.
		# The env prefix carries CS_WORKTREE_BASE across the tmux send-keys hop.
		cmd="$(cs_remote_child_env_prefix)'$DIRNAME/codespace-stack' run-remote-stack-post-create '$remote_host' '$stack_name' '$branch' '$stack_dest_rel' '$config_rel' '$repos_csv' '$create_mode' '$script_basename'"
	else
		cmd="STACK_NAME='$stack_name' STACK_PRESET='$stack_name' STACK_BRANCH='$branch' STACK_ROOT='$stack_dir' STACK_CONFIG_ROOT='$(dirname "$stacks_json")' STACK_REPOS='$repos_csv' STACK_CREATE_MODE='$create_mode' STACK_ORG_DIR='$org_dir' '$script_path'"
	fi

	if [ -n "$use_tmux" ]; then
		tmux new-window -t "$tmux_session" -n "stack-post-create"
		tmux send-keys -t "$tmux_session:stack-post-create" \
			"{ $cmd && echo '=== [stack-post-create] Done ===' || echo 'STACK_POST_CREATE_FAILED'; } 2>&1 | tee '$log_file'; echo 'Press q to exit, or scroll with mouse'; col -b < '$log_file' | less -R --mouse +G" Enter
	else
		(
			eval "$cmd" && echo "=== [stack-post-create] Done ===" || echo "STACK_POST_CREATE_FAILED"
		) >"$log_file" 2>&1 &
		stack_post_create_pid=$!
	fi

	stack_post_create_spawned=1
}

# Wait for jobs and print summary
# Args: $1 = mode ("create" or "extend")
# Uses globals: use_tmux, tmux_session, repo_names[], logs_dir, repo_pids[], stack_dir,
#               stack_post_create_spawned, stack_post_create_pid
# Print the first ERROR / fatal / err line in a log file, indented. Used by
# the failure summary so users see WHY a repo or the stack-post-create failed
# without opening the log. No-op when the log doesn't exist or has no
# matching line. Args: log_path, indent_prefix.
cs_stack__first_error_line() {
	local log="$1" indent="$2"
	[ -f "$log" ] || return 0
	local line
	line="$(grep -m1 -E '^(ERROR|fatal|err): ' "$log" 2>/dev/null)" || true
	[ -n "$line" ] || return 0
	>&2 echo "${indent}${line}"
}

cs_stack_create_wait_and_summarize() {
	local mode="${1:-create}"
	local failures=()
	local stack_post_create_failed=""

	if [ -n "$use_tmux" ]; then
		# build list of jobs to wait for
		local wait_jobs=("${repo_names[@]}")
		if [ -n "${stack_post_create_spawned:-}" ]; then
			wait_jobs+=("stack-post-create")
		fi

		cs_stack_tmux_wait "$logs_dir" "${wait_jobs[@]}"

		# check logs for failures
		for i in "${!repo_names[@]}"; do
			local r_name="${repo_names[$i]}"
			local log_file="$logs_dir/$r_name.log"
			if [ -f "$log_file" ] && grep -qE "CLONE_FAILED|POST_CREATE_FAILED" "$log_file"; then
				failures+=("$r_name")
			fi
		done

		# check stack post-create log
		if [ -n "${stack_post_create_spawned:-}" ]; then
			local stack_log="$logs_dir/stack-post-create.log"
			if [ -f "$stack_log" ] && grep -q "STACK_POST_CREATE_FAILED" "$stack_log"; then
				stack_post_create_failed=1
			fi
		fi
	else
		for i in "${!repo_pids[@]}"; do
			local pid="${repo_pids[$i]}"
			local r_name="${repo_names[$i]}"
			if ! wait "$pid"; then
				failures+=("$r_name")
			fi
		done

		# wait for stack post-create job
		if [ -n "${stack_post_create_spawned:-}" ] && [ -n "${stack_post_create_pid:-}" ]; then
			if ! wait "$stack_post_create_pid"; then
				stack_post_create_failed=1
			fi
		fi
	fi

	local verb
	if [ "$mode" = "extend" ]; then
		verb="extended"
	elif [ "$mode" = "init" ]; then
		verb="remote-initialized"
	else
		verb="created"
	fi

	echo
	if [ ${#failures[@]} -gt 0 ] || [ -n "$stack_post_create_failed" ]; then
		>&2 echo "==> stack $verb with errors:"
		if [ ${#failures[@]} -gt 0 ]; then
			>&2 echo "  failed repos: ${failures[*]}"
		fi
		if [ -n "$stack_post_create_failed" ]; then
			>&2 echo "  stack post-create script failed"
			cs_stack__first_error_line "$logs_dir/stack-post-create.log" "    "
		fi
		>&2 echo "  logs: $logs_dir"
		if [ -n "$use_tmux" ]; then
			>&2 echo "    tmux session: tmux attach -t $tmux_session"
		fi
	else
		>&2 echo "==> stack $verb successfully"
		# clean up logs on success (unless DEBUG is set)
		if [ -z "${DEBUG:-}" ]; then
			rm -rf "$logs_dir"
		else
			>&2 echo "  logs: $logs_dir"
		fi
		# tmux session is kept alive for user to attach and inspect
	fi

	echo "  $stack_dir"
	cs_stack_prefetch_remote_statuses "${failures[@]+"${failures[@]}"}"
	cs_stack_print_repo_status "${failures[@]+"${failures[@]}"}"
	echo ""
}

# Resolve ssh host for a remote stub repo in a stack summary.
# Args: repo_dest [stack_dir]
# Stdout: host if repo is a remote stub; empty otherwise
# Resolution: per-repo marker host= → stack_dir marker host= → remote_host global
cs_stack_repo_remote_host() {
	local repo_dest="$1"
	local _stack_dir="${2:-${stack_dir:-}}"
	local host=""

	if cs_remote_marker "$repo_dest"; then
		host="$(cs_remote_marker_get "$repo_dest" host)"
	fi
	if [ -z "$host" ] && [ -n "$_stack_dir" ] && cs_remote_marker "$_stack_dir"; then
		host="$(cs_remote_marker_get "$_stack_dir" host)"
	fi
	if [ -z "$host" ]; then
		host="${remote_host:-}"
	fi
	echo "$host"
}

cs_stack_repo_name_in_list() {
	local repo_name="$1"; shift
	local candidate
	for candidate in "$@"; do
		[ "$candidate" = "$repo_name" ] && return 0
	done
	return 1
}

_cs_stack_remote_status_names=()
_cs_stack_remote_status_values=()

cs_stack_remote_status_set() {
	local repo_name="$1" status="$2" i
	for i in "${!_cs_stack_remote_status_names[@]}"; do
		if [ "${_cs_stack_remote_status_names[$i]}" = "$repo_name" ]; then
			_cs_stack_remote_status_values[$i]="$status"
			return 0
		fi
	done
	_cs_stack_remote_status_names+=("$repo_name")
	_cs_stack_remote_status_values+=("$status")
}

cs_stack_remote_status_get() {
	local repo_name="$1" i
	for i in "${!_cs_stack_remote_status_names[@]}"; do
		if [ "${_cs_stack_remote_status_names[$i]}" = "$repo_name" ]; then
			echo "${_cs_stack_remote_status_values[$i]}"
			return 0
		fi
	done
	return 1
}

# Query every successful remote stub, batching repos into one ssh call per host.
# Args: failed_repo_names... (may be empty)
# Sets: remote status cache entries as status;base;ahead
cs_stack_prefetch_remote_statuses() {
	local -a failed=("$@")
	local -a hosts=()
	_cs_stack_remote_status_names=()
	_cs_stack_remote_status_values=()

	local i repo_name repo_dest host existing
	for i in "${!repo_names[@]}"; do
		repo_name="${repo_names[$i]}"
		repo_dest="${repo_dests[$i]}"
		cs_remote_marker "$repo_dest" || continue
		cs_stack_repo_name_in_list "$repo_name" "${failed[@]}" && continue
		host="$(cs_stack_repo_remote_host "$repo_dest")"
		[ -n "$host" ] || continue

		existing=""
		local candidate
		for candidate in "${hosts[@]}"; do
			[ "$candidate" = "$host" ] && existing=1 && break
		done
		[ -n "$existing" ] || hosts+=("$host")
	done

	for host in "${hosts[@]}"; do
		local -a specs=()
		for i in "${!repo_names[@]}"; do
			repo_name="${repo_names[$i]}"
			repo_dest="${repo_dests[$i]}"
			cs_remote_marker "$repo_dest" || continue
			cs_stack_repo_name_in_list "$repo_name" "${failed[@]}" && continue
			[ "$(cs_stack_repo_remote_host "$repo_dest")" = "$host" ] || continue

			local dest_rel repo_branch
			dest_rel="$(cs_remote_marker_get "$repo_dest" relpath)"
			if [ -z "$dest_rel" ]; then
				dest_rel="$(cs_remote_relpath_for_local "$repo_dest" 2>/dev/null)" || dest_rel=""
			fi
			repo_branch="$(cs_remote_marker_get "$repo_dest" branch)"
			[ -n "$repo_branch" ] || repo_branch="$branch"
			[ -n "$dest_rel" ] || continue
			specs+=("$repo_name|$dest_rel|$repo_branch|${base_branch:-}")
		done
		[ "${#specs[@]}" -gt 0 ] || continue

		local status_output
		status_output="$(cs_stack_remote_branch_status_batch "$host" "${specs[@]}" 2>/dev/null)" || status_output=""
		local status_name s b n
		while IFS=';' read -r status_name s b n; do
			[ -n "$status_name" ] || continue
			case "$s" in
				new|local|remote) cs_stack_remote_status_set "$status_name" "$s;$b;$n" ;;
				*)                cs_stack_remote_status_set "$status_name" "?;?;0" ;;
			esac
		done <<< "$status_output"
	done
}

# Print per-repo branch status block under the stack dir line.
# Args: failed_repo_names... (may be empty)
# Uses globals: repo_names[], repo_dests[], branch, base_branch, stack_dir
cs_stack_print_repo_status() {
	local -a failed=("$@")
	local -a row_states=() row_bases=() row_hosts=() row_failed=()
	local max_repo=0 max_state=0 max_base=0
	local i r_name state base host is_failed
	for i in "${!repo_names[@]}"; do
		r_name="${repo_names[$i]}"
		state=""
		base=""
		host=""
		is_failed=""

		cs_stack_repo_name_in_list "$r_name" "${failed[@]}" && is_failed=1

		if [ -n "$is_failed" ]; then
			state="(failed)"
		elif cs_remote_marker "${repo_dests[$i]}"; then
			host="$(cs_stack_repo_remote_host "${repo_dests[$i]}")"
			[ -n "$host" ] && host="@$host"
			local status_info
			status_info="$(cs_stack_remote_status_get "$r_name")" || status_info="?;?;0"
			local s b n
			IFS=';' read -r s b n <<< "$status_info"
			case "$s" in
				new)    state="new" ;;
				local)  state="unpublished" ;;
				remote) state="existing" ;;
				*)      state="?" ;;
			esac
			if [ "$state" != "?" ] && [ -n "$b" ] && [ "$b" != "?" ]; then
				base="($b)"
			fi
		elif [ -e "${repo_dests[$i]}/.git" ]; then
			local status_info s b n
			status_info="$(cs_branch_status "${repo_dests[$i]}" "$branch" "${base_branch:-}" 2>/dev/null)" || status_info="?;?;0"
			IFS=';' read -r s b n <<< "$status_info"
			case "$s" in
				remote) state="remote +$n" ;;
				local)  state="local +$n" ;;
				new)    state="new" ;;
				*)      state="?" ;;
			esac
			if [ "$state" != "?" ] && [ -n "$b" ] && [ "$b" != "?" ]; then
				base="($b)"
			fi
		else
			state="?"
		fi

		row_states[$i]="$state"
		row_bases[$i]="$base"
		row_hosts[$i]="$host"
		row_failed[$i]="$is_failed"
		[ "${#r_name}" -gt "$max_repo" ] && max_repo=${#r_name}
		[ "${#state}" -gt "$max_state" ] && max_state=${#state}
		[ "${#base}" -gt "$max_base" ] && max_base=${#base}
	done

	for i in "${!repo_names[@]}"; do
		r_name="${repo_names[$i]}"
		state="${row_states[$i]}"
		base="${row_bases[$i]}"
		host="${row_hosts[$i]}"

		printf "    %-${max_repo}s  " "$r_name"
		if [ -n "$base" ] || [ -n "$host" ]; then
			printf "%-${max_state}s" "$state"
			if [ -n "$host" ]; then
				[ "$max_base" -gt 0 ] && printf "  %-${max_base}s" "$base"
				printf "  %s" "$host"
			else
				printf "  %s" "$base"
			fi
		else
			printf "%s" "$state"
		fi
		printf "\n"

		# under each failed repo, surface the first ERROR/fatal/err line from
		# its log so the user doesn't have to open the file to see why.
		if [ -n "${row_failed[$i]}" ] && [ -n "${logs_dir:-}" ]; then
			cs_stack__first_error_line "$logs_dir/$r_name.log" "      "
		fi
	done
}

# Open editor for the stack.
# Uses globals: stack_dir, [remote_host], [stack_dest_rel]
cs_stack_create_open_editor() {
	if [ -n "${CS_NO_EDIT:-}" ]; then
		return 0  # --no-edit / CS_NO_EDIT / CS_NO_INTERACTIVE
	fi
	>&2 echo "==> opening editor"
	local editor="${GUI_EDITOR:-$EDITOR}"
	if [ -z "$editor" ]; then
		>&2 echo "warn: neither \$GUI_EDITOR nor \$EDITOR env var set, cannot open stack with editor"
		return 0
	fi

	if [ -n "${remote_host:-}" ]; then
		cs_open_editor_remote "$remote_host" "$stack_dest_rel" &
	else
		(unset GIT_DIR GIT_WORK_TREE; "$editor" --new-window "$stack_dir") &
	fi
}

# Stack-level remote prep (layer 1 + config rsync). Runs ONCE at the stack level
# before spawning per-repo jobs, since these are host-scoped, not repo-scoped.
# Uses globals: remote_host, repo_names[], stack_name, stacks_json, org_dir
cs_stack_remote_setup_host() {
	test -n "${remote_host:-}" || return 0
	cs_remote_self_install "$remote_host"
	cs_remote_probe "$remote_host"

	# rsync each repo's user-level config dir + the org-level (stacks.json) config dir.
	if [ -n "${CODESPACE_CONFIG_ROOT:-}" ]; then
		local config_rel
		config_rel="$(cs_stack_config_rel "${stacks_json:-}" 2>/dev/null)" || config_rel=""
		if [ -n "$config_rel" ]; then
			[ -d "$CODESPACE_CONFIG_ROOT/$config_rel/.codespace" ] && \
				cs_rsync_config_to_remote "$remote_host" "$config_rel" >/dev/null

			# Mirror the org-config root's TOP-LEVEL FILES to the remote config
			# dir so STACK_CONFIG_ROOT is complete there: stack-post-create.sh
			# (lives at the root, not under .codespace/) AND every sibling regular
			# file it may ln/cp (AGENTS.md, TODO.md, stacks.json, ...). The
			# '- /*/' filter excludes every top-level directory (.codespace/ and
			# the per-repo config dirs are shipped separately), so only the root's
			# regular files are sent.
			if [ -d "$CODESPACE_CONFIG_ROOT/$config_rel" ]; then
				cs_ssh_script "$remote_host" "$config_rel" <<'REMOTE'
mkdir -p "$(cs_rref "codespace-config/$1")"
REMOTE
				cs_rsync_to_remote "$remote_host" --filter='- /*/' \
					"$CODESPACE_CONFIG_ROOT/$config_rel/" "$CS_CFG_PREFIX/$config_rel/" >/dev/null
			fi
		fi

		# per-repo config dirs
		if [ -n "$config_rel" ]; then
			local r
			for r in "${repo_names[@]}"; do
				local rel_repo="$config_rel/$r"
				[ -d "$CODESPACE_CONFIG_ROOT/$rel_repo" ] && \
					cs_rsync_config_to_remote "$remote_host" "$rel_repo" >/dev/null
			done
		fi
	fi
	# best-effort sync; a missing optional dir mustn't fail the create flow.
	return 0
}

# Run the org/stack-common remote-bootstrap.sh ONCE, before spawning the
# parallel per-repo jobs (shared deps: base tools, language runtimes, inner dockerd). Runs
# inside the sandbox (remote_host is the sandbox alias when CS_SANDBOX is
# active); the stack config dir was already rsynced by cs_stack_remote_setup_host.
# Non-fatal: a failure is surfaced but doesn't abort the create — per-repo jobs
# still run and record their own setup_status (mirrors the rc-2 philosophy).
# Uses globals: remote_host, stacks_json, stack_name, branch, repo_names[]
cs_stack_run_org_bootstrap() {
	test -n "${remote_host:-}" || return 0
	local sj="${stacks_json:-}"
	# init-remote-existing (open -r / sync) doesn't carry stacks_json; resolve it
	# from the stack's org dir so re-provisioning also gets the shared toolchain.
	if [ -z "$sj" ] && [ -n "${org_dir:-}" ]; then
		sj="$(cs_stack_resolve_config_at_quiet "$org_dir" 2>/dev/null)" || sj=""
	fi
	[ -n "$sj" ] || return 0
	local config_rel repos_csv
	config_rel="$(cs_stack_config_rel "$sj" 2>/dev/null)" || return 0
	[ -n "$config_rel" ] || return 0
	repos_csv="$(IFS=,; echo "${repo_names[*]}")"
	>&2 echo "==> [$remote_host] running org-common bootstrap (once, before per-repo jobs)"
	cs_remote_run_org_bootstrap "$remote_host" "$config_rel" "$repos_csv" "${stack_name:-}" "${branch:-}" || {
		>&2 echo "warn: [$remote_host] org-common bootstrap failed; per-repo jobs will still run and report status"
		return 0
	}
}

# Write the local stack stub marker (.codespace-remote) for find/edit/rm.
# Uses globals: remote_host, stack_dir, stack_dest_rel, branch
cs_stack_write_remote_marker() {
	test -n "${remote_host:-}" || return 0
	local sbx=()
	mapfile -t sbx < <(cs_sandbox_marker_fields "$remote_host")
	cs_remote_marker_write "$stack_dir" \
		"host=$remote_host" \
		"relpath=$stack_dest_rel" \
		"kind=stack" \
		"branch=$branch" \
		${sbx[@]+"${sbx[@]}"}
}

# Forward already-parsed create args to a single-repo worktree create.
# Uses globals from cs_stack_create_parse_args: branch, base_branch, remote_host, create_mode.
cs_stack_create_fallback_worktree() {
	local args=("$branch")
	[ -n "$base_branch" ] && args+=(-b "$base_branch")
	[ -n "$remote_host" ] && args+=(-r "$remote_host")
	[ "$create_mode" = "clone" ] && args+=(--clone)
	cs_worktree_create "${args[@]}"
}

# Enter sandbox mode for a remote create: ensure the per-stack DinD sandbox on
# the resolved host and retarget every remote op onto it (remote_host -> ssh
# alias, CS_WORKTREE_BASE -> /codespaces/<slug>). No-op unless CS_SANDBOX is
# enabled AND the cloud module is available. Uses/sets global: remote_host.
cs_stack_create_retarget_sandbox() {
	test -n "${remote_host:-}" || return 0
	cs_sandbox_active || return 0
	>&2 echo "==> [$remote_host] ensuring per-stack sandbox for '$branch'"
	cs_sandbox_retarget "$remote_host" "$branch" || {
		>&2 echo "err: [$remote_host] could not ensure sandbox for '$branch'"
		exit 1
	}
	>&2 echo "==> sandbox ready; remote ops retargeted to $CS_SANDBOX_ALIAS ($CS_WORKTREE_BASE)"
	remote_host="$CS_SANDBOX_ALIAS"
}

cs_stack_create() {
	cs_stack_create_parse_args "$@"

	# no stacks.json anywhere -> create a single worktree instead of failing.
	if ! cs_stack_search_config >/dev/null 2>&1; then
		>&2 echo "note: no stacks.json detected; creating a single worktree instead"
		>&2 echo "  (run 'codespace stack init' to enable multi-repo stacks)"
		[ -z "$stack_name" ] || >&2 echo "  note: ignoring -s $stack_name (no stacks.json)"
		cs_stack_create_fallback_worktree
		return
	fi

	# find stacks.json config and org directory
	# cs_stack_find_config outputs two lines: config_path and org_dir
	config_output="$(cs_stack_find_config)"
	stacks_json="$(echo "$config_output" | head -n1)"
	org_dir="$(echo "$config_output" | tail -n1)"

	stack_name="$(cs_stack_resolve_default_preset "$stacks_json" "$stack_name")"

	# get repos for the stack
	repos="$(cs_stack_get_repos "$stack_name" "$stacks_json")"
	test -n "$repos" || {
		>&2 echo "err: stack '$stack_name' not found or empty in $stacks_json"
		exit 1
	}

	cs_stack_create_retarget_sandbox
	cs_stack_create_setup_dirs
	cs_stack_create_setup_tmux
	cs_stack_create_prepare_repos "$repos"
	cs_stack_remote_setup_host
	cs_stack_write_remote_marker
	cs_write_open_script "$stack_dir"
	cs_stack_create_open_editor
	cs_stack_run_org_bootstrap
	cs_stack_create_spawn_jobs
	cs_stack_spawn_stack_post_create
	cs_stack_create_wait_and_summarize "create"
	cs_stack_create_maybe_dev
}

# --dev: after a successful provision, bring the stack's services up + forward
# them (codespace dev). Only for a remote stack (dev runs in the sandbox).
# Uses globals: stack_run_dev, remote_host, stack_dir
cs_stack_create_maybe_dev() {
	[ -n "${stack_run_dev:-}" ] || return 0
	test -n "${remote_host:-}" || {
		>&2 echo "note: --dev is a no-op for a local stack (dev runs in the remote sandbox)"
		return 0
	}
	declare -f cs_dev >/dev/null 2>&1 || {
		>&2 echo "warn: --dev: the codespace-dev client isn't available; run 'codespace dev $stack_dir' manually"
		return 0
	}
	>&2 echo "==> --dev: starting dev for the new stack"
	cs_dev "$stack_dir" || >&2 echo "warn: --dev: 'codespace dev' failed; the stack is provisioned — retry with 'codespace dev $stack_dir'"
}

# extend an existing stack with repos from other stack configurations or repo names
cs_stack_extend() {
	# parse arguments
	local extend_args="${1:-}"
	test -n "$extend_args" || {
		>&2 echo "err: <stack_name|repo_name> is required"
		>&2 echo "usage: codespace stack extend <stack_name>[,<stack_name2>]..."
		>&2 echo "  accepts stack config names from stacks.json, or repo names from org directory"
		exit 1
	}

	# detect current stack
	local detect_output
	detect_output="$(cs_stack_detect_current)" || {
		>&2 echo "err: not inside a stack directory"
		>&2 echo "hint: run this command from within a stack_* directory or a repo inside one"
		exit 1
	}

	stack_dir="$(echo "$detect_output" | sed -n '1p')"
	branch="$(echo "$detect_output" | sed -n '2p')"
	org_dir="$(echo "$detect_output" | sed -n '3p')"

	>&2 echo "==> extending stack: $stack_dir"
	>&2 echo "  branch: $branch"

	# detect creation mode from existing repos
	create_mode="$(cs_stack_detect_mode "$stack_dir")"
	>&2 echo "  mode: $create_mode (auto-detected from existing repos)"

	# base_branch not used for extend (uses default branch of each repo)
	base_branch=""

	# find stacks.json config (optional for repo-name mode)
	# note: stacks_json is global so cs_stack_spawn_stack_post_create can access it
	stacks_json="$(cs_stack_resolve_config_at "$org_dir" || true)"

	# stack_name for extend uses a special marker (only global post-create settings apply)
	stack_name="_extend"

	# get list of existing repos/directories in the stack
	local existing_repos=()
	for repo_dir in "$stack_dir"/*; do
		test -d "$repo_dir" || continue
		existing_repos+=("$(basename "$repo_dir")")
	done

	# collect repos from all specified stack configs or repo names
	local all_new_repos=""
	IFS=',' read -ra arg_names <<< "$extend_args"
	for arg_name in "${arg_names[@]}"; do
		# trim whitespace
		arg_name="$(echo "$arg_name" | xargs)"
		test -n "$arg_name" || continue

		local repos=""
		local source_type=""

		# first, try as stack config name
		if [ -n "$stacks_json" ]; then
			repos="$(cs_stack_get_repos "$arg_name" "$stacks_json" 2>/dev/null)" && source_type="stack"
		fi

		# if not found as stack config, try as repo name in org directory
		if [ -z "$source_type" ]; then
			if [ -d "$org_dir/$arg_name/.git" ]; then
				# repo exists locally - create a simple repo entry
				repos="\"$arg_name\""
				source_type="repo"
			else
				# check if we can infer clone URL
				local inferred_url
				if inferred_url="$(cs_infer_clone_url "$arg_name" "$org_dir" 2>/dev/null)"; then
					repos="{ \"name\": \"$arg_name\", \"cloneURL\": \"$inferred_url\" }"
					source_type="repo (inferred)"
				else
					>&2 echo "err: '$arg_name' not found as stack config or repo in $org_dir"
					exit 1
				fi
			fi
		fi

		>&2 echo "  adding from $source_type: $arg_name"

		# filter out repos that already exist
		while IFS= read -r repo_entry; do
			test -n "$repo_entry" || continue

			cs_stack_parse_repo_entry "$repo_entry"
			# repo_name is set by cs_stack_parse_repo_entry

			# check if already exists
			local exists=""
			for existing in "${existing_repos[@]}"; do
				if [ "$existing" = "$repo_name" ]; then
					exists=1
					break
				fi
			done

			if [ -n "$exists" ]; then
				>&2 echo "    skipping '$repo_name' (already in stack)"
			else
				if [ -z "$all_new_repos" ]; then
					all_new_repos="$repo_entry"
				else
					all_new_repos="$all_new_repos"$'\n'"$repo_entry"
				fi
				# add to existing list to avoid duplicates across configs
				existing_repos+=("$repo_name")
			fi
		done <<< "$repos"
	done

	# check if there are any new repos to add
	test -n "$all_new_repos" || {
		>&2 echo "==> no new repos to add (all already in stack)"
		exit 0
	}

	# setup logs directory
	logs_dir="$stack_dir/.stack-extend-logs"
	mkdir -p "$logs_dir"

	# setup tmux if available
	cs_stack_create_setup_tmux

	# prepare and spawn jobs for new repos
	cs_stack_create_prepare_repos "$all_new_repos"
	cs_stack_create_spawn_jobs
	cs_stack_spawn_stack_post_create
	cs_stack_create_wait_and_summarize "extend"
}

# run stack post-create script in an existing stack
# Uses cs_stack_spawn_stack_post_create internally to avoid code duplication
cs_stack_post_create() {
	stack_name="default"
	while [ $# -gt 0 ]; do
		case "$1" in
			-s|--stack) shift; stack_name="${1:?err: -s requires a stack name}" ;;
			-*) >&2 echo "err: unknown option: $1"; exit 1 ;;
			*) >&2 echo "err: unexpected argument: $1"; exit 1 ;;
		esac
		shift
	done

	# detect current stack
	local detect_output
	detect_output="$(cs_stack_detect_current)" || {
		>&2 echo "err: not inside a stack directory"
		exit 1
	}
	stack_dir="$(echo "$detect_output" | sed -n '1p')"
	branch="$(echo "$detect_output" | sed -n '2p')"
	org_dir="$(echo "$detect_output" | sed -n '3p')"

	# find stacks.json
	stacks_json="$(cs_stack_resolve_config_at "$org_dir" || true)"
	[ -n "$stacks_json" ] || { >&2 echo "err: stacks.json not found for org dir: $org_dir"; exit 1; }

	# set up globals for cs_stack_spawn_stack_post_create
	repo_names=()
	for d in "$stack_dir"/*; do [ -d "$d/.git" ] && repo_names+=("$(basename "$d")"); done
	create_mode="$(cs_stack_detect_mode "$stack_dir")"
	logs_dir="$(mktemp -d -t stack-post-create.XXXXXX)"

	# set up tmux and run
	cs_stack_create_setup_tmux
	cs_stack_spawn_stack_post_create

	# wait for completion
	if [ -n "${stack_post_create_spawned:-}" ]; then
		if [ -n "$use_tmux" ]; then
			cs_stack_tmux_wait "$logs_dir" "stack-post-create"
			# check result
			if grep -q "STACK_POST_CREATE_FAILED" "$logs_dir/stack-post-create.log" 2>/dev/null; then
				>&2 echo "==> stack post-create failed"
				>&2 echo "  logs: $logs_dir"
				exit 1
			fi
		else
			if ! wait "$stack_post_create_pid"; then
				>&2 echo "==> stack post-create failed"
				>&2 echo "  logs: $logs_dir"
				exit 1
			fi
		fi
		>&2 echo "==> stack post-create completed"
		[ -z "${DEBUG:-}" ] && rm -rf "$logs_dir"
	fi
}

# Wait for tmux repo init jobs to complete by polling log files
# Args: logs_dir, repo_names...
cs_stack_tmux_wait() {
	local wait_logs_dir="$1"
	shift

	# poll until all jobs have completed (check for Done or failure markers in logs)
	while true; do
		remaining=0
		for r_name in "$@"; do
			local log_file="$wait_logs_dir/$r_name.log"
			# check if log file exists and contains completion marker
			# (pattern is lenient to handle buffering/whitespace variations)
			if [ -f "$log_file" ]; then
				if grep -qE "\[$r_name\] Done ===|CLONE_FAILED|POST_CREATE_FAILED|STACK_POST_CREATE_FAILED" "$log_file"; then
					continue  # this job is done
				fi
			fi
			remaining=$((remaining + 1))
		done
		[ "$remaining" -eq 0 ] && break
		sleep 1
	done
}

# Find stacks.json in a directory.
# Prefers <dir>/.codespace/stacks.json over <dir>/stacks.json.
# Args: dir
# Stdout: path to stacks.json, or empty
cs_stack_find_in_dir() {
	cs_stack_find_stacks_json_in_dir "$1"
}

# Resolve stacks.json for a given org directory (no walk-up).
# Precedence (first hit wins):
#   1. $CODESPACE_CONFIG_ROOT/<rel>/.codespace/stacks.json
#   2. $CODESPACE_CONFIG_ROOT/<rel>/stacks.json
#   3. <org_dir>/.codespace/stacks.json
#   4. <org_dir>/stacks.json
# Args: org_dir
# Stdout: stacks_json path, or nothing
# Stderr: notes about chosen/ignored paths
cs_stack_resolve_config_at() {
	local org_dir="$1" user_cfg="" org_cfg=""

	if [ -n "${CODESPACE_CONFIG_ROOT:-}" ]; then
		local rel
		rel="$(realpath "$org_dir" --relative-to="$HOME" 2>/dev/null)" || rel="$org_dir"
		user_cfg="$(cs_stack_find_stacks_json_in_dir "$CODESPACE_CONFIG_ROOT/$rel" 2>/dev/null)" || true
	fi
	org_cfg="$(cs_stack_find_stacks_json_in_dir "$org_dir" 2>/dev/null)" || true

	if [ -n "$user_cfg" ]; then
		>&2 echo "note: using stacks.json: $user_cfg"
		[ -n "$org_cfg" ] && >&2 echo "note: ignoring org-committed stacks.json: $org_cfg"
		echo "$user_cfg"
		return 0
	fi
	if [ -n "$org_cfg" ]; then
		>&2 echo "note: using stacks.json: $org_cfg"
		echo "$org_cfg"
		return 0
	fi
	return 1
}

# Same as cs_stack_resolve_config_at but without stderr notes.
cs_stack_resolve_config_at_quiet() {
	cs_stack_find_stacks_json_at "$1" 2>/dev/null
}

# Find stacks.json config by walking up from org_dir.
# At each level, applies cs_stack_resolve_config_at (user-level beats org-committed).
# Outputs two lines:
#   Line 1: config file path
#   Line 2: org directory where config was found (use this for stack creation)
# Pure walk-up search for stacks.json (no prompts, no error output, no exit).
# Stdout on hit: config_path, org_dir, levels_up (3 lines). Returns 1 if none.
# Note: cs_stack_resolve_config_at still prints "using/ignoring" notes to stderr.
cs_stack_search_config() {
	local start_dir current_dir levels_up=0 config_path
	start_dir="$(cs_stack_get_org_dir)"
	current_dir="$start_dir"

	while true; do
		if config_path="$(cs_stack_resolve_config_at "$current_dir")" && [ -n "$config_path" ]; then
			echo "$config_path"
			echo "$current_dir"
			echo "$levels_up"
			return 0
		fi

		# check if we've reached home or root
		if [ "$current_dir" = "$HOME" ] || [ "$current_dir" = "/" ]; then
			break
		fi

		current_dir="$(dirname "$current_dir")"
		levels_up=$((levels_up + 1))
	done
	return 1
}

cs_stack_find_config() {
	local start_dir search_output config_path current_dir levels_up answer
	start_dir="$(cs_stack_get_org_dir)"

	if ! search_output="$(cs_stack_search_config)"; then
		>&2 echo "err: stacks.json not found"
		>&2 echo "searched from: $start_dir (walked up to \$HOME or /)"
		>&2 echo "expected locations at each level (first hit wins):"
		if [ -n "${CODESPACE_CONFIG_ROOT:-}" ]; then
			>&2 echo "  \$CODESPACE_CONFIG_ROOT/<rel>/.codespace/stacks.json"
			>&2 echo "  \$CODESPACE_CONFIG_ROOT/<rel>/stacks.json"
		else
			>&2 echo "  (user-level search skipped; \$CODESPACE_CONFIG_ROOT not set)"
		fi
		>&2 echo "  <dir>/.codespace/stacks.json"
		>&2 echo "  <dir>/stacks.json"
		>&2 echo "hint: run 'codespace stack init' to create one"
		exit 1
	fi

	config_path="$(echo "$search_output" | sed -n '1p')"
	current_dir="$(echo "$search_output" | sed -n '2p')"
	levels_up="$(echo "$search_output" | sed -n '3p')"

	# if we went more than 1 level up, ask for confirmation
	if [ "$levels_up" -gt 1 ]; then
		if [ -n "${CS_NO_INTERACTIVE:-}" ]; then
			>&2 echo "found stacks.json $levels_up levels up, stack will be created in: $current_dir (auto-accepting, CS_NO_INTERACTIVE set)"
		else
			>&2 printf "found stacks.json $levels_up levels up, stack will be created in: $current_dir. use? [y/n] "
			read -r answer </dev/tty
			case "$answer" in
				y|Y|yes|Yes) ;;
				*)
					>&2 echo "aborted"
					exit 1
					;;
			esac
		fi
	fi

	# output config path and the matched org directory
	echo "$config_path"
	echo "$current_dir"
	return 0
}

cs_stack_init() {
	test -n "${CODESPACE_CONFIG_ROOT:-}" || {
		>&2 echo "err: env var '\$CODESPACE_CONFIG_ROOT' not set"
		exit 1
	}

	# check if a config already exists (possibly at a higher level)
	if config_output="$(cs_stack_find_config 2>/dev/null)"; then
		existing_config="$(echo "$config_output" | head -n1)"
		existing_org_dir="$(echo "$config_output" | tail -n1)"
		>&2 echo "stacks.json already exists at:"
		echo "$existing_config"
		>&2 echo "(org directory: $existing_org_dir)"
		exit 0
	fi

	# determine org directory
	local org_dir=""

	if [ -n "${1:-}" ]; then
		# path provided as argument
		org_dir="$(realpath "$1" 2>/dev/null)" || {
			>&2 echo "err: invalid path: $1"
			exit 1
		}
		if [ ! -d "$org_dir" ]; then
			>&2 echo "err: not a directory: $org_dir"
			exit 1
		fi
	elif [ -z "${CS_NO_INTERACTIVE:-}" ]; then
		# interactive mode: offer choices
		local current_dir parent_dir
		current_dir="$(pwd)"
		parent_dir="$(dirname "$current_dir")"

		# check if we're inside a git repo (parent might be org level)
		local in_git_repo=""
		if git rev-parse --git-dir >/dev/null 2>&1; then
			in_git_repo=1
		fi

		>&2 echo "Select directory where stacks will be held:"
		>&2 echo ""
		>&2 echo "  1) $current_dir"
		if [ -n "$in_git_repo" ]; then
			>&2 echo "  2) $parent_dir  (parent - you're inside a git repo)"
		else
			>&2 echo "  2) $parent_dir  (parent)"
		fi
		>&2 echo "  0) Exit (use 'codespace stack init <path>' to specify directly)"
		>&2 echo ""
		>&2 printf "Choice [1/2/0]: "
		read -r choice </dev/tty
		case "$choice" in
			1) org_dir="$current_dir" ;;
			2) org_dir="$parent_dir" ;;
			0|"")
				>&2 echo "aborted"
				exit 1
				;;
			*)
				>&2 echo "err: invalid choice: $choice"
				exit 1
				;;
		esac
	else
		# non-interactive mode: use current directory
		org_dir="$(pwd)"
	fi

	local org_name rel_path config_dir config_path
	org_name="$(basename "$org_dir")"
	rel_path="$(realpath "$org_dir" --relative-to="$HOME" 2>/dev/null)" || rel_path="$org_dir"
	config_dir="$CODESPACE_CONFIG_ROOT/$rel_path"
	config_path="$config_dir/stacks.json"

	>&2 echo ""
	>&2 echo "Creating configuration for org \"$org_name\""
	>&2 echo "  org directory: $org_dir"
	>&2 echo "  config path:   $config_path"

	# discover repos in org directory for template
	repos_json="$(cs_stack_discover_repos "$org_dir")"

	mkdir -p "$config_dir"

	# create template stacks.json
	cat > "$config_path" << EOF
{
    "version": "0",
    "mixedProjects": false,
    "stacks": {
        "default": $repos_json
    }
}
EOF

	# create sample stack-post-create.sh script
	local script_path="$config_dir/stack-post-create.sh"
	cat > "$script_path" << 'EOF'
#!/bin/bash
# stack-post-create.sh - runs after stack creation (in parallel with repo post-create scripts)
#
# Available environment variables:
#   STACK_NAME        - stack config name (e.g., "default")
#   STACK_PRESET      - same as STACK_NAME (stack preset key from stacks.json)
#   STACK_BRANCH      - branch name for the stack
#   STACK_ROOT        - absolute path to stack directory
#   STACK_CONFIG_ROOT - config directory (where stacks.json lives)
#   STACK_REPOS       - comma-separated list of repo names
#   STACK_CREATE_MODE - "worktree" or "clone"
#   STACK_ORG_DIR     - parent org directory

echo "=== Stack post-create: $STACK_NAME ==="
echo "Branch: $STACK_BRANCH"
echo "Repos: $STACK_REPOS"
echo "Dir: $STACK_ROOT"

# Example: link file from config to stack root
# ln -s "$STACK_CONFIG_ROOT/AGENTS.md" "$STACK_ROOT/AGENTS.md"

# Example: create shared .env file across repos
# for repo in ${STACK_REPOS//,/ }; do
#     cp "$STACK_ORG_DIR/templates/.env.template" "$STACK_ROOT/$repo/.env"
# done

# Example: create stack-level config
# echo "STACK_BRANCH=$STACK_BRANCH" > "$STACK_ROOT/.stack-env"
EOF
	chmod +x "$script_path"

	info="\
edit the file to configure your stacks:
  - \"default\" stack contains discovered repos from: $org_dir
  - add more stacks as needed
  - repo values can be:
$(echo "$REPO_VALUES_INFO" | sed 's/^/      /')
  - stack-post-create.sh runs when present and executable (delete or chmod -x to skip)
  - set \"mixedProjects\": true for shared org dirs with unrelated presets
    (stack dirs become stack_<preset>_<branch>)

created:
  $config_path
  $script_path\
"

	echo "$info"
}

# Discover repos in org directory and return as JSON array
cs_stack_discover_repos() {
	org_dir="$1"
	repos=""
	indent="            "  # 12 spaces for array items

	for dir in "$org_dir"/*; do
		test -d "$dir/.git" || continue
		repo_name="$(basename "$dir")"
		clone_url="$(git -C "$dir" remote get-url origin 2>/dev/null)" || clone_url=""

		if [ -n "$clone_url" ]; then
			entry="{ \"name\": \"$repo_name\", \"cloneURL\": \"$clone_url\" }"
		else
			entry="\"$repo_name\""
		fi

		if [ -z "$repos" ]; then
			repos="$entry"
		else
			repos="$repos,
$indent$entry"
		fi
	done

	if [ -z "$repos" ]; then
		echo '[
            { "name": "repo1", "cloneURL": "git@github.com:org/repo1.git" },
            { "name": "repo2", "cloneURL": "git@github.com:org/repo2.git" }
        ]'
	else
		echo "[
$indent$repos
        ]"
	fi
}

cs_stack_get_org_dir() {
	# if inside a git repo, go to parent (org level)
	# otherwise use current directory
	if git rev-parse --git-dir >/dev/null 2>&1; then
		# use cs_abs_path_base_repo to properly resolve through worktrees
		repo_root="$(cs_abs_path_base_repo)"
		dirname "$repo_root"
	else
		pwd
	fi
}

# detect if we're inside a stack directory by walking up the tree
# outputs three lines:
#   line 1: stack directory path
#   line 2: branch name (extracted from stack_<branch> pattern)
#   line 3: org directory (parent of stack)
# returns non-zero if not inside a stack
cs_stack_detect_current() {
	local current_dir
	current_dir="$(pwd)"

	while true; do
		local dir_name
		dir_name="$(basename "$current_dir")"

		# check if directory name matches stack_* pattern
		if [[ "$dir_name" == stack_* ]]; then
			local stack_dir="$current_dir"
			local org_dir stacks_json branch
			org_dir="$(dirname "$current_dir")"
			stacks_json="$(cs_stack_resolve_config_at_quiet "$org_dir" 2>/dev/null)" || stacks_json=""
			branch="$(cs_stack_branch_from_dir_basename "$dir_name" "$stacks_json")"

			echo "$stack_dir"
			echo "$branch"
			echo "$org_dir"
			return 0
		fi

		# check if we've reached root
		if [ "$current_dir" = "/" ]; then
			break
		fi

		current_dir="$(dirname "$current_dir")"
	done

	return 1
}

# detect creation mode of existing stack by checking for clone markers
# outputs: "clone" or "worktree"
cs_stack_detect_mode() {
	local stack_dir="$1"

	# check each repo in the stack for clone marker
	for repo_dir in "$stack_dir"/*; do
		test -d "$repo_dir/.git" || continue
		if [ -f "$repo_dir/.git/CODESPACE_IS_CLONE" ]; then
			echo "clone"
			return 0
		fi
	done

	# default to worktree if no clone markers found
	echo "worktree"
}

# Drop a .codespace/current marker at the current codespace root so agents
# (and `codespace current`) can detect where they are without guessing.
# Detects kind: stack (via cs_stack_detect_current) > clone > worktree.
# Args: [task]
cs_mark_current() {
	local task="${1:-}"
	local root branch kind detect_output

	if detect_output="$(cs_stack_detect_current 2>/dev/null)"; then
		root="$(echo "$detect_output" | sed -n '1p')"
		branch="$(echo "$detect_output" | sed -n '2p')"
		kind="stack"
	elif git rev-parse --git-dir >/dev/null 2>&1; then
		root="$(git rev-parse --show-toplevel)"
		branch="$(git branch --show-current)"
		if [ -n "$(cs_clone_marker)" ]; then
			kind="clone"
		else
			kind="worktree"
		fi
	else
		>&2 echo "err: not inside a codespace (no stack dir, not a git repo)"
		return 1
	fi

	local kvs=("path=$root" "branch=$branch" "kind=$kind")
	[ -n "$task" ] && kvs+=("task=$task")
	kvs+=("created=$(date -u +%Y-%m-%dT%H:%M:%SZ)")
	cs_current_marker_write "$root" "${kvs[@]}"

	# keep the marker out of git so it never trips rm-safety / shows as
	# untracked. only meaningful inside a git repo (stack root isn't one).
	if [ "$kind" != "stack" ]; then
		( cd "$root" && cs_git_exclude_add ".codespace/current" )
	fi

	>&2 echo "note: marked codespace ($kind) at: $root"
	echo "$root"
}

# Sorted comma-separated repo names for repos inside a stack instance dir.
# Args: stack_dir
cs_stack_repo_fingerprint() {
	local stack_dir="$1"
	local repos=()
	local d
	for d in "$stack_dir"/*; do
		[ -d "$d/.git" ] || continue
		repos+=("$(basename "$d")")
	done
	[ ${#repos[@]} -gt 0 ] || return 0
	printf '%s\n' "${repos[@]}" | LC_ALL=C sort | paste -sd,
}

# Find a stacks.json preset whose repo set matches fingerprint exactly.
# Args: stacks_json, fingerprint (sorted comma-separated repo names)
# Stdout: preset key, or empty if no unique match
cs_stack_match_preset_by_fingerprint() {
	local stacks_json="$1" fingerprint="$2"
	local matches
	[ -n "$fingerprint" ] || return 0

	matches="$(jq -r --arg fp "$fingerprint" '
		[.stacks | to_entries[] |
			.key as $name |
			((.value | if type == "array" then . else .repos end) |
				map(if type == "object" then .name else
					if test("^git@|^https?://") then (split("/") | last | rtrimstr(".git")) else .
					end
				end) | sort | join(",")) as $repos |
			select($repos == $fp) | $name
		] | unique | .[]
	' "$stacks_json" 2>/dev/null)" || return 0

	local count=0 match=""
	while IFS= read -r line; do
		[ -n "$line" ] || continue
		match="$line"
		count=$((count + 1))
	done <<< "$matches"

	[ "$count" -eq 1 ] || return 0
	echo "$match"
}

cs_stack_is_catchall_preset() {
	case "$1" in
		all|default) return 0 ;;
		*) return 1 ;;
	esac
}

# List stacks.json preset keys that include anchor as a repo member.
# Args: stacks_json, anchor
# Stdout: one preset name per line
cs_stack_list_presets_for_repo() {
	local stacks_json="$1" anchor="$2"
	[ -n "$anchor" ] || return 0

	jq -r --arg a "$anchor" '
		[.stacks | to_entries[] |
			.key as $name |
			((.value | if type == "array" then . else .repos end) |
				map(if type == "object" then .name else
					if test("^git@|^https?://") then (split("/") | last | rtrimstr(".git")) else .
					end
				end)) as $repos |
			select($repos | index($a)) | $name
		] | unique | .[]
	' "$stacks_json" 2>/dev/null
}

# Filter catch-all preset names unless they are the only candidates.
# Args: candidate names...
# Stdout: filtered names, one per line
cs_stack_filter_catchall_presets() {
	local -a all=("$@")
	local -a filtered=()
	local c

	if [ ${#all[@]} -le 1 ]; then
		printf '%s\n' "${all[@]}"
		return 0
	fi

	for c in "${all[@]}"; do
		cs_stack_is_catchall_preset "$c" || filtered+=("$c")
	done

	if [ ${#filtered[@]} -gt 0 ]; then
		printf '%s\n' "${filtered[@]}"
	else
		printf '%s\n' "${all[@]}"
	fi
}

# Find a stacks.json preset that lists anchor as a repo member.
# Skips catch-all presets (all, default) when a more specific preset also matches.
# Args: stacks_json, anchor (repo basename)
# Stdout: preset key, or empty if ambiguous / no match
cs_stack_match_preset_by_repo_membership() {
	local stacks_json="$1" anchor="$2"
	local -a raw=() picked=()
	local line

	[ -n "$anchor" ] || return 0

	while IFS= read -r line; do
		[ -n "$line" ] || continue
		raw+=("$line")
	done < <(cs_stack_list_presets_for_repo "$stacks_json" "$anchor")

	[ ${#raw[@]} -gt 0 ] || return 0

	if [ ${#raw[@]} -eq 1 ]; then
		echo "${raw[0]}"
		return 0
	fi

	while IFS= read -r line; do
		[ -n "$line" ] || continue
		picked+=("$line")
	done < <(cs_stack_filter_catchall_presets "${raw[@]}")

	[ ${#picked[@]} -eq 1 ] || return 0
	echo "${picked[0]}"
}

# Interactive menu to pick a stack preset when inference fails.
# Args: reason, candidate names...
# Stdout: chosen preset. Exits 1 on abort.
cs_stack_prompt_preset_choice() {
	local reason="$1"
	shift
	local -a candidates=("$@")
	local choice="" i=1 c opt_list="" idx

	[ ${#candidates[@]} -gt 0 ] || {
		>&2 echo "err: $reason"
		>&2 echo "  (no stack configs in stacks.json)"
		return 1
	}

	>&2 echo "err: $reason"
	>&2 echo ""
	>&2 echo "select stack config:"
	for c in "${candidates[@]}"; do
		>&2 echo "  $i) $c"
		opt_list="${opt_list:+$opt_list/}$i"
		i=$((i + 1))
	done
	>&2 echo "  a) abort"
	opt_list="${opt_list}/a"

	if [ -n "${CS_STACK_PRESET_CHOICE:-}" ]; then
		choice="$CS_STACK_PRESET_CHOICE"
	else
		>&2 printf "Choice [%s]: " "$opt_list"
		read -r choice </dev/tty
	fi

	case "$choice" in
		a|A)
			>&2 echo "aborted"
			return 1
			;;
	esac

	if [[ "$choice" =~ ^[0-9]+$ ]]; then
		idx=$((choice - 1))
		if [ "$idx" -ge 0 ] && [ "$idx" -lt ${#candidates[@]} ]; then
			echo "${candidates[$idx]}"
			return 0
		fi
	fi

	>&2 echo "err: invalid choice: $choice"
	return 1
}

# Handle unresolved preset inference: specific non-interactive error or prompt.
# Args: stacks_json, [anchor], [detail]
cs_stack_resolve_default_preset_fail() {
	local stacks_json="$1" anchor="${2:-}" detail="${3:-}"
	local -a all_presets=() repo_presets=() candidates=() filtered=()
	local reason="" line preset_list

	while IFS= read -r line; do
		[ -n "$line" ] || continue
		all_presets+=("$line")
	done < <(jq -r '.stacks | keys[]' "$stacks_json" 2>/dev/null)

	if [ -n "$anchor" ]; then
		while IFS= read -r line; do
			[ -n "$line" ] || continue
			repo_presets+=("$line")
		done < <(cs_stack_list_presets_for_repo "$stacks_json" "$anchor")

		if [ ${#repo_presets[@]} -gt 0 ]; then
			while IFS= read -r line; do
				[ -n "$line" ] || continue
				filtered+=("$line")
			done < <(cs_stack_filter_catchall_presets "${repo_presets[@]}")
			candidates=("${filtered[@]}")
			if [ -n "$detail" ]; then
				reason="could not infer stack preset for repo '$anchor' ($detail)"
			else
				preset_list="$(printf '%s, ' "${repo_presets[@]}")"
				preset_list="${preset_list%, }"
				reason="could not infer stack preset for repo '$anchor' (listed in: $preset_list)"
			fi
		else
			candidates=("${all_presets[@]}")
			reason="repo '$anchor' is not in any stack preset"
		fi
	else
		candidates=("${all_presets[@]}")
		reason="could not infer stack preset from context"
	fi

	if [ -n "${CS_NO_INTERACTIVE:-}" ]; then
		if [ -n "$anchor" ] && [ ${#candidates[@]} -gt 1 ]; then
			preset_list="$(printf '%s, ' "${candidates[@]}")"
			preset_list="${preset_list%, }"
			>&2 echo "err: repo '$anchor' matches multiple stack configs ($preset_list); pass -s <preset>"
		elif [ -n "$anchor" ] && [ ${#repo_presets[@]} -eq 0 ]; then
			>&2 echo "err: repo '$anchor' is not in any stack preset; pass -s <preset>"
		else
			>&2 echo "err: $reason; pass -s <preset>"
		fi
		return 1
	fi

	cs_stack_prompt_preset_choice "$reason" "${candidates[@]}"
}

# Resolve the stack preset to use when -s is not provided.
# Args: stacks_json, [explicit_preset]
# Stdout: preset key. Silent on success unless DEBUG is set.
cs_stack_resolve_default_preset() {
	local stacks_json="$1"
	local explicit="${2:-}"

	if [ -n "$explicit" ]; then
		echo "$explicit"
		return 0
	fi

	command -v jq >/dev/null 2>&1 || {
		>&2 echo "err: 'jq' is required to parse stacks.json"
		>&2 echo "install it with: brew install jq (macOS) or apt install jq (Linux)"
		exit 1
	}

	local detect_output="" stack_dir="" anchor=""

	if detect_output="$(cs_stack_detect_current 2>/dev/null)"; then
		stack_dir="$(echo "$detect_output" | sed -n '1p')"
		local fingerprint match
		fingerprint="$(cs_stack_repo_fingerprint "$stack_dir")"
		match="$(cs_stack_match_preset_by_fingerprint "$stacks_json" "$fingerprint")"
		if [ -n "$match" ]; then
			[ -n "${DEBUG:-}" ] && >&2 echo "note: using stack preset '$match' (from stack repo fingerprint)"
			echo "$match"
			return 0
		fi
	elif git rev-parse --git-dir >/dev/null 2>&1; then
		local repo_root member mapped
		local -a repo_presets=() ambiguous=() line

		repo_root="$(cs_abs_path_base_repo)"
		anchor="$(basename "$repo_root")"

		if jq -e --arg n "$anchor" '.stacks[$n] != null' "$stacks_json" >/dev/null 2>&1; then
			[ -n "${DEBUG:-}" ] && >&2 echo "note: using stack preset '$anchor' (from repo context)"
			echo "$anchor"
			return 0
		fi

		member="$(cs_stack_match_preset_by_repo_membership "$stacks_json" "$anchor")"
		if [ -n "$member" ]; then
			[ -n "${DEBUG:-}" ] && >&2 echo "note: using stack preset '$member' (repo '$anchor' listed in preset)"
			echo "$member"
			return 0
		fi

		mapped="$(jq -r --arg a "$anchor" '.defaults[$a] // empty' "$stacks_json")"
		if [ -n "$mapped" ]; then
			[ -n "${DEBUG:-}" ] && >&2 echo "note: using stack preset '$mapped' (from defaults map)"
			echo "$mapped"
			return 0
		fi

		while IFS= read -r line; do
			[ -n "$line" ] || continue
			repo_presets+=("$line")
		done < <(cs_stack_list_presets_for_repo "$stacks_json" "$anchor")

		if [ ${#repo_presets[@]} -gt 0 ]; then
			while IFS= read -r line; do
				[ -n "$line" ] || continue
				ambiguous+=("$line")
			done < <(cs_stack_filter_catchall_presets "${repo_presets[@]}")
			if [ ${#ambiguous[@]} -gt 1 ]; then
				local picked=""
				picked="$(cs_stack_resolve_default_preset_fail "$stacks_json" "$anchor" \
					"matches: $(printf '%s, ' "${ambiguous[@]}" | sed 's/, $//')")" || exit 1
				echo "$picked"
				return 0
			fi
		fi
	fi

	if jq -e '.stacks.default != null' "$stacks_json" >/dev/null 2>&1; then
		[ -n "${DEBUG:-}" ] && >&2 echo "note: using stack preset 'default' (org-wide fallback)"
		echo "default"
		return 0
	fi

	local picked=""
	picked="$(cs_stack_resolve_default_preset_fail "$stacks_json" "$anchor")" || exit 1
	echo "$picked"
	return 0
}

cs_stack_get_repos() {
	local stack_name="$1"
	local stacks_json="$2"

	# check if jq is available
	command -v jq >/dev/null 2>&1 || {
		>&2 echo "err: 'jq' is required to parse stacks.json"
		>&2 echo "install it with: brew install jq (macOS) or apt install jq (Linux)"
		exit 1
	}

	# extract repos array for the given stack
	# stack value can be either an array directly, or an object with "repos" key
	# each repo entry is output on a separate line as JSON
	local stack_value
	stack_value="$(jq -c --arg name "$stack_name" '.stacks[$name]' "$stacks_json" 2>/dev/null)" || {
		>&2 echo "err: failed to parse stacks.json"
		exit 1
	}

	if [ "$stack_value" = "null" ] || [ -z "$stack_value" ]; then
		>&2 echo "err: stack '$stack_name' not found in $stacks_json"
		exit 1
	fi

	# check if it's an array or object
	local value_type
	value_type="$(echo "$stack_value" | jq -r 'type')"

	if [ "$value_type" = "array" ]; then
		# direct array of repos
		echo "$stack_value" | jq -c '.[]'
	elif [ "$value_type" = "object" ]; then
		# object with "repos" key
		echo "$stack_value" | jq -c '.repos[]' 2>/dev/null || {
			>&2 echo "err: stack '$stack_name' is an object but missing 'repos' array"
			exit 1
		}
	else
		>&2 echo "err: stack '$stack_name' has invalid type: $value_type (expected array or object)"
		exit 1
	fi
}

# Get post-create script configuration for a stack
# Args: stack_name, stacks_json
# Outputs: script path to run (empty if disabled)
# Uses: stacks_json path to determine config directory
cs_stack_get_post_create_config() {
	local stack_name="$1"
	local stacks_json="$2"
	local config_dir custom_script="" stack_value value_type script_path
	config_dir="$(dirname "$stacks_json")"

	stack_value="$(jq -c --arg name "$stack_name" '.stacks[$name]' "$stacks_json" 2>/dev/null)"
	if [ -n "$stack_value" ] && [ "$stack_value" != "null" ]; then
		value_type="$(echo "$stack_value" | jq -r 'type')"
		if [ "$value_type" = "object" ]; then
			custom_script="$(echo "$stack_value" | jq -r '.customPostCreateScript // empty')"
		fi
	fi

	if [ -n "$custom_script" ]; then
		script_path="$config_dir/$custom_script"
	else
		script_path="$config_dir/stack-post-create.sh"
	fi

	[ -f "$script_path" ] && [ -x "$script_path" ] || return 0
	echo "$script_path"
}

# Parse a repo entry from stacks.json, setting globals: repo_name, clone_url
# Entry can be: string (repo name or URL) or object {"name": "...", "cloneURL": "..."}
cs_stack_parse_repo_entry() {
	entry="$1"

	# reset globals
	repo_name=""
	clone_url=""

	if echo "$entry" | grep -q '^{'; then
		# JSON object: {"name": "repo", "cloneURL": "url"}
		repo_name="$(echo "$entry" | jq -r '.name')"
		clone_url="$(echo "$entry" | jq -r '.cloneURL // empty')"
	else
		# String value
		value="$(echo "$entry" | jq -r '.')"
		if echo "$value" | grep -qE '^(https?://|git@|ssh://)'; then
			clone_url="$value"
			repo_name="$(cs_repo_name_from_url "$value")"
		else
			repo_name="$value"
		fi
	fi

	test -n "$repo_name" || {
		>&2 echo "err: could not determine repo name from entry: $entry"
		exit 1
	}
}

# init a single repo for stack (clone/worktree + post-create).
# When remote_host is set, all work runs on remote; the local r_dest is a stub.
cs_stack_init_repo() {
	create_mode="$1"
	r_name="$2"
	r_clone_url="$3"
	r_dest="$4"
	r_base="$5"
	branch_name="$6"
	r_base_branch="${7:-}"
	remote_host="${8:-}"
	# no_stub: skip the local .codespace-remote stub marker. Set when
	# (re-)initializing an EXISTING local stack's remote (open/sync), whose
	# relationship is tracked by the stack-level .codespace/sync marker instead.
	no_stub="${9:-}"

	echo "=== [$r_name] Clone/worktree ==="

	# In remote mode the local r_dest is only a stub (create -r) or an existing
	# worktree (init of an existing local stack) -- non-empty is expected, and the
	# real guard is the remote dest's health (handled idempotently downstream). So
	# the non-empty-dest refusal only applies to a local create.
	if [ -z "$remote_host" ] && [ -d "$r_dest" ] && [ "$(ls -A "$r_dest" 2>/dev/null)" ]; then
		echo "err: destination already exists (non-empty): $r_dest"
		echo "CLONE_FAILED"
		exit 1
	fi

	if [ -n "$remote_host" ]; then
		cs_stack_init_repo_remote || {
			echo "CLONE_FAILED"
			exit 1
		}
	elif [ "$create_mode" = "clone" ]; then
		test -n "$r_clone_url" || r_clone_url="$(git -C "$r_base" remote get-url origin)"
		cs_create_clone_core "$r_clone_url" "$r_dest" "$branch_name" || {
			echo "CLONE_FAILED"
			exit 1
		}
		echo "$r_name" > "$r_dest/.git/CODESPACE_IS_CLONE"
	else
		if [ ! -d "$r_base/.git" ]; then
			echo "Base repo not found, cloning: $r_clone_url -> $r_base"
			git clone "$r_clone_url" "$r_base" || {
				echo "CLONE_FAILED"
				exit 1
			}
		fi
		git -C "$r_base" worktree prune
		cs_create_worktree_core "$branch_name" "$r_base" "$r_dest" "$r_base_branch" || {
			echo "CLONE_FAILED"
			exit 1
		}
	fi

	echo "=== [$r_name] Post-create ==="
	if [ -n "$remote_host" ]; then
		# Post-create already invoked inside cs_stack_init_repo_remote;
		# nothing more to do here. We still print "Done" so cs_stack_tmux_wait
		# sees completion.
		:
	else
		cd "$r_dest" || {
			echo "POST_CREATE_FAILED"
			exit 1
		}
		cs_post_create "$r_dest" || {
			echo "POST_CREATE_FAILED"
			exit 1
		}
	fi

	echo "=== [$r_name] Done ==="
}

# Provision (in parallel) the REMOTE side of an EXISTING local stack, reusing the
# same tmux/background harness as `stack create -r`. Used by open -r / sync when a
# local stack's remote is absent: fan out one init-repo per repo (each idempotent
# via cs_remote_init_repo -> install deps on the remote), WITHOUT planting per-repo
# stub markers (the stack's .codespace/sync relationship stays authoritative) and
# without touching local worktrees or code (that's sync's job).
#
# Sets harness globals (branch, org_dir, repo_names[], ...); callers that keep
# using those names afterwards should invoke this in a subshell to isolate them.
# Args: stack_dir host [base_branch]
cs_stack_init_remote_existing() {
	local _stack_dir="$1" _host="$2" _base_branch="${3:-}"

	stack_dir="$_stack_dir"
	org_dir="$(dirname "$stack_dir")"
	remote_host="$_host"
	base_branch="$_base_branch"
	create_mode="worktree"
	branch="$(cs_stack_branch_from_stack_dir "$stack_dir")"
	stack_dest_rel="$(cs_remote_relpath_for_local "$stack_dir")"
	logs_dir="$stack_dir/.stack-init-logs"
	mkdir -p "$logs_dir"
	# don't shadow the stack's .codespace/sync marker with per-repo stubs
	cs_init_no_stub=1

	# the existing local worktrees ARE the repo set; clone URLs are inferred from
	# each base repo's origin inside cs_stack_init_repo_remote.
	repo_names=(); repo_clone_urls=(); repo_dests=(); repo_base_repos=()
	local d name
	for d in "$stack_dir"/*; do
		[ -e "$d/.git" ] || continue
		name="$(basename "$d")"
		repo_names+=("$name")
		repo_clone_urls+=("")
		repo_dests+=("$d")
		repo_base_repos+=("$org_dir/$name")
	done
	if [ "${#repo_names[@]}" -eq 0 ]; then
		>&2 echo "err: no repos found under stack dir: $stack_dir"
		return 1
	fi

	>&2 echo "==> [$remote_host] initializing remote for stack '$branch' (${#repo_names[@]} repos, parallel)"

	cs_ssh_script "$remote_host" "$stack_dest_rel" <<'REMOTE'
set -eu
mkdir -p "$(cs_rref "$1")"
REMOTE
	cs_stack_create_setup_tmux
	cs_stack_remote_setup_host
	cs_stack_run_org_bootstrap
	cs_stack_create_spawn_jobs
	cs_stack_create_wait_and_summarize "init"
}

# Remote variant: clone/worktree + bootstrap + post-create on remote.
# All paths derived from local r_dest / r_base via cs_remote_relpath_for_local.
# Uses (caller-provided) globals: r_name, r_clone_url, r_dest, r_base, branch_name,
#                                  r_base_branch, remote_host, create_mode
cs_stack_init_repo_remote() {
	# clone-url inference (mirrors local behaviour when r_clone_url is empty)
	if [ -z "$r_clone_url" ]; then
		if [ -d "$r_base/.git" ]; then
			r_clone_url="$(git -C "$r_base" remote get-url origin 2>/dev/null)" || true
		fi
	fi
	test -n "$r_clone_url" || {
		echo "err: cannot infer clone URL for repo '$r_name'"
		return 1
	}

	local dest_rel base_rel cfg_rel rel_org repo_id
	dest_rel="$(cs_remote_relpath_for_local "$r_dest")"
	base_rel="$(cs_remote_relpath_for_local "$r_base")"
	rel_org="$(realpath --relative-to="$HOME" "$(dirname "$r_base")" 2>/dev/null || echo "")"
	repo_id="${rel_org:+$rel_org/}$r_name"
	# config dir was rsynced at stack-setup time; reuse the same relpath here
	cfg_rel="$CS_CFG_PREFIX/$repo_id"

	# ensure a forwardable key is loaded so the remote clone can authenticate
	# (see cs_ensure_agent_key); best-effort, memoized.
	cs_ensure_agent_key "$repo_id"

	mkdir -p "$r_dest"

	# create (a fresh stack init always provisions, so skip the health
	# round-trip via health=absent) + ship the repo's declared files + run
	# bootstrap/post-create -- all on the remote, via the shared primitive.
	# Per-repo r_base is the ship/collect resolver root (spawn cwd is the user's
	# invocation dir, not r_base).
	# rc: 0 = fully ok; 1 = provisioning (clone/worktree) failed -> no marker;
	# 2 = provisioned but bootstrap/post-create failed. On rc 2 the worktree
	# still exists on the remote, so we DO stamp the marker (recording the
	# failure) and propagate rc 2 so the summary still flags the repo. This keeps
	# a toolchain-less post-create (e.g. missing make/npm) from leaving an
	# unmarked-but-provisioned worktree that open/rm can't resolve.
	local init_rc=0
	cs_remote_init_repo "$remote_host" "$repo_id" "$branch_name" "$dest_rel" "$create_mode" \
		"$base_rel" "$r_base" "$cfg_rel" "$r_clone_url" "$r_base_branch" absent || init_rc=$?
	[ "$init_rc" -ne 1 ] || return 1

	local setup_status=ok
	[ "$init_rc" -eq 0 ] || setup_status=failed

	# write a CODESPACE_IS_CLONE marker on remote (so remote-side codespace rm
	# dispatches correctly for clone-kind stack members)
	if [ "$create_mode" = "clone" ]; then
		cs_ssh_script "$remote_host" "$dest_rel" "$r_name" <<'REMOTE'
echo "$2" > "$(cs_rref "$1")/.git/CODESPACE_IS_CLONE"
REMOTE
	fi

	# local stub marker (the stack itself is tracked by a stack-level marker).
	# Skipped when (re-)initializing an existing local stack, so we don't shadow
	# its .codespace/sync relationship with a per-repo .codespace-remote stub.
	if [ -z "${no_stub:-}" ]; then
		local sbx=()
		mapfile -t sbx < <(cs_sandbox_marker_fields "$remote_host")
		cs_remote_marker_write "$r_dest" \
			"host=$remote_host" \
			"relpath=$dest_rel" \
			"kind=$create_mode" \
			"repo_id=$repo_id" \
			"branch=$branch_name" \
			"setup_status=$setup_status" \
			${sbx[@]+"${sbx[@]}"}
	fi

	return "$init_rc"
}

test -n "${CS_STACK_NO_RUN:-}" || {
	cs_stack_main "$@"
	exit $?
}
