#!/usr/bin/env bash

set -euo pipefail

DIRNAME="$(dirname "$(realpath "$0")")"

# shellcheck source=codespace-utils
source "$DIRNAME/codespace-utils"

# shellcheck source=codespace-stack
CS_STACK_NO_RUN=1 source "$DIRNAME/codespace-stack"

# codespace-find: find existing codespaces/stacks by branch name

FIND_HELP="\
Usage:
codespace find <branch>
codespace edit <branch> [-r [host]]
codespace open [branch|path] [-r [host]] [--init[=force|auto|no]] [--no-init] [--no-sync]

sub-commands:
  find <branch>    find codespace/stack path by branch name.
                   searches worktrees and directory patterns.
  edit <branch> [-r [host]]
                   find codespace/stack and open in editor.
  open [branch|path] [-r [host]]
                   open a codespace in editor. with no arg, opens the
                   codespace at the current dir; with a path, opens that
                   codespace; with a branch, behaves like 'edit'.
                   handles remote codespaces (opens over ssh-remote).
  -r, --remote [host]
                   open the codespace's REMOTE counterpart: init-remote it
                   if absent (in parallel, for stacks), start a live sync,
                   then open over ssh-remote. host: explicit value, else the
                   .codespace/sync marker / config default. inside a stack
                   repo worktree (with no path arg), prompts for this repo
                   only vs the entire stack; \$CS_NO_INTERACTIVE defaults to
                   the entire stack. if a watch is already running at the same
                   scope it just opens; a narrower watch is stopped and
                   restarted for the wider scope.
  --init[=force|auto|no], --no-init
                   forwarded to sync: control remote provisioning. auto
                   (default) inits only when the remote is absent; bare
                   --init (=force) re-runs setup on a healthy remote;
                   --no-init (=no) skips it (code-only; errors if absent).
  --no-sync        open the remote as-is, without syncing (assumes it is
                   already provisioned + synced).

search strategy:
  1. git worktrees - checks if branch is checked out in a worktree
  2. directory scan - walks up parent dirs looking for:
     - stack_<branch>  (stack pattern)
     - *_<branch>      (single codespace pattern)

priority (when multiple matches):
  1. stack (highest)
  2. worktree from current repo
  3. sibling directory matches

output:
  - prints primary match path to stdout
  - if multiple matches, prints alternatives to stderr
"

cs_find_main() {
	case "${1:-}" in
		-h|--help)
			echo "$FIND_HELP"
			exit 0
			;;
		"")
			>&2 echo "$FIND_HELP"
			exit 1
			;;
		find)
			shift
			cs_find "$@"
			;;
		edit)
			shift
			cs_edit "$@"
			;;
		open)
			shift
			cs_open "$@"
			;;
		*)
			# default to find
			cs_find "$@"
			;;
	esac
}

cs_find() {
	branch="${1:-}"
	test -n "$branch" || {
		>&2 echo "err: <branch> is required"
		>&2 echo "usage: codespace find <branch>"
		return 1
	}

	clean_branch="$(cs_cleanpath "$branch")"
	matches=()

	# 1. Check git worktrees (if in a repo)
	if git rev-parse --git-dir >/dev/null 2>&1; then
		wt_path="$(cs_find_worktree_by_branch "$branch")"
		if [ -n "$wt_path" ]; then
			matches+=("worktree:$wt_path")
		fi
	fi

	# 2. Walk up directories, scanning for matches at each level
	start_dir="$(cs_stack_get_org_dir 2>/dev/null)" || start_dir="$(pwd)"
	current_dir="$start_dir"

	while [ "$current_dir" != "$HOME" ] && [ "$current_dir" != "/" ]; do
		# Check for stack
		stack_path="$current_dir/stack_$clean_branch"
		if [ -d "$stack_path" ]; then
			matches+=("stack:$stack_path")
		fi

		# Check for single codespaces (*_<branch>)
		for dir in "$current_dir"/*_"$clean_branch"; do
			[ -d "$dir" ] || continue
			matches+=("sibling:$dir")
		done

		current_dir="$(dirname "$current_dir")"
	done

	# Dedupe and prioritize
	cs_find_select_and_report "$branch" "${matches[@]}"
}

# Parse git worktree list --porcelain to find path for a branch
cs_find_worktree_by_branch() {
	branch="$1"
	# porcelain format:
	# worktree /path/to/worktree
	# HEAD <sha>
	# branch refs/heads/<branch>
	# (blank line)
	git worktree list --porcelain 2>/dev/null | awk -v branch="$branch" '
		/^worktree / { path = substr($0, 10) }
		/^branch refs\/heads\// {
			b = substr($0, 21)
			if (b == branch) { print path; exit }
		}
	'
}

# Dedupe matches, select primary, report others
# Args: branch, matches...
cs_find_select_and_report() {
	local branch="$1"
	shift
	local matches=("$@")

	# No matches
	if [ ${#matches[@]} -eq 0 ]; then
		cs_find_not_found "$branch"
		return 1
	fi

	# Dedupe and extract paths
	declare -A seen
	local stack_match=""
	local worktree_match=""
	local other_matches=()

	for entry in "${matches[@]}"; do
		local type="${entry%%:*}"
		local path="${entry#*:}"

		# Skip duplicates
		[ -n "${seen[$path]:-}" ] && continue
		seen[$path]=1

		case "$type" in
			stack)
				# Stack takes highest priority
				if [ -z "$stack_match" ]; then
					stack_match="$path"
				else
					other_matches+=("$path")
				fi
				;;
			worktree)
				# Worktree from current repo is second priority
				if [ -z "$worktree_match" ]; then
					worktree_match="$path"
				else
					other_matches+=("$path")
				fi
				;;
			*)
				other_matches+=("$path")
				;;
		esac
	done

	# Select primary match (stack > worktree > first other)
	local primary=""
	if [ -n "$stack_match" ]; then
		primary="$stack_match"
		[ -n "$worktree_match" ] && other_matches=("$worktree_match" "${other_matches[@]}")
	elif [ -n "$worktree_match" ]; then
		primary="$worktree_match"
	elif [ ${#other_matches[@]} -gt 0 ]; then
		primary="${other_matches[0]}"
		other_matches=("${other_matches[@]:1}")
	fi

	# Report other matches to stderr
	if [ ${#other_matches[@]} -gt 0 ]; then
		local others_str
		others_str="$(IFS=', '; echo "${other_matches[*]}")"
		>&2 echo "also found: $others_str"
	fi

	# Output primary match
	echo "$primary"
}

cs_find_not_found() {
	local branch="$1"
	>&2 echo "err: codespace not found for branch '$branch'"
	>&2 echo "create with:"
	>&2 echo "  codespace create $branch"
	>&2 echo "  codespace stack create $branch"
}

# Open an already-resolved codespace path in the editor.
# Remote stubs (.codespace-remote marker) open over ssh-remote+host against the
# real remote path; plain dirs open locally. Prints the path on stdout.
# Args: path
cs_open_path() {
	local path="$1"

	GUI_EDITOR="${GUI_EDITOR:-$EDITOR}"

	# Remote stub: open via ssh-remote+host on the actual remote path.
	if cs_remote_marker "$path"; then
		local host dest_rel remote_abs
		host="$(cs_remote_marker_get "$path" host)"
		dest_rel="$(cs_remote_marker_get "$path" relpath)"
		# back-compat: older markers stored 'path=$HOME/<relpath>'.
		if [ -z "$dest_rel" ]; then
			local legacy
			legacy="$(cs_remote_marker_get "$path" path)"
			dest_rel="${legacy#\$HOME/}"
		fi

		case "$(basename "${GUI_EDITOR:-}")" in
			cursor|code|codium)
				if remote_abs="$(cs_remote_abs "$host" "$dest_rel")"; then
					(unset GIT_DIR GIT_WORK_TREE; "$GUI_EDITOR" --new-window --remote "ssh-remote+$host" "$remote_abs")
				else
					>&2 echo "warn: could not resolve remote path on $host; cannot open editor"
					>&2 echo "  remote codespace at: $host:~/$dest_rel"
				fi
				;;
			*)
				>&2 echo "remote codespace at: $host:~/$dest_rel"
				>&2 echo "  ssh $host -t \"cd ~/$dest_rel && \\\$SHELL\""
				;;
		esac
		echo "$path"
		return 0
	fi

	if [ -n "$GUI_EDITOR" ]; then
		(unset GIT_DIR GIT_WORK_TREE; "$GUI_EDITOR" --new-window "$path")
	else
		>&2 echo "warn: neither \$GUI_EDITOR nor \$EDITOR env var set, cannot open with editor"
	fi

	echo "$path"
}

cs_edit() {
	# -r/--remote anywhere routes through the remote-open path (same as open -r).
	local a
	for a in "$@"; do
		case "$a" in -r|--remote) cs_open "$@"; return $? ;; esac
	done
	local path
	path="$(cs_find "$1")" || exit 1
	cs_open_path "$path"
}

# Open a codespace in the editor.
#   no arg          -> open the codespace at the current dir
#   existing dir    -> open that codespace
#   branch          -> find + open (alias for 'edit')
#   -r [host]       -> open the codespace's REMOTE counterpart: init-remote it
#                      if absent (parallel for stacks), start a live sync, then
#                      open over ssh-remote. host: explicit, else the marker.
#   --init[=force|auto|no] / --no-init  -> forwarded to sync (control provisioning)
#   --no-sync                           -> open the remote as-is (skip sync)
cs_open() {
	local remote="" rhost="" no_sync="" args=() sync_flags=()
	while [ $# -gt 0 ]; do
		case "$1" in
			-r|--remote)
				remote=1; shift
				if [ $# -gt 0 ] && [ "${1#-}" = "$1" ] && [ ! -e "$1" ]; then
					rhost="$1"; shift
				fi ;;
			--init|--init=*|--no-init) sync_flags+=("$1"); shift ;;
			--no-sync) no_sync=1; shift ;;
			*) args+=("$1"); shift ;;
		esac
	done

	local arg="${args[0]:-}"

	if [ -z "$remote" ]; then
		if [ -z "$arg" ]; then
			cs_open_path "$(pwd)"
		elif [ -d "$arg" ]; then
			cs_open_path "$(cs_abspath "$arg")"
		else
			local p
			p="$(cs_find "$arg")" || exit 1
			cs_open_path "$p"
		fi
		return 0
	fi

	# remote: resolve the LOCAL codespace, sync it (live), open the remote.
	command -v cs_sync >/dev/null 2>&1 || {
		>&2 echo "err: 'open -r' needs the codespace-sync component (run via 'codespace open')"
		exit 1
	}
	local path sup sync_host="$rhost"
	path="$(cs_sync_resolve_open_path "$arg")" || exit 1

	# --detach: start a background watch and return (don't block in the
	# foreground) so we can go on to open the remote editor. If one is already
	# running at the same scope, leave it be and just open. A narrower watch
	# (e.g. single-repo after a stack open) is stopped and restarted.
	# --no-sync: open the remote as-is (assume it's already provisioned/synced).
	if [ -n "$no_sync" ]; then
		>&2 echo "note: --no-sync: opening the remote for $path without syncing."
	elif command -v cs_sync_watch_running >/dev/null 2>&1 && cs_sync_watch_running "$path"; then
		sup=""
		if command -v cs_sync_watch_supervisor_path >/dev/null 2>&1; then
			sup="$(cs_sync_watch_supervisor_path "$path" 2>/dev/null)" || sup=""
		fi
		if [ -n "$sup" ] \
			&& command -v cs_sync_watch_same_scope >/dev/null 2>&1 \
			&& ! cs_sync_watch_same_scope "$path" "$sup"; then
			[ -z "$sync_host" ] && sync_host="$(cs_sync_marker_get "$sup" host)"
			>&2 echo "note: watch running at $sup; restarting for $path."
			cs_sync "$sup" --stop
			if [ -n "$sync_host" ]; then cs_sync "$path" --watch --detach ${sync_flags[@]+"${sync_flags[@]}"} -r "$sync_host"
			else cs_sync "$path" --watch --detach ${sync_flags[@]+"${sync_flags[@]}"}
			fi
		else
			>&2 echo "note: a watch is already running for this codespace; opening the remote."
			>&2 echo "  stop it first: codespace sync --stop"
		fi
	elif [ -n "$sync_host" ]; then cs_sync "$path" --watch --detach ${sync_flags[@]+"${sync_flags[@]}"} -r "$sync_host"
	else cs_sync "$path" --watch --detach ${sync_flags[@]+"${sync_flags[@]}"}
	fi

	# marker resolution: a synced codespace has a sync marker; a create -r
	# remote-only stub opened with --no-sync only has the remote stub marker.
	local host dest_rel
	host="$(cs_sync_marker_get "$path" host)"
	[ -n "$host" ] || host="$(cs_remote_marker_get "$path" host 2>/dev/null || true)"
	[ -n "$host" ] || host="$sync_host"
	dest_rel="$(cs_sync_marker_get "$path" relpath)"
	[ -n "$dest_rel" ] || dest_rel="$(cs_remote_marker_get "$path" relpath 2>/dev/null || true)"
	if [ -z "$dest_rel" ] && command -v cs_sync_is_stack >/dev/null 2>&1 && cs_sync_is_stack "$path"; then
		dest_rel="$(cs_remote_relpath_for_local "$(cs_abspath "$path")" 2>/dev/null || true)"
	fi
	[ -n "$host" ] && [ -n "$dest_rel" ] || {
		>&2 echo "err: no sync target recorded for $path"
		exit 1
	}
	cs_open_editor_remote "$host" "$dest_rel"
	echo "$path"
}

test -n "${CS_FIND_NO_RUN:-}" || {
	cs_find_main "$@"
	exit $?
}
