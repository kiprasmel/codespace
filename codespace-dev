#!/usr/bin/env bash

# codespace-dev — the CLIENT half of `codespace dev` (runs on the laptop).
#
# One command to bring up whatever the current codespace is (stack or single
# worktree), same context model as `codespace open` / `codespace sync`.
#
# It resolves the codespace at the current dir (or [path]) and runs in one of
# two modes, using the SAME runner (codespace-cloud dev) + the SAME dev hooks +
# the SAME dev-manifest.json format — only the transport differs:
#   LOCAL  (a plain local worktree/stack, no remote marker): run the org dev
#          scripts locally (tmux, via the cloud runner) and report the services
#          on http://127.0.0.1:<port> directly (no tunnels; optional Caddy https).
#   REMOTE (a codespace with a remote/sync marker, or `-r`): run the dev scripts
#          in the remote sandbox, open ssh -L tunnels to the sandbox-local ports,
#          and route them through a local Caddy as https://{slug}.localhost
#          (per-branch subdomains so multiple stacks don't clash). --raw-ports
#          (or no Caddy) falls back to a 1:1 local-port map.
# With `-r` on a codespace that isn't on the remote yet, it provisions + syncs
# it first (via 'codespace sync -r'), then runs the remote flow.
#
# Sourced by `codespace`; helpers are pure/shim-friendly for bats. Include
# guard: CS_DEV_NO_RUN=1.

CS_DEV_HELP="\
Usage:
codespace dev [path] [-r [host]] [--no-forward] [--no-open] [--detach] [--raw-ports] [--timeout N]
codespace dev stop   [-s <slug> | <slug|path>]   (alias: codespace dev --stop ...)
codespace dev status [-s <slug> | <slug|path>]

  Brings the current codespace's services up and forwards them to your laptop.
  With no [path], uses the current directory (slug inferred from the branch).

  Runs LOCALLY for a plain local codespace, or in the REMOTE sandbox for a
  remote/synced one (or with -r). Same dev hooks + manifest in both; only the
  transport differs (localhost vs ssh -L + Caddy).

verbs:
  stop                  tear down this codespace's tunnels + proxy routes + dev session.
  status                show whether the dev session is running + its service urls.
                        With NO target and not inside a codespace, lists the dev
                        sessions (and local sandboxes) to choose from.

flags:
  -r, --remote [host]   run in the remote sandbox (else inferred from the marker);
                        provisions + syncs the remote first if it isn't there yet.
  -s, --slug <slug>     target a specific codespace by slug (for stop/status),
                        without needing to be in its directory. A bare positional
                        that isn't a path/branch is also treated as a slug.
  --stop                same as the 'stop' verb.
  --no-forward          start the dev session only; don't open tunnels/proxy.
  --no-open             don't open the browser.
  --detach              (reserved) don't foreground-monitor; return after setup.
  --raw-ports           skip Caddy; map each service 1:1 to the same local port
                        (http://127.0.0.1:<port>). the default for LOCAL mode.
  --timeout N           max seconds to wait for the dev-manifest.json. only used
                        when NO static ports are declared (see below); static
                        ports are forwarded immediately. precedence:
                        --timeout > \$CS_DEV_TIMEOUT > stacks.json dev.timeout > 300.

env vars:
  CS_DEV_TIMEOUT        default manifest wait (seconds) when there are no static
                        ports; overridden by --timeout and stacks.json dev.timeout.
  CS_DEV_HTTPS_PORT     Caddy https listen port for {slug}.localhost (default 443).
  CS_DEV_CADDY          caddy binary (default: 'caddy' on PATH).

static ports (skip the wait):
  declare them in stacks.json — either the flat 'dev' map (dev:{web:3000,...})
  or the structured form (dev:{timeout:300, ports:{web:3000,...}}) — or via a
  '# CS_DEV: web=3000:https core-api=8000' hint line in the config dir's dev.sh.
  known ports forward immediately; the manifest is only WAITED on when none are
  declared (purely-dynamic ports)."

##############################
#  small utilities           #
##############################

# Cache root for dev session state (falls back off $CODESPACE_CONFIG_ROOT).
cs_dev_cache_dir() {
	local base
	base="$(cs_cache_dir 2>/dev/null)" || base="${XDG_CACHE_HOME:-$HOME/.cache}/codespace"
	echo "$base"
}

# A DNS-safe, lowercase slug for URLs (branch -> feature-x). Args: branch/slug
cs_dev_url_slug() {
	printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9-' '-' | sed -E 's/-+/-/g; s/^-+//; s/-+$//'
}

# Allocate a free ephemeral local TCP port (bind :0). Prints the port.
cs_dev_free_port() {
	if command -v python3 >/dev/null 2>&1; then
		python3 -c 'import socket;s=socket.socket();s.bind(("127.0.0.1",0));print(s.getsockname()[1]);s.close()'
		return 0
	fi
	# fallback: pick a random high port and hope it's free (best-effort)
	echo $(( (RANDOM % 20000) + 30000 ))
}

# The session registry file for a codespace. Args: host_key, slug
cs_dev_session_file() {
	local host_key slug
	host_key="$(cs_cleanpath "$1")"
	slug="$(cs_cleanpath "$2")"
	echo "$(cs_dev_cache_dir)/dev-sessions/$host_key/$slug.json"
}

##############################
#  dev orchestration         #
##############################
#
# The runner (codespace-cloud dev {run,manifest,stop,status}) is the SAME in
# both modes; only how we reach it differs:
#   remote -> over ssh, inside the sandbox (cs_dev_remote_*)
#   local  -> invoked directly on the laptop (cs_dev_local_* via cs_dev_cloud_local)
# The runner is dependency-light (tmux + coreutils) so it runs on macOS too.

# Invoke the codespace-cloud dispatcher LOCALLY (for local-mode dev). Resolves
# the cloud repo via cs_cloud_root; errors clearly if it isn't available.
cs_dev_cloud_local() {
	local cloud_root
	cloud_root="$(cs_cloud_root)"
	[ -n "$cloud_root" ] && [ -x "$cloud_root/codespace-cloud" ] || {
		>&2 echo "err: codespace-cloud not available locally (needed to run 'codespace dev' on this machine)"
		>&2 echo "  install the codespace-cloud repo beside codespace, or set \$CS_CLOUD_ROOT."
		return 1
	}
	"$cloud_root/codespace-cloud" "$@"
}

# Start (or restart) the remote dev session inside the sandbox.
# Args: host, dest_rel, config_rel, repos_csv, slug
cs_dev_remote_start() {
	local host="$1" dest_rel="$2" config_rel="$3" repos_csv="$4" slug="$5"
	cs_ssh_script "$host" "$dest_rel" "$config_rel" "$repos_csv" "$slug" <<'REMOTE'
set -eu
dest_rel="$1"; cfg_rel="$2"; repos="$3"; slug="$4"
export PATH="$HOME/.local/bin:$PATH"
root="$(cs_rref "$dest_rel")"
cfg=""
[ -n "$cfg_rel" ] && cfg="$(cs_rref "codespace-config/$cfg_rel")"
codespace-cloud dev run --slug "$slug" --root "$root" --repos "$repos" --config-dir "$cfg"
REMOTE
}

# Start (or restart) the LOCAL dev session (same runner, run on the laptop).
# Args: root(local path), config_dir(local), repos_csv, slug
cs_dev_local_start() {
	local root="$1" cfg="$2" repos_csv="$3" slug="$4"
	cs_dev_cloud_local dev run --slug "$slug" --root "$root" --repos "$repos_csv" --config-dir "$cfg"
}

# Fetch the remote dev-manifest.json. Args: host, dest_rel
cs_dev_remote_manifest() {
	local host="$1" dest_rel="$2"
	cs_ssh_script "$host" "$dest_rel" <<'REMOTE'
set -eu
export PATH="$HOME/.local/bin:$PATH"
codespace-cloud dev manifest --root "$(cs_rref "$1")"
REMOTE
}

# Fetch the LOCAL dev-manifest.json. Args: root(local path)
cs_dev_local_manifest() {
	cs_dev_cloud_local dev manifest --root "$1"
}

# Fetch the manifest for whichever mode is active. Args: mode, host, dest_rel, root
cs_dev_manifest_now() {
	local mode="$1" host="$2" dest_rel="$3" root="$4"
	if [ "$mode" = local ]; then
		cs_dev_local_manifest "$root"
	else
		cs_dev_remote_manifest "$host" "$dest_rel"
	fi
}

# Stop the remote dev session. Args: host, slug
cs_dev_remote_stop() {
	local host="$1" slug="$2"
	cs_ssh_script "$host" "$slug" <<'REMOTE'
set -eu
export PATH="$HOME/.local/bin:$PATH"
codespace-cloud dev stop --slug "$1" || true
REMOTE
}

# Stop the LOCAL dev session. Args: slug
cs_dev_local_stop() {
	cs_dev_cloud_local dev stop --slug "$1" 2>/dev/null || true
}

# Is the (remote) dev session running? Args: host, slug -> stdout: running|stopped|unknown
cs_dev_remote_status_query() {
	local host="$1" slug="$2"
	cs_ssh_script "$host" "$slug" <<'REMOTE' 2>/dev/null || echo unknown
set -eu
export PATH="$HOME/.local/bin:$PATH"
codespace-cloud dev status --slug "$1" 2>/dev/null || echo unknown
REMOTE
}

# Is the LOCAL dev session running? Args: slug -> stdout: running|stopped|unknown
cs_dev_local_status_query() {
	cs_dev_cloud_local dev status --slug "$1" 2>/dev/null || echo unknown
}

# Parse ports out of a manifest json (stdin). Emits: label<TAB>port<TAB>scheme
cs_dev_parse_manifest() {
	jq -r '.ports[]? | [(.label // "svc"), (.port|tostring), (.scheme // (if .label=="web" then "https" else "http" end))] | @tsv' 2>/dev/null
}

# Wait for the manifest to report at least one port (or timeout). Only used when
# NO static ports were declared (purely-dynamic case) — otherwise the static map
# is forwarded immediately without blocking. Prints the manifest json on success.
# Args: mode, host, dest_rel, root, timeout_secs
cs_dev_wait_for_manifest() {
	local mode="$1" host="$2" dest_rel="$3" root="$4" timeout="${5:-300}"
	local waited=0 json
	while :; do
		json="$(cs_dev_manifest_now "$mode" "$host" "$dest_rel" "$root" 2>/dev/null || true)"
		if [ -n "$json" ] && [ "$(printf '%s' "$json" | cs_dev_parse_manifest | wc -l | tr -d ' ')" != "0" ]; then
			printf '%s' "$json"
			return 0
		fi
		[ "$waited" -lt "$timeout" ] || { >&2 echo "warn: dev-manifest.json still empty after ${timeout}s"; printf '%s' "$json"; return 1; }
		sleep 2
		waited=$((waited + 2))
	done
}

##############################
#  port resolution           #
##############################

# stacks.json 'dev' map fallback: top-level .dev or per-stack object .dev.
# Two shapes, both supported (back-compat):
#   flat:       dev: { web:3000, core-api:8000 }              (today's format)
#   structured: dev: { timeout:300, ports:{ web:3000, ... } } (reserved keys)
# When .dev.ports exists it's the port map; otherwise .dev IS the map minus the
# reserved 'timeout' key. Emits label<TAB>port<TAB>scheme. Args: stacks_json, stack_name
cs_dev_ports_from_stacks_json() {
	local sj="$1" name="$2"
	[ -f "$sj" ] || return 0
	jq -r --arg n "$name" '
		( .dev // (.stacks[$n] | if type=="object" then .dev else null end) // {} ) as $dev
		| ( if ($dev.ports? // null) != null then $dev.ports else ($dev | del(.timeout)) end )
		| to_entries[]? | [.key, (.value|tostring), (if .key=="web" then "https" else "http" end)] | @tsv
	' "$sj" 2>/dev/null
}

# Read the reserved dev.timeout (seconds) from stacks.json, top-level or per-stack.
# Empty if unset/absent. Args: stacks_json, stack_name
cs_dev_timeout_from_stacks_json() {
	local sj="$1" name="$2"
	[ -f "$sj" ] || return 0
	jq -r --arg n "$name" '
		( .dev // (.stacks[$n] | if type=="object" then .dev else null end) // {} )
		| (.timeout // empty)
	' "$sj" 2>/dev/null
}

# `# CS_DEV:` static hints in a local dev.sh (convention). Format:
#   # CS_DEV: web=3000:https core-api=8000 backend=8002
# Emits label<TAB>port<TAB>scheme. Args: dev_sh_path
cs_dev_ports_from_hints() {
	local f="$1" line tok label port scheme
	[ -f "$f" ] || return 0
	line="$(grep -m1 -E '^[[:space:]]*#[[:space:]]*CS_DEV:' "$f" 2>/dev/null | sed -E 's/^[[:space:]]*#[[:space:]]*CS_DEV:[[:space:]]*//')"
	[ -n "$line" ] || return 0
	for tok in $line; do
		label="${tok%%=*}"; rest="${tok#*=}"
		port="${rest%%:*}"
		if [ "$rest" != "$port" ]; then scheme="${rest#*:}"; else scheme=""; fi
		[ -n "$scheme" ] || { [ "$label" = "web" ] && scheme=https || scheme=http; }
		printf '%s\t%s\t%s\n' "$label" "$port" "$scheme"
	done
}

# Union two label<TAB>port<TAB>scheme streams, first-source-wins per label. Reads
# all args as tsv text (newline-separated rows) in order; the runtime manifest is
# passed first so its port/scheme win, while the static map fills labels it hasn't
# published yet. Blank/malformed rows (missing label or port) are dropped. This is
# what makes forwarding robust to a slow/partial manifest rather than racing on
# whichever fragment lands first.
cs_dev_merge_ports() {
	printf '%s\n' "$@" | awk -F'\t' 'NF>=2 && $1!="" && $2!="" && !seen[$1]++'
}

##############################
#  local proxy (Caddy)       #
##############################

cs_dev_caddy_bin() { echo "${CS_DEV_CADDY:-caddy}"; }
cs_dev_caddy_dir() { echo "$(cs_dev_cache_dir)/dev-caddy"; }
cs_dev_caddyfile() { echo "$(cs_dev_caddy_dir)/Caddyfile"; }

# Regenerate the Caddyfile from ALL registered dev sessions (source of truth),
# so adding/removing a stack's routes never disturbs another's.
cs_dev_caddy_regen() {
	local dir sessions_dir cf f
	dir="$(cs_dev_caddy_dir)"; mkdir -p "$dir"
	cf="$(cs_dev_caddyfile)"
	sessions_dir="$(cs_dev_cache_dir)/dev-sessions"
	: > "$cf"
	{
		echo "{"
		echo "	admin localhost:2019"
		echo "}"
	} >> "$cf"
	[ -d "$sessions_dir" ] || return 0
	while IFS= read -r f; do
		[ -f "$f" ] || continue
		jq -r '
			(.proxy // false) as $p | select($p)
			| .ports[]?
			| select(.url != null and (.url|startswith("https://")))
			| "\(.url) {\n\treverse_proxy \(if .scheme=="https" then "https://" else "" end)127.0.0.1:\(.local)"
			  + (if .scheme=="https" then " {\n\t\ttransport http {\n\t\t\ttls_insecure_skip_verify\n\t\t}\n\t}" else "" end)
			  + "\n}"
		' "$f" 2>/dev/null >> "$cf"
	done < <(find "$sessions_dir" -type f -name '*.json' 2>/dev/null)
}

# Ensure caddy is installed + running with our config; reload after regen.
# Returns non-zero if Caddy is unavailable (caller falls back to plain ports).
cs_dev_proxy_reload() {
	local caddy cf
	caddy="$(cs_dev_caddy_bin)"
	command -v "$caddy" >/dev/null 2>&1 || {
		>&2 echo "note: caddy not found; falling back to plain local ports (install caddy, or use --raw-ports to silence)"
		return 1
	}
	cs_dev_caddy_regen
	cf="$(cs_dev_caddyfile)"
	# reload a running instance, else start one. `caddy start` daemonizes.
	if curl -fsS -o /dev/null "http://localhost:2019/config/" 2>/dev/null; then
		"$caddy" reload --config "$cf" --adapter caddyfile 2>/dev/null || {
			>&2 echo "warn: caddy reload failed"; return 1; }
	else
		"$caddy" start --config "$cf" --adapter caddyfile 2>/dev/null || {
			>&2 echo "warn: caddy start failed (port ${CS_DEV_HTTPS_PORT:-443} may need privileges; try --raw-ports)"; return 1; }
	fi
	return 0
}

##############################
#  session lifecycle         #
##############################

# Build the port plan (json array) from resolved services + allocated local
# ports + URLs. Reads label<TAB>port<TAB>scheme lines on stdin.
# Args: url_slug, plain(1|""), local_mode(1|"").
#   plain      : 1:1 raw ports — local==remote, http://127.0.0.1:<port>, no proxy.
#   local_mode : services already listen on 127.0.0.1:<port> on THIS machine, so
#                local==remote (no ssh -L remap) even under Caddy https urls.
# In remote+slug mode local ports are ephemeral (a tunnel remaps remote->local).
# Emits a json array of port objects.
cs_dev_build_port_plan() {
	local url_slug="$1" plain="$2" local_mode="${3:-}"
	local https_port="${CS_DEV_HTTPS_PORT:-443}"
	local label port scheme local_port url sub first=1
	echo "["
	# `|| [ -n "$label" ]` so a final line WITHOUT a trailing newline is still
	# processed: ports_tsv comes from `$(...)` (trailing newline stripped) and is
	# piped in with `printf '%s'`, so read returns non-zero at EOF on the last row
	# even though it populated the vars — without this the LAST service is dropped.
	while IFS=$'\t' read -r label port scheme || [ -n "$label" ]; do
		[ -n "$port" ] || continue
		# local mode + raw mode both keep the service's own port (no tunnel remap).
		if [ -n "$plain" ] || [ -n "$local_mode" ]; then
			local_port="$port"
		else
			local_port="$(cs_dev_free_port)"
		fi
		if [ -n "$plain" ]; then
			url="http://127.0.0.1:$local_port"
		else
			if [ "$label" = "web" ]; then sub="$url_slug"; else sub="$url_slug-$(cs_dev_url_slug "$label")"; fi
			if [ "$https_port" = "443" ]; then url="https://$sub.localhost"; else url="https://$sub.localhost:$https_port"; fi
		fi
		[ -n "$first" ] || echo ","
		first=""
		printf '  {"label":%s,"remote":%s,"local":%s,"scheme":%s,"url":%s}' \
			"$(jq -Rn --arg v "$label" '$v')" "$port" "$local_port" \
			"$(jq -Rn --arg v "$scheme" '$v')" "$(jq -Rn --arg v "$url" '$v')"
	done
	echo ""
	echo "]"
}

# Open ssh -L tunnels for every port in the plan (one multiplexed ssh -N).
# Args: host, port_plan_json. Prints the tunnel pid.
cs_dev_start_tunnels() {
	local host="$1" plan="$2"
	local forwards=() l r
	while IFS=$'\t' read -r l r; do
		[ -n "$l" ] || continue
		forwards+=(-L "127.0.0.1:$l:127.0.0.1:$r")
	done < <(printf '%s' "$plan" | jq -r '.[] | [(.local|tostring),(.remote|tostring)] | @tsv')
	[ "${#forwards[@]}" -gt 0 ] || return 0
	# one long-lived, no-multiplex ssh holding all forwards; kill by pid to stop.
	# cs_ssh_opts expands to multiple words on purpose (same as cs_ssh/rsync -e).
	# shellcheck disable=SC2046,SC2086
	ssh $(cs_ssh_opts) -o ExitOnForwardFailure=yes -o ControlMaster=no -o ControlPath=none \
		-N "${forwards[@]}" "$host" &
	echo "$!"
}

# Write the session registry file. Args: file, host, jump, dest_rel, branch,
#   slug, tunnel_pid, proxy(1|""), port_plan_json
cs_dev_session_write() {
	local file="$1" host="$2" jump="$3" dest_rel="$4" branch="$5" slug="$6" pid="$7" proxy="$8" plan="$9"
	mkdir -p "$(dirname "$file")"
	jq -n \
		--arg host "$host" --arg jump "$jump" --arg relpath "$dest_rel" \
		--arg branch "$branch" --arg slug "$slug" \
		--argjson pid "${pid:-0}" --argjson proxy "$( [ -n "$proxy" ] && echo true || echo false )" \
		--argjson ports "$plan" \
		'{host:$host, jump:$jump, relpath:$relpath, branch:$branch, slug:$slug, tunnel_pid:$pid, proxy:$proxy, ports:$ports}' \
		> "$file"
}

