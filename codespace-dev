# Resolve config_rel (stack config dir under $CODESPACE_CONFIG_ROOT) + repos for
# a codespace path. Sets caller vars via stdout: two lines "config_rel" "repos".
cs_dev_resolve_config() {
	local path="$1" kind="$2" repo_id="$3"
	local config_rel="" repos=""
	if [ "$kind" = "stack" ]; then
		local org_dir sj
		org_dir="$(dirname "$path")"
		sj="$(cs_stack_resolve_config_at_quiet "$org_dir" 2>/dev/null)" || sj=""
		[ -n "$sj" ] && config_rel="$(cs_stack_config_rel "$sj" 2>/dev/null)" || true
		# repo list = the member dirs present under the stack. local stacks have a
		# real .git per repo; remote stacks are thin stubs whose repo dirs carry a
		# .codespace-remote marker (the real worktree lives on the host).
		local d
		for d in "$path"/*; do
			[ -d "$d" ] || continue
			{ [ -e "$d/.git" ] || cs_remote_marker "$d"; } || continue
			repos="${repos:+$repos,}$(basename "$d")"
		done
	else
		# single worktree: config dir is the repo's own user config
		config_rel="$repo_id"
	fi
	echo "$config_rel"
	echo "$repos"
}

# Provision + sync a codespace to its remote when `-r` is given but it isn't on
# the remote yet, mirroring `codespace open -r`. Delegates to cs_sync (which
# provisions if absent and records a .codespace/sync marker). Args: path, rhost
cs_dev_provision_remote() {
	local path="$1" rhost="$2"
	command -v cs_sync >/dev/null 2>&1 || {
		>&2 echo "err: 'dev -r' needs the codespace-sync component (run via 'codespace dev')"
		return 1
	}
	>&2 echo "==> provisioning remote for '$(basename "$path")' (not on the remote yet)"
	if [ -n "$rhost" ]; then
		cs_sync "$path" -r "$rhost"
	else
		cs_sync "$path" -r
	fi
}

# Read a remote target from whichever marker exists at <path>: a `create -r`
# stub (.codespace-remote) or a synced codespace (.codespace/sync); the stub
# wins per-key. Emits 5 lines: host, branch, kind, repo_id, relpath (any may be
# empty). Args: path
cs_dev_read_markers() {
	local path="$1" key v
	for key in host branch kind repo_id relpath; do
		v="$(cs_remote_marker_get "$path" "$key" 2>/dev/null || true)"
		[ -n "$v" ] || v="$(cs_sync_marker_get "$path" "$key" 2>/dev/null || true)"
		printf '%s\n' "$v"
	done
}

cs_dev() {
	# leading verb: `codespace dev {stop,status} [path]` — the friendly user
	# surface (infers the slug from the cwd). Everything else is the run form.
	local verb=""
	case "${1:-}" in stop|status) verb="$1"; shift ;; esac

	local path_arg="" rhost="" remote_flag="" stop="" status="" no_forward="" no_open="" detach="" plain="" timeout="" slug_arg=""
	[ "$verb" = stop ] && stop=1
	[ "$verb" = status ] && status=1
	while [ $# -gt 0 ]; do
		case "$1" in
			-r|--remote)
				remote_flag=1; shift
				if [ $# -gt 0 ] && [ "${1#-}" = "$1" ] && [ ! -e "$1" ]; then rhost="$1"; shift; fi ;;
			-s|--slug) slug_arg="${2:-}"; shift; [ $# -gt 0 ] && shift ;;
			--stop) stop=1; shift ;;
			--status) status=1; shift ;;
			--no-forward) no_forward=1; shift ;;
			--no-open) no_open=1; shift ;;
			--detach) detach=1; shift ;;
			--raw-ports|--plain-ports) plain=1; shift ;;   # --plain-ports: hidden back-compat alias
			--timeout) timeout="$2"; shift 2 ;;
			-h|--help) echo "$CS_DEV_HELP"; return 0 ;;
			*) path_arg="$1"; shift ;;
		esac
	done
	# --detach is reserved: cs_dev already returns after setup (tunnels run in the
	# background), so today it's a no-op we simply acknowledge.
	[ -z "$detach" ] || >&2 echo "note: --detach: dev already returns after setup (reserved for a future foreground-monitor mode)"

	# stop/status can target a codespace by SLUG (no local path needed): an
	# explicit -s <slug>, or a bare positional that doesn't resolve to a path or
	# a findable branch. With no target at all, `status` lists what's available.
	if [ -n "$stop$status" ]; then
		local evb="status"; [ -n "$stop" ] && evb="stop"
		local want_slug="$slug_arg"
		if [ -z "$want_slug" ] && [ -n "$path_arg" ] && [ ! -d "$path_arg" ] \
			&& ! cs_find "$path_arg" >/dev/null 2>&1; then
			want_slug="$path_arg"; path_arg=""
		fi
		if [ -n "$want_slug" ]; then
			cs_dev_status_or_stop_by_slug "$evb" "$want_slug"
			return $?
		fi
		if [ -n "$status" ] && [ -z "$path_arg" ] && ! cs_dev_cwd_is_codespace "$(pwd)"; then
			cs_dev_status_list
			return 0
		fi
	fi

	# resolve the codespace path (mirror cs_open's non-remote resolution)
	local path
	if [ -z "$path_arg" ]; then path="$(pwd)"
	elif [ -d "$path_arg" ]; then path="$(cs_abspath "$path_arg")"
	else path="$(cs_find "$path_arg")" || return 1; fi

	local host branch kind repo_id dest_rel meta
	meta="$(cs_dev_read_markers "$path")"
	host="$(sed -n '1p' <<<"$meta")"; branch="$(sed -n '2p' <<<"$meta")"
	kind="$(sed -n '3p' <<<"$meta")"; repo_id="$(sed -n '4p' <<<"$meta")"
	dest_rel="$(sed -n '5p' <<<"$meta")"
	[ -n "$rhost" ] && host="$rhost"

	# provision-if-absent: `-r` on a codespace not yet on the remote -> sync it
	# there first (like open -r), then re-read the marker. Skipped for stop/status.
	if [ -n "$remote_flag" ] && [ -z "$dest_rel" ] && [ -z "$stop$status" ]; then
		cs_dev_provision_remote "$path" "$rhost" || return 1
		meta="$(cs_dev_read_markers "$path")"
		host="$(sed -n '1p' <<<"$meta")"; branch="$(sed -n '2p' <<<"$meta")"
		kind="$(sed -n '3p' <<<"$meta")"; repo_id="$(sed -n '4p' <<<"$meta")"
		dest_rel="$(sed -n '5p' <<<"$meta")"
		[ -n "$rhost" ] && host="$rhost"
	fi

	# MODE: remote when we have a remote target (marker or -r-provisioned), else
	# local — run the same dev hooks on this machine (the reported bug: a plain
	# local codespace no longer errors, it just runs locally).
	local mode="local"
	[ -n "$host" ] && [ -n "$dest_rel" ] && mode="remote"

	[ -n "$branch" ] || branch="$(basename "$path")"

	# in local mode nothing recorded kind/repo_id, so detect them from disk.
	if [ "$mode" = local ]; then
		if cs_sync_is_stack "$path"; then kind="stack"
		else kind="worktree"; [ -n "$repo_id" ] || repo_id="$(cd "$path" 2>/dev/null && cs_repo_id 2>/dev/null || true)"; fi
	fi

	local slug jump host_key
	slug="$(cs_cleanpath "${slug_arg:-$branch}")"
	if [ "$mode" = remote ]; then
		jump="$(cs_remote_marker_get "$path" sandbox_host 2>/dev/null || true)"
		host_key="${jump:-$host}"
	else
		jump=""; host_key="local"
	fi

	# stop verb / --stop: tear down tunnels + proxy routes + the dev session.
	if [ -n "$stop" ]; then
		cs_dev_stop_target "$mode" "$host" "$slug" "$host_key" "$branch"
		return 0
	fi

	# status verb: report session + runner state; make no changes.
	if [ -n "$status" ]; then
		cs_dev_status_report "$mode" "$host" "$dest_rel" "$path" "$host_key" "$slug" "$branch"
		return 0
	fi

	# re-ensure a sandbox-backed remote stub (start if stopped; refresh ssh
	# alias/port), like rm/open. RUN path only — never as a side effect of status.
	if [ "$mode" = remote ] && cs_remote_marker_is_sandbox "$path"; then
		if cs_remote_reensure_sandbox "$path"; then host="$CS_SANDBOX_ALIAS"
		else >&2 echo "warn: could not re-ensure sandbox for $path; trying recorded host '$host'"; fi
	fi

	# resolve config dir + repo list (both modes)
	local cfg_out config_rel repos
	cfg_out="$(cs_dev_resolve_config "$path" "$kind" "$repo_id")"
	config_rel="$(printf '%s\n' "$cfg_out" | sed -n '1p')"
	repos="$(printf '%s\n' "$cfg_out" | sed -n '2p')"

	# local config dir (where the dev hooks live) + stacks.json (static ports/timeout).
	local cfg_local="" sj_local=""
	if [ -n "${CODESPACE_CONFIG_ROOT:-}" ] && [ -n "$config_rel" ]; then
		cfg_local="$CODESPACE_CONFIG_ROOT/$config_rel"
		sj_local="$cfg_local/stacks.json"; [ -f "$sj_local" ] || sj_local="$cfg_local/.codespace/stacks.json"
	fi

	if [ "$mode" = remote ]; then
		>&2 echo "==> [remote $host] starting dev for '$branch'${repos:+ ($repos)}"
		cs_dev_remote_start "$host" "$dest_rel" "$config_rel" "$repos" "$slug" || {
			>&2 echo "err: failed to start remote dev session"; return 1; }
	else
		>&2 echo "==> [local] starting dev for '$branch'${repos:+ ($repos)}"
		cs_dev_local_start "$path" "$cfg_local" "$repos" "$slug" || {
			>&2 echo "err: failed to start local dev session"; return 1; }
	fi

	if [ -n "$no_forward" ]; then
		if [ "$mode" = remote ]; then
			>&2 echo "==> dev session started (--no-forward); attach: ssh $host -t 'tmux attach -t codespace-dev-$slug'"
		else
			>&2 echo "==> dev session started (--no-forward); attach: tmux attach -t codespace-dev-$slug"
		fi
		return 0
	fi

	# resolve ports. Static (stacks.json 'dev' / '# CS_DEV:' hints) is resolved
	# FIRST and forwarded IMMEDIATELY; the manifest is only WAITED on when there
	# are NO static ports (purely-dynamic) — this kills the timeout pain for the
	# common case. The manifest still wins per-label (runtime port/scheme); the
	# static map fills any labels the manifest hasn't published yet.
	local static_tsv=""
	[ -n "$sj_local" ] && static_tsv="$(cs_dev_ports_from_stacks_json "$sj_local" "$(basename "$config_rel")")"
	[ -n "$static_tsv" ] || { [ -n "$cfg_local" ] && static_tsv="$(cs_dev_ports_from_hints "$cfg_local/dev.sh")"; }

	# timeout precedence: --timeout > $CS_DEV_TIMEOUT > stacks.json dev.timeout > 300
	[ -n "$timeout" ] || timeout="${CS_DEV_TIMEOUT:-}"
	[ -n "$timeout" ] || { [ -n "$sj_local" ] && timeout="$(cs_dev_timeout_from_stacks_json "$sj_local" "$(basename "$config_rel")")"; }
	[ -n "$timeout" ] || timeout=300

	local manifest ports_tsv
	if [ -n "$static_tsv" ]; then
		manifest="$(cs_dev_manifest_now "$mode" "$host" "$dest_rel" "$path" 2>/dev/null || true)"
	else
		manifest="$(cs_dev_wait_for_manifest "$mode" "$host" "$dest_rel" "$path" "$timeout" 2>/dev/null || true)"
	fi
	ports_tsv="$(printf '%s' "$manifest" | cs_dev_parse_manifest)"
	ports_tsv="$(cs_dev_merge_ports "$ports_tsv" "$static_tsv")"

	[ -n "$ports_tsv" ] || {
		>&2 echo "err: no dev ports resolved (empty manifest + no stacks.json 'dev' map / '# CS_DEV:' hints)"
		if [ "$mode" = remote ]; then >&2 echo "  the dev session is running; attach: ssh $host -t 'tmux attach -t codespace-dev-$slug'"
		else >&2 echo "  the dev session is running; attach: tmux attach -t codespace-dev-$slug"; fi
		return 1
	}

	# build the port plan. Local mode keeps each service's own port (no tunnel
	# remap) since it already listens on 127.0.0.1 here; remote+slug allocates
	# ephemeral local ports bridged by ssh -L.
	local url_slug plan proxy_ok="" local_flag=""
	[ "$mode" = local ] && local_flag=1
	url_slug="$(cs_dev_url_slug "$branch")"
	plan="$(printf '%s' "$ports_tsv" | cs_dev_build_port_plan "$url_slug" "$plain" "$local_flag")"

	# tunnels: remote only (local services already listen on 127.0.0.1).
	local tpid=""
	[ "$mode" = remote ] && tpid="$(cs_dev_start_tunnels "$host" "$plan")"

	# register the session, then (unless raw) wire up Caddy routes
	local sf
	sf="$(cs_dev_session_file "$host_key" "$slug")"
	if [ -z "$plain" ]; then
		cs_dev_session_write "$sf" "$host" "$jump" "$dest_rel" "$branch" "$slug" "$tpid" "1" "$plan"
		if cs_dev_proxy_reload; then proxy_ok=1; else
			# proxy unavailable: rewrite the session as plain and print local ports
			cs_dev_session_write "$sf" "$host" "$jump" "$dest_rel" "$branch" "$slug" "$tpid" "" "$plan"
		fi
	else
		cs_dev_session_write "$sf" "$host" "$jump" "$dest_rel" "$branch" "$slug" "$tpid" "" "$plan"
	fi

	# report + open
	cs_dev_report "$plan" "$proxy_ok" "$local_flag"
	if [ -z "$no_open" ] && [ -n "$proxy_ok" ]; then
		local primary
		primary="$(printf '%s' "$plan" | jq -r '(.[] | select(.label=="web") | .url) // (.[0].url) // empty' 2>/dev/null)"
		[ -n "$primary" ] && cs_dev_open_url "$primary"
	fi
}

# Print the service table. Args: plan_json, proxy_ok, local_mode(1|"")
cs_dev_report() {
	local plan="$1" proxy_ok="$2" local_mode="${3:-}"
	>&2 echo "==> dev services:"
	if [ -n "$proxy_ok" ] && [ -n "$local_mode" ]; then
		printf '%s' "$plan" | jq -r '.[] | "    \(.label): \(.url)  (-> 127.0.0.1:\(.local))"' >&2
	elif [ -n "$proxy_ok" ]; then
		printf '%s' "$plan" | jq -r '.[] | "    \(.label): \(.url)  (-> 127.0.0.1:\(.local) -> sandbox :\(.remote))"' >&2
	elif [ -n "$local_mode" ]; then
		printf '%s' "$plan" | jq -r '.[] | "    \(.label): http://127.0.0.1:\(.local)"' >&2
	else
		printf '%s' "$plan" | jq -r '.[] | "    \(.label): http://127.0.0.1:\(.local)  (-> sandbox :\(.remote))"' >&2
	fi
}

# The session-registry file for a slug, searched across all recorded host_keys
# (so status/stop can find a codespace by slug alone). Prints the first match's
# path, or nothing. Args: clean_slug
cs_dev_find_session_by_slug() {
	local clean="$1" base f
	base="$(cs_dev_cache_dir)/dev-sessions"
	[ -d "$base" ] || return 0
	for f in "$base"/*/"$clean.json"; do
		[ -f "$f" ] && { printf '%s' "$f"; return 0; }
	done
	return 0
}

# Is <dir> an actual codespace (a remote/sync marker, or a real local worktree/
# stack)? Used to decide whether `dev status` should report on the cwd or fall
# back to listing. Args: dir
cs_dev_cwd_is_codespace() {
	local p="$1"
	[ -d "$p" ] || return 1
	cs_remote_marker "$p" 2>/dev/null && return 0
	[ -f "$p/.codespace/sync" ] && return 0
	cs_sync_is_stack "$p" 2>/dev/null && return 0
	[ -e "$p/.git" ] && return 0
	return 1
}

# Container state of a sandbox-backed remote codespace, queried on the JUMP host
# (never the alias, which may be stale/down): absent|running|stopped|unknown.
# Args: jump_host, slug
cs_dev_remote_sandbox_state() {
	local jump="$1" slug="$2"
	cs_ssh_script "$jump" "$slug" <<'REMOTE' 2>/dev/null || echo unknown
set -eu
export PATH="$HOME/.local/bin:$PATH"
codespace-cloud sandbox status "$1" 2>/dev/null || echo unknown
REMOTE
}

# Tear down a codespace's tunnels + proxy routes + dev session. Shared by the
# path-form and slug-form stop. Args: mode host slug host_key branch
cs_dev_stop_target() {
	local mode="$1" host="$2" slug="$3" host_key="$4" branch="$5"
	local sf tpid
	sf="$(cs_dev_session_file "$host_key" "$slug")"
	if [ -f "$sf" ]; then
		tpid="$(jq -r '.tunnel_pid // 0' "$sf" 2>/dev/null || echo 0)"
		[ "${tpid:-0}" -gt 0 ] 2>/dev/null && kill "$tpid" 2>/dev/null || true
		rm -f "$sf"
		cs_dev_proxy_reload || true
	fi
	if [ "$mode" = remote ]; then cs_dev_remote_stop "$host" "$slug" || true; else cs_dev_local_stop "$slug"; fi
	>&2 echo "==> dev stopped for '${branch:-$slug}'"
}

# status/stop a codespace addressed by SLUG (no local worktree needed): resolve
# its host/mode from the recorded session, else assume a local slug. Args: verb(status|stop), slug
cs_dev_status_or_stop_by_slug() {
	local verb="$1" want="$2"
	local clean sf host="" jump="" branch="" dest_rel="" mode host_key
	clean="$(cs_cleanpath "$want")"
	sf="$(cs_dev_find_session_by_slug "$clean")"
	if [ -n "$sf" ] && [ -f "$sf" ]; then
		host="$(jq -r '.host // ""' "$sf" 2>/dev/null)"
		jump="$(jq -r '.jump // ""' "$sf" 2>/dev/null)"
		branch="$(jq -r '.branch // ""' "$sf" 2>/dev/null)"
		dest_rel="$(jq -r '.relpath // ""' "$sf" 2>/dev/null)"
	fi
	[ -n "$host" ] && mode=remote || mode=local
	host_key="${jump:-${host:-local}}"
	[ -n "$branch" ] || branch="$want"
	if [ "$verb" = stop ]; then
		cs_dev_stop_target "$mode" "$host" "$clean" "$host_key" "$branch"
	else
		cs_dev_status_report "$mode" "$host" "$dest_rel" "" "$host_key" "$clean" "$branch"
	fi
}

# List the recorded dev sessions (+ local sandboxes) so the user can pick one to
# target with `-s <slug>`. Cheap: no per-session SSH (just tunnel-pid liveness).
cs_dev_status_list() {
	local base f any="" cloud_root
	base="$(cs_dev_cache_dir)/dev-sessions"
	>&2 echo "dev sessions (target one with: codespace dev {status,stop} -s <slug>):"
	if [ -d "$base" ]; then
		for f in "$base"/*/*.json; do
			[ -f "$f" ] || continue
			any=1
			local slug host branch tpid alive
			slug="$(jq -r '.slug // ""' "$f" 2>/dev/null)"
			host="$(jq -r '.host // ""' "$f" 2>/dev/null)"
			branch="$(jq -r '.branch // ""' "$f" 2>/dev/null)"
			if [ -n "$host" ]; then
				tpid="$(jq -r '.tunnel_pid // 0' "$f" 2>/dev/null || echo 0)"
				alive=no; { [ "${tpid:-0}" -gt 0 ] 2>/dev/null && kill -0 "$tpid" 2>/dev/null; } && alive=yes
				>&2 printf '  - %-28s [remote %s] tunnels:%s (%s)\n' "$slug" "$host" "$alive" "$branch"
			else
				>&2 printf '  - %-28s [local] (%s)\n' "$slug" "$branch"
			fi
		done
	fi
	[ -n "$any" ] || >&2 echo "  (none recorded)"
	# local docker sandboxes, when the cloud module is present on this machine.
	cloud_root="$(cs_cloud_root 2>/dev/null || true)"
	if [ -n "$cloud_root" ] && [ -x "$cloud_root/codespace-cloud" ]; then
		local ls_out
		ls_out="$(cs_dev_cloud_local sandbox ls 2>/dev/null || true)"
		[ -n "$ls_out" ] && { >&2 echo "local sandboxes:"; >&2 printf '%s\n' "$ls_out" | sed 's/^/  /'; }
	fi
	return 0
}

# Report dev status for a codespace: whether the session is running (queried via
# the runner) + the forwarded service urls from the session file (if any).
# Read-only — never (re)starts a sandbox. Distinguishes ABSENT (no codespace or
# session exists) from stopped, so a non-existent stack never reports "stopped".
# Args: mode host dest_rel path host_key slug branch
cs_dev_status_report() {
	local mode="$1" host="$2" dest_rel="$3" path="$4" host_key="$5" slug="$6" branch="$7"
	local state sf exists="" cstate=""
	sf="$(cs_dev_session_file "$host_key" "$slug")"
	# existence: a recorded session, a remote target, or a real local codespace.
	[ -f "$sf" ] && exists=1
	[ "$mode" = remote ] && [ -n "$host" ] && [ -n "$dest_rel" ] && exists=1
	[ "$mode" = local ] && [ -n "$path" ] && cs_dev_cwd_is_codespace "$path" && exists=1
	if [ -z "$exists" ]; then
		>&2 echo "dev '$branch' — not created (no codespace or dev session found)."
		>&2 echo "  run 'codespace dev [-r]' from the codespace, or 'codespace dev status' to list sessions."
		return 0
	fi

	if [ "$mode" = remote ]; then
		# sandbox-backed (host_key is the jump host, distinct from the alias):
		# check the CONTAINER first so we report absent/stopped without SSHing a
		# possibly-dead alias, and without (re)starting anything.
		if [ -n "$host_key" ] && [ "$host_key" != local ] && [ "$host_key" != "$host" ]; then
			cstate="$(cs_dev_remote_sandbox_state "$host_key" "$slug" 2>/dev/null || echo unknown)"
			case "$cstate" in
				absent)  >&2 echo "dev '$branch' — remote sandbox not provisioned. run 'codespace dev -r' to create it."; return 0 ;;
				stopped) >&2 echo "dev '$branch' — remote sandbox stopped. run 'codespace dev -r' to start it."; return 0 ;;
			esac
		fi
		state="$(cs_dev_remote_status_query "$host" "$slug" 2>/dev/null || echo unknown)"
		>&2 echo "dev '$branch' — remote ($host): ${state:-unknown}"
	else
		state="$(cs_dev_local_status_query "$slug" 2>/dev/null || echo unknown)"
		>&2 echo "dev '$branch' — local: ${state:-unknown}"
	fi

	if [ -f "$sf" ]; then
		if [ "$mode" = remote ]; then
			local tpid alive="no"
			tpid="$(jq -r '.tunnel_pid // 0' "$sf" 2>/dev/null || echo 0)"
			{ [ "${tpid:-0}" -gt 0 ] 2>/dev/null && kill -0 "$tpid" 2>/dev/null; } && alive="yes"
			>&2 echo "  tunnels: pid ${tpid:-0} (alive: $alive)"
		fi
		>&2 echo "  services:"
		jq -r '.ports[]? | "    \(.label): \(.url)  (-> 127.0.0.1:\(.local))"' "$sf" >&2 2>/dev/null || true
	else
		>&2 echo "  (no forwarded session recorded; run 'codespace dev' to start one)"
	fi
	return 0
}

# Open a URL in the default browser (best-effort, cross-platform).
cs_dev_open_url() {
	local url="$1"
	if command -v open >/dev/null 2>&1; then open "$url" >/dev/null 2>&1 || true
	elif command -v xdg-open >/dev/null 2>&1; then xdg-open "$url" >/dev/null 2>&1 || true
	fi
	>&2 echo "==> $url"
}

test -n "${CS_DEV_NO_RUN:-}" || {
	cs_dev "$@"
	exit $?
}
