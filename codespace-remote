#!/usr/bin/env bash

# codespace-remote: remote-codespace helpers + create/remove flows.
# this file should be sourced, not executed directly.
#
# Sourced from codespace-utils so any caller of `source codespace-utils`
# (codespace, codespace-worktree, codespace-stack, codespace-find, ...) gets
# these functions for free.
#
# Path layout (single mapping rule):
#   local  $HOME/X     <->  remote  $HOME/codespace/X
# Plus a config mirror:
#   local  $CODESPACE_CONFIG_ROOT/<repo-id>/   <->  remote  $HOME/codespace-config/<repo-id>/
#
# All cs_remote_* helpers traffic in REMOTE-RELATIVE paths (relative to remote
# $HOME) so we don't have to fight bash quoting around literal "$HOME" strings:
#
#   "codespace/org/repo"          -- remote base repo
#   "codespace/org/repo_feat"     -- remote worktree
#   "codespace-config/org/repo"   -- remote rsynced config dir
#
# Helpers accepting these prepend $HOME/ on the remote side.

# include-guard so we can be sourced multiple times safely (codespace-utils
# may be sourced from multiple entry points in the same shell).
if [ -n "${_CS_REMOTE_LOADED:-}" ]; then
	return 0 2>/dev/null || true
fi
_CS_REMOTE_LOADED=1


###################################
#                                 #
#  resolution / pure helpers      #
#                                 #
###################################

# Sentinel: passed by `-r/--remote` (with no value) to mean "use the configured default".
CS_REMOTE_USE_DEFAULT="__use_default__"

# Find a per-repo/per-org config FILE by name, walking repo-level then
# org-level under $CODESPACE_CONFIG_ROOT (repo wins). Per cs_find_in_config_dir
# each level may hold the file in .codespace/ or at the config-dir root
# (.codespace/<name> wins). Shared by the `remote` target and `ssh-key` list
# resolvers, so the walk lives in one place.
# Args: name, [repo_id]  -- repo_id defaults to cs_repo_id (cwd-derived).
# Stdout: resolved file path; returns 1 if $CODESPACE_CONFIG_ROOT is unset, the
# repo-id can't be resolved, or no file exists at either level.
cs_find_repo_org_config() {
	local name="$1" repo_id="${2:-}"
	[ -n "${CODESPACE_CONFIG_ROOT:-}" ] || return 1
	if [ -z "$repo_id" ]; then
		repo_id="$(cs_repo_id 2>/dev/null)" || repo_id=""
	fi
	[ -n "$repo_id" ] || return 1

	local found
	found="$(cs_find_in_config_dir "$CODESPACE_CONFIG_ROOT/$repo_id" "$name")"
	if [ -n "$found" ]; then echo "$found"; return 0; fi

	local org_id
	org_id="$(dirname "$repo_id")"
	if [ "$org_id" != "." ]; then
		found="$(cs_find_in_config_dir "$CODESPACE_CONFIG_ROOT/$org_id" "$name")"
		if [ -n "$found" ]; then echo "$found"; return 0; fi
	fi
	return 1
}

# Resolve the SSH target for a remote codespace.
# Precedence (first non-empty wins):
#   1. flag value (if not the sentinel)
#   2. $CS_DEFAULT_REMOTE
#   3. per-repo/per-org `remote` config file (cs_find_repo_org_config)
# Args: flag_value (may be "" or the sentinel)
# Stdout: ssh target (e.g. user@host); empty + non-zero if unresolved.
cs_resolve_remote() {
	local flag_value="${1:-}"

	if [ -n "$flag_value" ] && [ "$flag_value" != "$CS_REMOTE_USE_DEFAULT" ]; then
		echo "$flag_value"
		return 0
	fi

	if [ -n "${CS_DEFAULT_REMOTE:-}" ]; then
		echo "$CS_DEFAULT_REMOTE"
		return 0
	fi

	local remote_file
	if remote_file="$(cs_find_repo_org_config remote)"; then
		head -n1 "$remote_file" | tr -d '[:space:]'
		return 0
	fi

	return 1
}

# Resolve the private key(s) to load into the local ssh-agent so remote git
# operations can authenticate to the code host via agent forwarding.
# Source (first that applies):
#   1. $CS_SSH_KEY
#   2. per-repo/per-org `ssh-key` config file (cs_find_repo_org_config)
# Both accept MULTIPLE keys: entries split on commas AND newlines; whitespace
# is trimmed, blank and `#`-comment lines are dropped, and a leading `~` is
# expanded to $HOME.
# Args: [repo_id]
# Stdout: zero or more key paths, one per line.
cs_resolve_ssh_keys() {
	local raw file
	if [ -n "${CS_SSH_KEY:-}" ]; then
		raw="$CS_SSH_KEY"
	else
		file="$(cs_find_repo_org_config ssh-key "${1:-}")" || return 0
		raw="$(cat "$file")"
	fi

	local key
	printf '%s\n' "$raw" | tr ',' '\n' | while IFS= read -r key; do
		key="${key#"${key%%[![:space:]]*}"}"
		key="${key%"${key##*[![:space:]]}"}"
		[ -n "$key" ] && [ "${key#\#}" = "$key" ] || continue
		printf '%s\n' "${key/#\~/$HOME}"
	done
}

# Extract the ssh login target from a git clone URL, for auth diagnostics.
#   git@github.com:org/repo.git      -> git@github.com
#   ssh://git@github.com/org/repo    -> git@github.com
#   https://github.com/org/repo.git  -> github.com
# Returns 1 for shapes we can't parse (caller just omits the hint line).
cs_ssh_target_from_url() {
	local url="$1"
	case "$url" in
		ssh://*)  url="${url#ssh://}"; echo "${url%%/*}" ;;
		*://*)    url="${url#*://}"; url="${url%%/*}"; echo "${url##*@}" ;;
		*@*:*)    echo "${url%%:*}" ;;
		*:*)      echo "${url%%:*}" ;;
		*)        return 1 ;;
	esac
}

# Map a local path under $HOME to the corresponding remote-relative path
# (relative to remote $HOME). Pure: works for paths that don't yet exist locally.
# Args: local_abs_path
# Stdout: relpath like "codespace/org/repo_feat"
# Returns 1 if local_abs_path is not under $HOME.
cs_remote_relpath_for_local() {
	local local_path="$1" home_real
	home_real="$(realpath "$HOME" 2>/dev/null)" || home_real="$HOME"

	local rel=""
	case "$local_path" in
		"$HOME") rel="" ;;
		"$HOME"/*) rel="${local_path#"$HOME"/}" ;;
		"$home_real") rel="" ;;
		"$home_real"/*) rel="${local_path#"$home_real"/}" ;;
		*)
			>&2 echo "err: cannot map path outside \$HOME to remote: $local_path"
			return 1
			;;
	esac

	if [ -z "$rel" ]; then
		echo "$CS_WT_PREFIX"
	else
		echo "$CS_WT_PREFIX/$rel"
	fi
}


###################################
#                                 #
#  remote path base (indirection) #
#                                 #
###################################
#
# Remote paths come in two logical namespaces, each with a base dir on the
# remote:
#   - WORKTREES + base repos   -> "$CS_WT_PREFIX/..."      (default base $HOME)
#   - config mirror (creds)    -> "$CS_CFG_PREFIX/..."     (base $HOME)
# In the default (host-FS) layout both bases are the remote $HOME, so a relpath
# like "codespace/org/repo" resolves to "$HOME/codespace/org/repo" exactly as
# before. In SANDBOX mode the worktree namespace is redirected to a per-stack
# volume (an absolute path such as /codespaces/<slug>) while the config mirror
# stays on the shared per-user home volume — see cs_sandbox_* + the wiring in
# create/sync. The redirection is expressed with ONE variable, CS_WORKTREE_BASE,
# resolved on the remote by cs_rref (below); nothing else in the flow hardcodes
# "$HOME/codespace".

# Logical relpath prefixes (single source of truth; not scattered literals).
CS_WT_PREFIX="codespace"          # worktrees + base repos
CS_CFG_PREFIX="codespace-config"  # rsynced config dir (creds/tokens)

# The remote-side resolver, emitted into every remote script by cs_ssh_script.
# Maps a logical relpath to an absolute remote path, honoring CS_WORKTREE_BASE
# (exported into the script by the prologue when a sandbox is active). Kept as a
# text constant so it can be prepended verbatim; POSIX sh, no bashisms.
CS_RREF_DEF='cs_rref() {
	case "$1" in
		codespace-config|codespace-config/*) printf "%s/%s\n" "$HOME" "$1" ;;
		codespace)   printf "%s\n" "${CS_WORKTREE_BASE:-$HOME/codespace}" ;;
		codespace/*) printf "%s/%s\n" "${CS_WORKTREE_BASE:-$HOME/codespace}" "${1#codespace/}" ;;
		*)           printf "%s/%s\n" "$HOME" "$1" ;;
	esac
}'

# Prologue prepended to every cs_ssh_script body: defines cs_rref, and — when a
# sandbox is active on the client (CS_WORKTREE_BASE set in our env) — pins the
# same base on the remote so worktree relpaths land on the per-stack volume.
# Host-FS mode leaves CS_WORKTREE_BASE unset, so cs_rref uses "$HOME/codespace"
# and behavior is byte-for-byte the old one.
cs_remote_prologue() {
	printf '%s\n' "$CS_RREF_DEF"
	if [ -n "${CS_WORKTREE_BASE:-}" ]; then
		printf 'CS_WORKTREE_BASE=%q\n' "$CS_WORKTREE_BASE"
	fi
}

# Client-side twin of cs_rref for rsync destinations (rsync can't call the
# remote function). Only the worktree namespace is ever redirected, and only to
# an absolute path we already know locally (the sandbox base), so we never need
# the remote $HOME here: config + everything else stay home-relative.
# Args: relpath. Stdout: rsync destination (relative or absolute).
cs_remote_rsync_dest() {
	local rel="$1"
	if [ -z "${CS_WORKTREE_BASE:-}" ]; then
		echo "$rel"; return 0
	fi
	case "$rel" in
		"$CS_WT_PREFIX")    echo "$CS_WORKTREE_BASE" ;;
		"$CS_WT_PREFIX"/*)  echo "$CS_WORKTREE_BASE/${rel#"$CS_WT_PREFIX"/}" ;;
		*)                  echo "$rel" ;;
	esac
}


###################################
#                                 #
#  marker file (.codespace-remote)#
#                                 #
###################################

# Path of the .codespace-remote marker for a given codespace dir (default: cwd).
cs_remote_marker_path() {
	if [ -n "${1:-}" ]; then
		echo "$1/.codespace-remote"
	else
		echo "$(pwd)/.codespace-remote"
	fi
}

# Read a single key from a .codespace-remote marker file.
# Args: dir, key
# Stdout: value, or empty if not set / file missing
cs_remote_marker_get() {
	local dir="$1" key="$2"
	local marker
	marker="$(cs_remote_marker_path "$dir")"
	[ -f "$marker" ] || return 0
	awk -F= -v k="$key" '$1 == k { sub(/^[^=]*=/, "", $0); print; exit }' "$marker"
}

# Write a .codespace-remote marker file at <dir> with the given key=value pairs.
# Args: dir, key=value, [key=value]...
cs_remote_marker_write() {
	local dir="$1"; shift
	mkdir -p "$dir"
	local marker="$dir/.codespace-remote"
	: > "$marker"
	local kv
	for kv in "$@"; do
		echo "$kv" >> "$marker"
	done
}

# Returns 0 if dir contains a .codespace-remote marker.
cs_remote_marker() {
	local dir="${1:-$(pwd)}"
	[ -f "$(cs_remote_marker_path "$dir")" ]
}


###################################
#                                 #
#  ssh / rsync wrappers           #
#                                 #
###################################

# SSH options shared by ssh + rsync. Persist a control socket across calls in
# one create flow, so we don't pay multi-hop / 2FA / banner cost repeatedly.
# ForwardAgent=yes lets git operations on the remote (e.g. `git clone
# git@github.com:...`) authenticate via the user's local ssh-agent, instead of
# requiring a separate key on the remote. Override per-host in ~/.ssh/config
# (`ForwardAgent no`) if you want to opt out.
cs_ssh_opts() {
	mkdir -p "$HOME/.ssh" 2>/dev/null || true
	echo "-o BatchMode=yes -o ForwardAgent=yes -o ControlMaster=auto -o ControlPath=$HOME/.ssh/cs-cm-%r@%h:%p -o ControlPersist=60"
}

# Run a one-shot command on the remote.
# Args: host, cmd...
cs_ssh() {
	local host="$1"; shift
	# shellcheck disable=SC2046
	ssh $(cs_ssh_opts) "$host" -- "$@"
}

# Run a bash script on the remote, reading the script body from stdin.
# Trailing args are forwarded as positional ($1..$N) to the script body — this
# is the safe way to pass shell metacharacters / paths without quoting acrobatics.
# Args: host, [script_arg]...
# Stdin: bash script body
cs_ssh_script() {
	local host="$1"; shift
	local quoted=""
	local arg
	for arg in "$@"; do
		# escape single quotes for use inside single-quoted shell tokens
		quoted="$quoted '$(printf '%s' "$arg" | sed "s/'/'\\\\''/g")'"
	done
	# Prepend the shared prologue (defines cs_rref + pins CS_WORKTREE_BASE in
	# sandbox mode) ahead of the caller's script body, so every remote heredoc
	# can resolve logical relpaths with cs_rref. The body still sees the same
	# positional args (they ride on `bash -s <args>`, not stdin).
	# shellcheck disable=SC2046
	{ cs_remote_prologue; cat; } | ssh $(cs_ssh_opts) "$host" -- "bash -s$quoted"
}

# rsync wrapper using the same SSH options.
# Args: host, rsync_args..., remote_relpath_dest
# (sources may include `--delete` etc.; the LAST positional is the dest relpath)
cs_rsync_to_remote() {
	local host="$1"; shift
	local n=$#
	local sources=("${@:1:$((n-1))}")
	local dest_rel="${!n}"
	local dest
	dest="$(cs_remote_rsync_dest "$dest_rel")"
	rsync -a -e "ssh $(cs_ssh_opts)" "${sources[@]}" "$host:$dest"
}

# Resolve the remote $HOME for a host (one ssh round-trip; cheap via ControlMaster).
# Memoized per-host in $_CS_REMOTE_HOME_<host_slug>.
# Args: host
# Stdout: absolute remote $HOME (no trailing slash)
cs_remote_home() {
	local host="$1"
	local slug var
	slug="$(printf '%s' "$host" | tr -c 'a-zA-Z0-9' '_')"
	var="_CS_REMOTE_HOME_$slug"
	if [ -z "${!var:-}" ]; then
		local h
		h="$(cs_ssh "$host" 'printf %s "$HOME"')" || h=""
		if [ -z "$h" ]; then
			h="$(cs_ssh "$host" 'printf %s "$HOME"')" || h=""
		fi
		test -n "$h" || return 1
		printf -v "$var" '%s' "$h"
		export "${var?}"
	fi
	printf '%s\n' "${!var}"
}

# Resolve a logical relpath to its absolute path ON the remote, client-side
# (the mirror of the remote cs_rref, for callers like editor-open that need the
# path locally). The worktree namespace may be redirected to a sandbox base we
# already know locally (no round-trip); everything else hangs off remote $HOME.
# Args: host, relpath. Stdout: absolute remote path.
cs_remote_abs() {
	local host="$1" rel="$2"
	if [ -n "${CS_WORKTREE_BASE:-}" ]; then
		case "$rel" in
			"$CS_WT_PREFIX"|"$CS_WT_PREFIX"/*) cs_remote_rsync_dest "$rel"; return 0 ;;
		esac
	fi
	local home
	home="$(cs_remote_home "$host")" || return 1
	echo "$home/$rel"
}

# ssh-add a single key, preferring the macOS keychain (so a passphrase-protected
# key loads non-interactively). Falls back to a plain ssh-add. Args: key path.
cs_ssh_add_key() {
	local key="$1"
	if [ "$(uname -s)" = "Darwin" ]; then
		if ssh-add --apple-use-keychain "$key" 2>/dev/null; then return 0; fi
	fi
	ssh-add "$key" 2>/dev/null
}

# Ensure the local ssh-agent holds a key that agent-forwarding can present to
# the code host, so remote git operations (clone/fetch) can authenticate.
# Best-effort (never fatal): the fail-fast clone diagnostic is the hard gate.
#   1. load configured key(s) -- $CS_SSH_KEY or a per-repo/per-org `ssh-key`
#      file (multiple supported). ssh-add each once (memoized per path).
#   2. only if nothing was configured AND the agent is empty: load the user's
#      main/default identities (+ macOS keychain).
#   3. warn if the agent still has no forwardable key.
# Memoized so repeated calls (e.g. per-repo across a stack) stay cheap.
# Args: [repo_id]
cs_ensure_agent_key() {
	local repo_id="${1:-}"
	local loaded_any="" key

	while IFS= read -r key; do
		[ -n "$key" ] || continue
		loaded_any=1
		case " ${_CS_AGENT_ADDED_KEYS:-} " in *" $key "*) continue ;; esac
		if [ ! -f "$key" ]; then
			>&2 echo "warn: configured ssh key not found: $key"
			continue
		fi
		if cs_ssh_add_key "$key"; then
			_CS_AGENT_ADDED_KEYS="${_CS_AGENT_ADDED_KEYS:-} $key"
			>&2 echo "note: added ssh key to agent for remote git auth: $key"
		else
			>&2 echo "warn: could not ssh-add configured key (passphrase or bad key?): $key"
		fi
	done < <(cs_resolve_ssh_keys "$repo_id")

	if [ -n "${_CS_AGENT_FALLBACK_DONE:-}" ]; then return 0; fi
	_CS_AGENT_FALLBACK_DONE=1
	if [ -n "$loaded_any" ]; then return 0; fi

	local rc=0
	ssh-add -l >/dev/null 2>&1 || rc=$?
	if [ "$rc" -eq 0 ]; then return 0; fi
	if [ "$rc" -eq 2 ]; then
		>&2 echo "warn: no ssh-agent running; remote git auth via forwarding won't work."
		>&2 echo "  start one and add your key: eval \"\$(ssh-agent)\" && ssh-add <key>"
		return 0
	fi

	# rc == 1: agent reachable but empty -> load the user's main/default keys.
	if [ "$(uname -s)" = "Darwin" ]; then
		ssh-add --apple-load-keychain 2>/dev/null || true
	fi
	if [ -z "${CS_NO_INTERACTIVE:-}" ]; then
		ssh-add 2>/dev/null || true
	fi
	if ! ssh-add -l >/dev/null 2>&1; then
		>&2 echo "warn: ssh-agent has no keys; the remote git clone/fetch will likely fail."
		>&2 echo "  load one (ssh-add <key>) or configure key(s) for codespace:"
		>&2 echo "    \$CS_SSH_KEY=<path>[,<path>...]  or a per-repo/org 'ssh-key' file."
	fi
	return 0
}


###################################
#                                 #
#  sandbox client glue            #
#                                 #
###################################
#
# The client half of the sandbox model: drive the host orchestrator over
# SSH-to-host (never raw docker) to ensure a per-stack DinD sandbox, authorize
# our key into it, and register it as a first-class SSH destination (a
# ~/.ssh/config Host alias with ProxyJump <host>). Once the alias exists, every
# transport — cs_ssh, rsync -e ssh, GIT_SSH_COMMAND, mutagen — reaches the
# sandbox interior just by using the alias as $host. See remote-codespaces.md.

# Dedicated include file for sandbox Host aliases, so we never rewrite the
# user's hand-maintained ~/.ssh/config (we only ensure one Include line).
cs_sandbox_ssh_config_path() {
	echo "$HOME/.ssh/config.d/codespace-sandboxes"
}

# Ensure ~/.ssh/config Includes our sandbox alias file (idempotent). The
# Include is prepended so it applies before any Host blocks.
cs_sandbox_ssh_config_ensure_include() {
	local cfg="$HOME/.ssh/config" inc line tmp
	inc="$(cs_sandbox_ssh_config_path)"
	mkdir -p "$HOME/.ssh/config.d"
	chmod 700 "$HOME/.ssh" 2>/dev/null || true
	touch "$inc"
	chmod 600 "$inc" 2>/dev/null || true
	line="Include config.d/codespace-sandboxes"
	if [ ! -f "$cfg" ] || ! grep -qxF "$line" "$cfg" 2>/dev/null; then
		tmp="$(mktemp)"
		printf '%s\n' "$line" > "$tmp"
		[ -f "$cfg" ] && cat "$cfg" >> "$tmp"
		mv "$tmp" "$cfg"
		chmod 600 "$cfg" 2>/dev/null || true
	fi
}

# Write/refresh the Host alias for a sandbox (replaces any prior block for the
# same alias, so a new ephemeral port takes effect). Args: alias, jump_host, port, [user]
cs_sandbox_ssh_config_write() {
	local alias="$1" jump_host="$2" port="$3" user="${4:-codespace}"
	cs_sandbox_ssh_config_ensure_include
	local inc knownhosts tmp
	inc="$(cs_sandbox_ssh_config_path)"
	knownhosts="$HOME/.ssh/cs-sandbox-known-hosts"
	tmp="$(mktemp)"
	awk -v a="$alias" '
		/^Host / { skip = ($2 == a) }
		!skip { print }
	' "$inc" > "$tmp" 2>/dev/null || true
	{
		cat "$tmp"
		echo "Host $alias"
		echo "	HostName 127.0.0.1"
		echo "	Port $port"
		echo "	User $user"
		echo "	ProxyJump $jump_host"
		echo "	StrictHostKeyChecking accept-new"
		echo "	UserKnownHostsFile $knownhosts"
		echo "	ForwardAgent yes"
	} > "$inc"
	rm -f "$tmp"
	chmod 600 "$inc" 2>/dev/null || true
}

# Resolve the local PUBLIC key to authorize into a sandbox (so our jumped ssh
# can log in). Prefers a configured private key's .pub, else a default identity.
# Args: [repo_id]. Stdout: the public key line; non-zero if none found.
cs_sandbox_pubkey() {
	local key f
	key="$(cs_resolve_ssh_keys "${1:-}" | head -n1)"
	if [ -n "$key" ] && [ -f "$key.pub" ]; then
		cat "$key.pub"
		return 0
	fi
	for f in "$HOME/.ssh/id_ed25519.pub" "$HOME/.ssh/id_rsa.pub" "$HOME/.ssh/id_ecdsa.pub"; do
		[ -f "$f" ] && { cat "$f"; return 0; }
	done
	return 1
}

# Ensure a sandbox exists on the host for a slug (build image if missing),
# authorize our key, write the SSH Host alias, and echo the alias to use as the
# retargeted $host for all subsequent remote ops. Args: host, slug, [uid]
cs_sandbox_remote_ensure() {
	local host="$1" slug="$2" uid="${3:-}"
	local pubkey out port alias
	pubkey="$(cs_sandbox_pubkey)" || {
		>&2 echo "err: no local ssh public key to authorize into the sandbox (configure \$CS_SSH_KEY or generate one)"
		return 1
	}

	out="$(cs_ssh_script "$host" "$slug" "$uid" "$pubkey" <<'REMOTE'
set -eu
slug="$1"; uid="$2"; pubkey="$3"
export PATH="$HOME/.local/bin:$PATH"
args=(sandbox ensure "$slug" --pubkey "$pubkey")
[ -n "$uid" ] && args+=(--uid "$uid")
codespace-cloud "${args[@]}"
REMOTE
)" || { >&2 echo "err: [$host] sandbox ensure failed for '$slug'"; return 1; }

	port="$(printf '%s\n' "$out" | sed -n 's/^port=//p')"
	alias="$(printf '%s\n' "$out" | sed -n 's/^alias=//p')"
	[ -n "$port" ] && [ -n "$alias" ] || {
		>&2 echo "err: [$host] sandbox ensure did not return an ssh-target"
		return 1
	}

	cs_sandbox_ssh_config_write "$alias" "$host" "$port"
	echo "$alias"
}


###################################
#                                 #
#  layer 1: codespace runtime     #
#                                 #
###################################

# Self-install codespace scripts on the remote at ~/.local/bin/.
# Idempotent (rsync handles "is it new"). Verifies executability.
# Args: host
cs_remote_self_install() {
	local host="$1"
	local cs_root
	cs_root="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"

	>&2 echo "==> [$host] installing codespace scripts to ~/.local/bin/"
	cs_ssh "$host" 'mkdir -p .local/bin'
	cs_rsync_to_remote "$host" \
		"$cs_root/codespace" \
		"$cs_root/codespace-utils" \
		"$cs_root/codespace-remote" \
		"$cs_root/codespace-worktree" \
		"$cs_root/codespace-stack" \
		"$cs_root/codespace-stack-ls" \
		"$cs_root/codespace-ls" \
		"$cs_root/codespace-find" \
		"$cs_root/codespace-sync" \
		"$cs_root/codespace-sync-commit" \
		"$cs_root/codespace-sync-uncommitted" \
		"$cs_root/codespace-sync-watch" \
		"$cs_root/codespace-sync-notify" \
		'.local/bin/'
	cs_ssh "$host" 'chmod +x .local/bin/codespace .local/bin/codespace-stack .local/bin/codespace-find .local/bin/codespace-worktree'
	if ! cs_ssh "$host" 'test -x .local/bin/codespace'; then
		>&2 echo "err: [$host] codespace not runnable after install"
		return 1
	fi

	# two-target install, half (a): the HOST also gets the codespace-cloud
	# dispatcher + sandbox/ (module + image build inputs) next to the client
	# scripts, so it can run `codespace-cloud sandbox …` over our SSH-to-host
	# and cs_cloud_root's flat-install branch resolves there. (Half (b) — the
	# container gets client scripts — runs during in-sandbox provisioning.)
	cs_remote_self_install_cloud "$host"
}

# Ship the codespace-cloud server infra to the remote host's ~/.local/bin/.
# Skips (with a warning) when the cloud repo isn't resolvable locally. Args: host
cs_remote_self_install_cloud() {
	local host="$1" cloud_root
	cloud_root="$(cs_cloud_root)"
	if [ -z "$cloud_root" ] || [ ! -f "$cloud_root/codespace-cloud" ]; then
		>&2 echo "warn: [$host] codespace-cloud repo not found locally; sandbox features unavailable on this host"
		return 0
	fi
	>&2 echo "==> [$host] installing codespace-cloud (sandbox infra) to ~/.local/bin/"
	cs_rsync_to_remote "$host" "$cloud_root/codespace-cloud" '.local/bin/'
	# preserve the sandbox/ subdir (minus test/) so the flat-install layout +
	# the module's Dockerfile/entrypoint resolve on the host.
	cs_rsync_to_remote "$host" --delete --exclude=test "$cloud_root/sandbox" '.local/bin/'
	cs_ssh "$host" 'chmod +x .local/bin/codespace-cloud .local/bin/sandbox/codespace-sandbox .local/bin/sandbox/entrypoint.sh'
	if ! cs_ssh "$host" 'test -x .local/bin/codespace-cloud'; then
		>&2 echo "err: [$host] codespace-cloud not runnable after install"
		return 1
	fi
}

# Probe remote for codespace's runtime deps. On missing, print platform-specific
# install instructions and return non-zero.
# Args: host
cs_remote_probe() {
	local host="$1"
	local missing
	missing="$(cs_ssh_script "$host" <<'REMOTE'
out=""
for tool in bash git jq rsync; do
	command -v "$tool" >/dev/null 2>&1 || out="$out $tool"
done
echo "${out# }"
REMOTE
)"

	if [ -z "$missing" ]; then
		return 0
	fi

	>&2 echo "err: [$host] missing required tools: $missing"
	local os_id
	os_id="$(cs_ssh_script "$host" <<'REMOTE'
if [ -f /etc/os-release ]; then
	. /etc/os-release; echo "${ID:-unknown}"
else
	uname -s
fi
REMOTE
)"
	local pkgs="${missing// /, }"
	case "$os_id" in
		ubuntu|debian)
			>&2 echo "  install with: ssh $host -- 'sudo apt-get update && sudo apt-get install -y ${missing}'" ;;
		fedora|rhel|centos|rocky|almalinux)
			>&2 echo "  install with: ssh $host -- 'sudo dnf install -y ${missing}'" ;;
		alpine)
			>&2 echo "  install with: ssh $host -- 'sudo apk add ${missing}'" ;;
		Darwin|darwin)
			>&2 echo "  install with: ssh $host -- 'brew install ${missing}'" ;;
		*)
			>&2 echo "  install '${pkgs}' with your package manager (detected: $os_id)" ;;
	esac
	return 1
}

# rsync $CODESPACE_CONFIG_ROOT/<repo-id>/.codespace/ to remote
# ~/codespace-config/<repo-id>/.codespace/. Scripts-only mirror — data files
# (.env, AGENTS.md, etc.) reach the remote per-declaration via the collect+ship
# flow in cs_create_via_remote_{worktree,clone}, not by mirroring the full dir.
#
# Caveat: scripts that read $CS_POST_CREATE_CONFIG_DIR/<arbitrary-file> at
# runtime on the remote will fail unless the file is committed to the repo or
# declared via link-files-from-config (so it gets shipped per-file).
#
# No-op if CODESPACE_CONFIG_ROOT unset or src dir missing.
# Args: host, repo_id
# Stdout: remote relpath of the config dir (e.g. "codespace-config/org/repo")
cs_rsync_config_to_remote() {
	local host="$1" repo_id="$2"
	local remote_rel="$CS_CFG_PREFIX/$repo_id"
	echo "$remote_rel"

	[ -n "${CODESPACE_CONFIG_ROOT:-}" ] || return 0
	local src="$CODESPACE_CONFIG_ROOT/$repo_id/.codespace"
	[ -d "$src" ] || return 0

	>&2 echo "==> [$host] syncing config scripts: $src -> ~/$remote_rel/.codespace"
	cs_ssh_script "$host" "$remote_rel" <<'REMOTE'
mkdir -p "$(cs_rref "$1")/.codespace"
REMOTE
	cs_rsync_to_remote "$host" --delete "$src/" "$remote_rel/.codespace/"
}

# Discover (locally) which files the user's post-create would link, so the
# create flow can ship them to the remote worktree directly.
#
# Runs the resolved local post-create script in a `mktemp -d` sandbox with
# CS_REMOTE_FILE_COLLECT=1 so cs_post_create__link_files_from_{repo,config}
# record `repo:<file>` / `config:<file>` lines instead of symlinking. Anything
# the script writes lands in the sandbox and is wiped on exit. Heavy commands
# (mise install, bun install, …) run with the user's full PATH; if they trip
# `set -e` (e.g. no .git in cwd), collect aborts but the lines captured up to
# that point are kept (template puts link calls before setup).
#
# Resolution: uses the explicitly-passed base_repo (or, when none, falls back
# to cs_abs_path_base_repo from cwd) as the resolver root — NOT the remote
# stub, which doesn't exist yet at create time and wouldn't be a git repo even
# if it did.
#
# Args: [base_repo]   -- absolute path to the local repo to resolve against.
#                       Optional; defaults to cs_abs_path_base_repo (cwd-based).
#                       The stack flow passes per-repo r_base here, since cwd
#                       is the user's invocation dir, not the per-repo base.
# Stdout: absolute path to a manifest file with `<type>:<file>` lines (one per
#         declared file). Caller is responsible for `rm -f` on the manifest.
# Returns 0 on success (manifest path printed). An empty manifest is normal
# when there's no resolvable post-create or no local base repo (e.g. -r --clone
# from outside any git repo) — there's just nothing to discover.
cs_collect_remote_files() {
	local base_repo_arg="${1:-}"
	local manifest collect_dir resolved active_script active_config_dir base_repo

	manifest="$(mktemp -t cs-collect-manifest.XXXXXX)" || return 1

	if [ -n "$base_repo_arg" ]; then
		base_repo="$base_repo_arg"
	else
		base_repo="$(cs_abs_path_base_repo 2>/dev/null)" || base_repo=""
	fi
	if [ -z "$base_repo" ] || ! resolved="$(cs_resolve_post_create "$base_repo" 2>/dev/null)"; then
		# nothing to discover — emit empty manifest, no files to ship.
		echo "$manifest"
		return 0
	fi
	active_script="$(echo "$resolved" | sed -n '1p')"
	active_config_dir="$(echo "$resolved" | sed -n '2p')"

	collect_dir="$(mktemp -d -t cs-collect.XXXXXX)" || { rm -f "$manifest"; return 1; }

	# the script may abort (set -e) — wrap in a subshell so the cleanup below
	# always runs. the manifest lives outside the sandbox so it survives.
	(
		cd "$collect_dir" || exit 1
		CS_REMOTE_FILE_COLLECT=1 \
		CS_REMOTE_FILE_COLLECT_OUT="$manifest" \
		CS_POST_CREATE_CONFIG_DIR="$active_config_dir" \
			"$active_script" "$base_repo"
	) >/dev/null 2>&1 || true

	rm -rf "$collect_dir"
	echo "$manifest"
}

# Ship the files declared by collect to the remote worktree.
# For each `repo:<f>` line, src = $base_repo/<f>; for `config:<f>`, src
# = $CODESPACE_CONFIG_ROOT/<repo-id>/<f>. Both targets are dst_rel/<f> on the
# remote (under $HOME/codespace/...).
#
# Args: host, dst_rel (remote worktree relpath), manifest, repo_id, [base_repo]
#       base_repo: optional. Defaults to cs_abs_path_base_repo (cwd-based).
#                  Stack flow passes per-repo r_base, since cwd is the user's
#                  invocation dir, not the per-repo base.
cs_ship_files_to_remote() {
	local host="$1" dst_rel="$2" manifest="$3" repo_id="$4" base_repo_arg="${5:-}"
	[ -s "$manifest" ] || return 0

	local base_repo cfg_root
	if [ -n "$base_repo_arg" ]; then
		base_repo="$base_repo_arg"
	else
		base_repo="$(cs_abs_path_base_repo 2>/dev/null)" || base_repo=""
	fi
	cfg_root="${CODESPACE_CONFIG_ROOT:+$CODESPACE_CONFIG_ROOT/$repo_id}"

	# Pre-create unique parent dirs on the remote (one ssh call), then per-file
	# rsync. Avoids one ssh per file just for `mkdir -p`.
	local parents=""
	local kind file src
	while IFS=: read -r kind file; do
		[ -n "$kind" ] && [ -n "$file" ] || continue
		case "$file" in */*) parents="$parents $(dirname "$file")"/ ;; esac
	done < "$manifest"
	if [ -n "$parents" ]; then
		# shellcheck disable=SC2086
		cs_ssh_script "$host" "$dst_rel" $parents <<'REMOTE'
set -eu
dst_abs="$(cs_rref "$1")"; shift
for p in "$@"; do
	mkdir -p "$dst_abs/$p"
done
REMOTE
	fi

	while IFS=: read -r kind file; do
		[ -n "$kind" ] && [ -n "$file" ] || continue
		case "$kind" in
			repo)
				[ -n "$base_repo" ] || { >&2 echo "warn: link-files-from-repo declared '$file' but no local base repo; skipping"; continue; }
				src="$base_repo/$file" ;;
			config)
				[ -n "$cfg_root" ] || { >&2 echo "warn: link-files-from-config declared '$file' but \$CODESPACE_CONFIG_ROOT unset; skipping"; continue; }
				src="$cfg_root/$file" ;;
			*)
				>&2 echo "warn: unknown manifest kind '$kind' for '$file'; skipping"; continue ;;
		esac
		if [ ! -e "$src" ]; then
			>&2 echo "warn: declared file not found locally: $src"
			continue
		fi
		>&2 echo "==> [$host] shipping $kind:$file -> ~/$dst_rel/$file"
		cs_rsync_to_remote "$host" "$src" "$dst_rel/$file"
	done < "$manifest"
}


###################################
#                                 #
#  remote cores (worktree/clone)  #
#                                 #
###################################

# Print an actionable hint after a remote `git clone` fails. The usual cause is
# agent forwarding not presenting a key the code host accepts (empty local
# agent, missing key, or no org access). Args: host, clone_url
cs_remote_git_auth_hint() {
	local host="$1" url="$2" target
	target="$(cs_ssh_target_from_url "$url" 2>/dev/null)" || target=""
	>&2 echo "err: [$host] failed to clone $url on the remote."
	>&2 echo "  the remote authenticates to your git host via your FORWARDED ssh-agent,"
	>&2 echo "  which is currently empty or lacks access to this repo."
	>&2 echo "  fix locally, then re-run:"
	>&2 echo "    - load your key:      ssh-add <key>   (macOS keychain: ssh-add --apple-load-keychain)"
	>&2 echo "    - verify it's loaded: ssh-add -l"
	if [ -n "$target" ]; then
		>&2 echo "    - verify remote auth: ssh $host -- ssh -T $target"
	fi
	>&2 echo "    - ensure that key has access to the repo/org (SSO authorized)"
	>&2 echo "  tip: let codespace auto-load key(s) via \$CS_SSH_KEY=<path>[,<path>...]"
	>&2 echo "       or a per-repo/org 'ssh-key' file (see remote-codespaces.md)."
}

# Ensure a remote base repo exists on the remote (clone from clone_url if not).
# Args: host, repo_id, clone_url
# Stdout: remote relpath of base repo (e.g. "codespace/org/repo")
# Returns non-zero (with an auth hint) if the remote clone fails.
cs_remote_ensure_base_repo() {
	local host="$1" repo_id="$2" clone_url="$3"
	local base_rel="$CS_WT_PREFIX/$repo_id"
	echo "$base_rel"

	if ! cs_ssh_script "$host" "$base_rel" "$clone_url" "$host" <<'REMOTE'
set -eu
base_rel="$1"; clone_url="$2"; host="$3"
base_abs="$(cs_rref "$base_rel")"
mkdir -p "$(dirname "$base_abs")"
if [ ! -d "$base_abs/.git" ]; then
	>&2 echo "==> [$host] cloning $clone_url -> $base_abs"
	git clone "$clone_url" "$base_abs"
fi
REMOTE
	then
		cs_remote_git_auth_hint "$host" "$clone_url"
		return 1
	fi
}

# Create a worktree on the remote, mirroring cs_create_worktree_core.
# Args: host, repo_id, branch, remote_dest_rel, [base_branch], [clone_url]
cs_create_remote_worktree_core() {
	local host="$1" repo_id="$2" branch="$3" dest_rel="$4"
	local base_branch="${5:-}" clone_url="${6:-}"

	if [ -z "$clone_url" ]; then
		local local_base="$HOME/$repo_id"
		if [ -d "$local_base/.git" ]; then
			clone_url="$(git -C "$local_base" remote get-url origin 2>/dev/null)" || true
		fi
	fi
	test -n "$clone_url" || {
		>&2 echo "err: cannot infer clone URL for repo '$repo_id' (provide via stacks.json or use --clone <url>)"
		return 1
	}

	cs_remote_ensure_base_repo "$host" "$repo_id" "$clone_url" >/dev/null || return 1

	cs_ssh_script "$host" "$CS_WT_PREFIX/$repo_id" "$dest_rel" "$branch" "$base_branch" <<'REMOTE'
set -eu
base_rel="$1"; dest_rel="$2"; branch="$3"; base_branch_arg="$4"
base_abs="$(cs_rref "$base_rel")"; dest_abs="$(cs_rref "$dest_rel")"

cd "$base_abs"
if [ -z "$base_branch_arg" ]; then
	base_ref="$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|^refs/remotes/origin/||')"
	[ -n "$base_ref" ] || base_ref="master"
else
	base_ref="$base_branch_arg"
fi
git fetch origin "$base_ref" 2>/dev/null || true

if ! git show-ref --verify --quiet "refs/heads/$branch"; then
	if git ls-remote --exit-code --heads origin "$branch" >/dev/null 2>&1; then
		git fetch origin "$branch"
		git branch --track "$branch" "origin/$branch"
	else
		git branch --no-track "$branch" "origin/$base_ref"
	fi
fi
git worktree prune
git worktree add "$dest_abs" "$branch"
REMOTE
}

# Does the remote hold a *valid* git checkout at dest yet? A bare `.git`
# existence test isn't enough: a half-provisioned remote (e.g. a worktree whose
# base repo was lost) leaves a dangling `.git` behind, and treating that as
# "provisioned" skips the repair/reprovision path and breaks the later align.
# Args: host, dest_rel
cs_sync_remote_exists() {
	local host="$1" dest_rel="$2"
	cs_ssh_script "$host" "$dest_rel" <<'REMOTE'
set -eu
dest_rel="$1"
git -C "$(cs_rref "$dest_rel")" rev-parse --is-inside-work-tree >/dev/null 2>&1
REMOTE
}

# Classify the remote codespace's health in one ssh round-trip. Ships the pure
# cs_checkout_health rules to the remote verbatim (declare -f) so the local and
# remote classifications can never drift. Echoes ok|absent|broken (see
# cs_checkout_health). `broken` means a leftover from an interrupted run that the
# caller repairs-or-archives then reprovisions.
# Args: host, dest_rel, base_rel, kind
cs_sync_remote_health() {
	local host="$1" dest_rel="$2" base_rel="$3" kind="$4"
	cs_ssh_script "$host" "$dest_rel" "$base_rel" "$kind" <<REMOTE
set -eu
$(declare -f cs_checkout_health)
cs_checkout_health "\$(cs_rref "\$1")" "\$(cs_rref "\$2")" "\$3"
REMOTE
}

# Query branch status for multiple repos in one ssh round-trip.
# Args: host, repo_name|dest_rel|branch|base_branch, [...]
# Stdout: repo_name;status;base;ahead, one line per repo
cs_stack_remote_branch_status_batch() {
	local host="$1"; shift
	cs_ssh_script "$host" "$@" <<REMOTE
set -u
$(declare -f cs_branch_status)
for spec in "\$@"; do
	IFS='|' read -r name dest_rel branch base_branch <<< "\$spec"
	repo="\$(cs_rref "\$dest_rel")"
	if git -C "\$repo" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
		info="\$(cs_branch_status "\$repo" "\$branch" "\$base_branch" 2>/dev/null)" || info="?;?;0"
	else
		info="?;?;0"
	fi
	printf '%s;%s\n' "\$name" "\$info"
done
REMOTE
}

# Repair a half-provisioned remote codespace (dest present but not a valid,
# base-backed checkout) without ever losing work. Two tiers:
#   1. base repo is still valid -> only the worktree link is stale: re-link it
#      in place with `git worktree repair` (no files moved; uncommitted and
#      untracked work is preserved exactly as-is). Echoes `repaired`.
#   2. base repo is gone (its per-worktree git-state is unrecoverable) or this
#      is a clone -> archive the whole dir aside with `mv` (never rm) to
#      "<dest>.broken-<utc>" so tracked + modified + untracked files survive,
#      and let the caller reprovision a fresh checkout. Echoes `archived`.
# Returns non-zero only on an unexpected failure (e.g. the mv itself failed).
# Args: host, dest_rel, base_rel, kind
cs_sync_remote_repair() {
	local host="$1" dest_rel="$2" base_rel="$3" kind="$4"
	cs_ssh_script "$host" "$dest_rel" "$base_rel" "$kind" <<'REMOTE'
set -eu
dest_rel="$1"; base_rel="$2"; kind="$3"
dest="$(cs_rref "$dest_rel")"; base="$(cs_rref "$base_rel")"

# tier 1: base repo intact -> re-link the worktree in place, no files touched.
if [ "$kind" != clone ] && git -C "$base" rev-parse --git-dir >/dev/null 2>&1; then
	git -C "$base" worktree repair "$dest" >/dev/null 2>&1 || true
	git -C "$dest" worktree repair >/dev/null 2>&1 || true
	if git -C "$dest" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
		>&2 echo "==> repaired worktree link at ~/$dest_rel (no files moved)"
		echo repaired
		exit 0
	fi
fi

# tier 2: base unrecoverable (or a clone) -> archive aside, never delete.
ts="$(date -u +%Y%m%dT%H%M%SZ)"
mv "$dest" "$dest.broken-$ts"
>&2 echo "==> archived broken remote codespace: ~/$dest_rel -> ~/$dest_rel.broken-$ts"
>&2 echo "    recover any uncommitted/untracked work from there (it is not auto-deleted)."
echo archived
REMOTE
}

# Create a fresh clone on the remote, mirroring cs_create_clone_core.
# Args: host, clone_url, remote_dest_rel, branch
# Returns non-zero (with an auth hint) if the remote clone fails.
cs_create_remote_clone_core() {
	local host="$1" clone_url="$2" dest_rel="$3" branch="$4"
	if ! cs_ssh_script "$host" "$clone_url" "$dest_rel" "$branch" <<'REMOTE'
set -eu
clone_url="$1"; dest_rel="$2"; branch="$3"
dest_abs="$(cs_rref "$dest_rel")"
mkdir -p "$(dirname "$dest_abs")"
git clone "$clone_url" "$dest_abs"
cd "$dest_abs"
if ! git show-ref --verify --quiet "refs/heads/$branch"; then
	if git ls-remote --exit-code --heads origin "$branch" >/dev/null 2>&1; then
		git fetch origin "$branch"
		git branch --track "$branch" "origin/$branch"
	fi
fi
git checkout "$branch" 2>/dev/null || git checkout -b "$branch"
REMOTE
	then
		cs_remote_git_auth_hint "$host" "$clone_url"
		return 1
	fi
}


###################################
#                                 #
#  layer 2 / 3: hooks on remote   #
#                                 #
###################################

# Run remote-bootstrap.sh on the remote (ALWAYS runs; idempotency is the
# script's job — no caching markers on our side).
# Resolution on remote: user-level rsynced config wins over repo-committed
# script in the worktree. Absent → no-op with a note.
# Args: host, repo_id, dest_rel, base_rel, branch, [config_rel]
cs_remote_run_bootstrap() {
	local host="$1" repo_id="$2" dest_rel="$3" base_rel="$4" branch="$5"
	local config_rel="${6:-$CS_CFG_PREFIX/$repo_id}"

	cs_ssh_script "$host" \
		"$host" "$repo_id" "$branch" "$dest_rel" "$base_rel" "$config_rel" \
		<<'REMOTE'
set -eu
host="$1"; repo_id="$2"; branch="$3"; dest_rel="$4"; base_rel="$5"; cfg_rel="$6"
dest_abs="$(cs_rref "$dest_rel")"; base_abs="$(cs_rref "$base_rel")"; cfg_abs="$(cs_rref "$cfg_rel")"

# config dir (user-level) may hold the hook at .codespace/ or its root (mirror
# cs_find_in_config_dir); the repo worktree only at .codespace/ to avoid
# picking up an unrelated root-level file.
find_user_hook() {
	if [ -f "$1/.codespace/remote-bootstrap.sh" ]; then echo "$1/.codespace/remote-bootstrap.sh"
	elif [ -f "$1/remote-bootstrap.sh" ]; then echo "$1/remote-bootstrap.sh"; fi
}
user_script="$(find_user_hook "$cfg_abs")"
repo_script=""
[ -f "$dest_abs/.codespace/remote-bootstrap.sh" ] && repo_script="$dest_abs/.codespace/remote-bootstrap.sh"

if [ -n "$user_script" ]; then
	script="$user_script"
	>&2 echo "note: using remote-bootstrap.sh from: $script"
	[ -n "$repo_script" ] && >&2 echo "note: ignoring repo-committed remote-bootstrap.sh at: $repo_script"
elif [ -n "$repo_script" ]; then
	script="$repo_script"
	>&2 echo "note: using remote-bootstrap.sh from: $script"
else
	>&2 echo "note: no remote-bootstrap.sh found, skipping host-level setup"
	exit 0
fi

# non-interactive ssh sessions don't source .bashrc, so ~/.local/bin
# (where cs_remote_self_install put 'codespace') isn't on PATH. Prepend it
# so user scripts can invoke 'codespace' without a full path.
export PATH="$HOME/.local/bin:$PATH"
export CS_HOST="$host"
export CS_REPO_ID="$repo_id"
export CS_BRANCH="$branch"
export CS_REMOTE_PATH="$dest_abs"
export CS_REMOTE_BASE_REPO="$base_abs"
export CS_POST_CREATE_CONFIG_DIR="$cfg_abs"
bash "$script"
REMOTE
}

# Run codespace post-create on the remote.
# Args: host, repo_id, dest_rel, [config_rel]
cs_remote_run_post_create() {
	local host="$1" repo_id="$2" dest_rel="$3"
	local config_rel="${4:-$CS_CFG_PREFIX/$repo_id}"

	cs_ssh_script "$host" "$dest_rel" "$config_rel" <<'REMOTE'
set -eu
dest_rel="$1"; cfg_rel="$2"
dest_abs="$(cs_rref "$dest_rel")"; cfg_abs="$(cs_rref "$cfg_rel")"
# non-interactive ssh sessions don't source .bashrc, so ~/.local/bin (where
# cs_remote_self_install put 'codespace') isn't on PATH. Prepend it so the
# post-create script can invoke 'codespace post-create.link-files-from-*'
# without a full path.
export PATH="$HOME/.local/bin:$PATH"
export CS_POST_CREATE_CONFIG_DIR="$cfg_abs"
# Tell on-remote link-files-from-{repo,config} helpers to skip linking and
# instead verify the file is present in the worktree (the create flow shipped
# it). See cs_post_create__link_files_from_{repo,config} in 'codespace'.
export CS_REMOTE_CODESPACE=1
codespace post-create "$dest_abs"
REMOTE
}


###################################
#                                 #
#  shared init primitive          #
#                                 #
###################################

# Create the remote checkout (worktree or clone). Split out of cs_remote_init_repo
# so the "absent" and "archived-then-recreate" paths share one create decision.
# Args: host, repo_id, branch, dest_rel, kind, [clone_url], [base_branch]
cs_remote_init_create() {
	local host="$1" repo_id="$2" branch="$3" dest_rel="$4" kind="$5"
	local clone_url="${6:-}" base_branch="${7:-}"
	if [ "$kind" = clone ]; then
		if [ -z "$clone_url" ]; then
			>&2 echo "err: cannot provision clone codespace '$repo_id': no clone URL"
			return 1
		fi
		cs_create_remote_clone_core "$host" "$clone_url" "$dest_rel" "$branch"
	else
		cs_create_remote_worktree_core "$host" "$repo_id" "$branch" "$dest_rel" "$base_branch" "$clone_url"
	fi
}

# The one remote-provision primitive, shared by sync and stack init. Ensures the
# remote checkout exists (create if absent, repair-or-recreate if broken), then
# ALWAYS ships linked files -> runs remote-bootstrap -> runs post-create (the
# dep-install step; the hook scripts own their own idempotency). It never
# transfers local commits/dirty work (that's sync's job) and never writes local
# markers (that's the caller's concern). Inherently idempotent: re-running skips
# the create when the remote is already healthy and just re-runs setup.
# Args: host, repo_id, branch, dest_rel, kind, base_rel, base_repo,
#       cfg_rel, [clone_url], [base_branch], [health]
#   base_repo: local base repo path, resolver root for cs_collect_remote_files.
#   health:    ok|absent|broken. When empty, the primitive classifies it itself
#              (one ssh); callers that already know pass it to skip the round-trip.
cs_remote_init_repo() {
	local host="$1" repo_id="$2" branch="$3" dest_rel="$4" kind="$5"
	local base_rel="$6" base_repo="$7" cfg_rel="$8"
	local clone_url="${9:-}" base_branch="${10:-}" health="${11:-}"

	[ -n "$health" ] || health="$(cs_sync_remote_health "$host" "$dest_rel" "$base_rel" "$kind")" || health=broken

	case "$health" in
	ok) : ;;
	absent)
		cs_remote_init_create "$host" "$repo_id" "$branch" "$dest_rel" "$kind" "$clone_url" "$base_branch" || return 1
		;;
	broken)
		>&2 echo "==> [$host] remote codespace at ~/$dest_rel is broken; repairing"
		local rstate
		rstate="$(cs_sync_remote_repair "$host" "$dest_rel" "$base_rel" "$kind")" || return 1
		if [ "$rstate" = archived ]; then
			cs_remote_init_create "$host" "$repo_id" "$branch" "$dest_rel" "$kind" "$clone_url" "$base_branch" || return 1
		fi
		;;
	esac

	local manifest
	manifest="$(cs_collect_remote_files "$base_repo")"
	cs_ship_files_to_remote "$host" "$dest_rel" "$manifest" "$repo_id" "$base_repo"
	rm -f "$manifest"

	cs_remote_run_bootstrap "$host" "$repo_id" "$dest_rel" "$base_rel" "$branch" "$cfg_rel" || return 1
	cs_remote_run_post_create "$host" "$repo_id" "$dest_rel" "$cfg_rel" || return 1
}


###################################
#                                 #
#  worktree-create flows          #
#                                 #
###################################

# Create a remote worktree codespace.
# Args: host, branch, [base_branch]
cs_create_via_remote_worktree() {
	local host="$1" branch="$2" base_branch="${3:-}"
	local repo_id stub_path dest_rel base_rel cfg_rel

	repo_id="$(cs_repo_id)" || {
		>&2 echo "err: could not determine repo-id (run from inside the base repo, or with CODESPACE_CONFIG_ROOT set)"
		exit 1
	}
	stub_path="$(cs_abs_path_from_repo_name_and_branch "$branch")"
	dest_rel="$(cs_remote_relpath_for_local "$stub_path")"
	base_rel="$CS_WT_PREFIX/$repo_id"

	if [ -d "$stub_path" ] && [ "$(ls -A "$stub_path" 2>/dev/null)" ]; then
		>&2 echo "err: local stub/worktree path is non-empty: $stub_path"
		exit 1
	fi

	cs_ensure_agent_key "$repo_id"
	cs_remote_self_install "$host"
	cs_remote_probe "$host"
	cfg_rel="$(cs_rsync_config_to_remote "$host" "$repo_id" | head -n1)"

	cs_create_remote_worktree_core "$host" "$repo_id" "$branch" "$dest_rel" "$base_branch"

	local manifest
	manifest="$(cs_collect_remote_files)"
	cs_ship_files_to_remote "$host" "$dest_rel" "$manifest" "$repo_id"
	rm -f "$manifest"

	cs_remote_run_bootstrap "$host" "$repo_id" "$dest_rel" "$base_rel" "$branch" "$cfg_rel"
	cs_remote_run_post_create "$host" "$repo_id" "$dest_rel" "$cfg_rel"

	cs_remote_marker_write "$stub_path" \
		"host=$host" \
		"relpath=$dest_rel" \
		"kind=worktree" \
		"repo_id=$repo_id" \
		"branch=$branch"
	cs_write_open_script "$stub_path"

	cs_open_editor_remote "$host" "$dest_rel" "$stub_path"
	echo "$stub_path"
}

# Create a remote clone codespace.
# Args: host, branch, [clone_url]
cs_create_via_remote_clone() {
	local host="$1" branch="$2" clone_url="${3:-}"
	local repo_id stub_path dest_rel cfg_rel

	if [ -z "$clone_url" ]; then
		clone_url="$(git remote get-url origin 2>/dev/null)" || true
	fi
	test -n "$clone_url" || {
		>&2 echo "err: no clone URL provided, and cannot infer (not inside a git repository)"
		exit 1
	}

	# repo-id derives from the clone URL's repo name + branch (sibling-dir layout)
	local repo_name
	repo_name="$(cs_repo_name_from_url "$clone_url")"

	# put local stub somewhere predictable: $HOME/<org>/<repo>_<branch> if inside a repo;
	# else cwd-based. Mirror the existing cs_create_via_clone heuristic.
	local base_dir
	if git rev-parse --git-dir >/dev/null 2>&1; then
		base_dir="$(dirname "$(cs_abs_path_base_repo)")"
	else
		base_dir="$(pwd)"
	fi
	stub_path="$(cs_abspath "$base_dir/$(cs_cleanpath "${repo_name}/${branch}")")"

	dest_rel="$(cs_remote_relpath_for_local "$stub_path")"
	repo_id="$(realpath --relative-to="$HOME" "$base_dir/$repo_name")"

	if [ -d "$stub_path" ] && [ "$(ls -A "$stub_path" 2>/dev/null)" ]; then
		>&2 echo "err: local stub path is non-empty: $stub_path"
		exit 1
	fi

	cs_ensure_agent_key "$repo_id"
	cs_remote_self_install "$host"
	cs_remote_probe "$host"
	cfg_rel="$(cs_rsync_config_to_remote "$host" "$repo_id" | head -n1)"

	cs_create_remote_clone_core "$host" "$clone_url" "$dest_rel" "$branch"

	local manifest
	manifest="$(cs_collect_remote_files)"
	cs_ship_files_to_remote "$host" "$dest_rel" "$manifest" "$repo_id"
	rm -f "$manifest"

	cs_remote_run_bootstrap "$host" "$repo_id" "$dest_rel" "$dest_rel" "$branch" "$cfg_rel"
	cs_remote_run_post_create "$host" "$repo_id" "$dest_rel" "$cfg_rel"

	cs_remote_marker_write "$stub_path" \
		"host=$host" \
		"relpath=$dest_rel" \
		"kind=clone" \
		"repo_id=$repo_id" \
		"branch=$branch"
	cs_write_open_script "$stub_path"

	cs_open_editor_remote "$host" "$dest_rel" "$stub_path"
	echo "$stub_path"
}

# Open editor against a remote codespace via SSH-Remote, or print SSH instructions.
# Args: host, dest_rel, [stub_path] (stub_path arg kept for back-compat, unused)
cs_open_editor_remote() {
	local host="$1" dest_rel="$2"
	if [ -n "${CS_NO_EDIT:-}" ]; then
		return 0
	fi
	local editor="${GUI_EDITOR:-${EDITOR:-}}"
	case "$(basename "$editor")" in
		cursor|code|codium)
			local remote_abs
			remote_abs="$(cs_remote_abs "$host" "$dest_rel")" || {
				>&2 echo "warn: could not resolve remote path on $host; skipping editor open"
				>&2 echo "  open manually with: $editor --new-window --remote ssh-remote+$host <remote-path>"
				return 0
			}
			"$editor" --new-window --remote "ssh-remote+$host" "$remote_abs"
			;;
		*)
			>&2 echo "remote codespace at: $host:~/$dest_rel"
			>&2 echo "  ssh $host -t \"cd ~/$dest_rel && \\\$SHELL\""
			;;
	esac
}


###################################
#                                 #
#  remove flow                    #
#                                 #
###################################

# Remove a remote codespace: cleanup remote (worktree prune / rm -rf), then stub.
# Args: cs_path, [force]
cs_remove_remote() {
	local cs_path="$1" force="${2:-}"
	local host kind repo_id branch dest_rel
	host="$(cs_remote_marker_get "$cs_path" host)"
	kind="$(cs_remote_marker_get "$cs_path" kind)"
	repo_id="$(cs_remote_marker_get "$cs_path" repo_id)"
	branch="$(cs_remote_marker_get "$cs_path" branch)"
	dest_rel="$(cs_remote_marker_get "$cs_path" relpath)"

	# back-compat: older markers stored 'path=$HOME/<relpath>'; strip the prefix.
	if [ -z "$dest_rel" ]; then
		local dest_path
		dest_path="$(cs_remote_marker_get "$cs_path" path)"
		dest_rel="${dest_path#\$HOME/}"
	fi

	test -n "$host" || { >&2 echo "err: stub missing 'host' in $cs_path/.codespace-remote"; exit 1; }
	test -n "$dest_rel" || { >&2 echo "err: stub missing 'relpath' in $cs_path/.codespace-remote"; exit 1; }

	# Safety check (best effort over ssh): uncommitted/untracked/unpushed.
	if [ -z "$force" ]; then
		cs_ssh_script "$host" "$dest_rel" "$cs_path" <<'REMOTE' || exit $?
set -eu
dest_rel="$1"; cs_path="$2"
dest_abs="$(cs_rref "$dest_rel")"
[ -d "$dest_abs/.git" ] || [ -f "$dest_abs/.git" ] || {
	>&2 echo "warn: remote codespace not found at $dest_abs (proceeding with stub cleanup)"
	exit 0
}
cd "$dest_abs"
if ! git diff --quiet HEAD 2>/dev/null; then
	>&2 echo "err: uncommitted changes at $dest_abs"
	>&2 echo "  commit/stash or pass -f to force"
	exit 1
fi
if [ -n "$(git ls-files --others --exclude-standard)" ]; then
	>&2 echo "err: untracked files at $dest_abs"
	>&2 echo "  remove/commit or pass -f to force"
	exit 1
fi
br="$(git branch --show-current 2>/dev/null)"
if [ -n "$br" ]; then
	up="$(git rev-parse --abbrev-ref "@{upstream}" 2>/dev/null)" || up=""
	if [ -n "$up" ]; then
		if [ -n "$(git log "$up..HEAD" --oneline 2>/dev/null)" ]; then
			>&2 echo "err: unpushed commits on $br at $dest_abs"
			exit 1
		fi
	else
		git ls-remote --exit-code --heads origin "$br" >/dev/null 2>&1 || {
			>&2 echo "err: branch '$br' not on origin and has no upstream"
			exit 1
		}
	fi
fi
REMOTE
	fi

	# Cleanup remote.
	if [ "$kind" = "worktree" ]; then
		local base_rel="$CS_WT_PREFIX/$repo_id"
		cs_ssh_script "$host" "$base_rel" "$dest_rel" "$force" <<'REMOTE'
set -eu
base_rel="$1"; dest_rel="$2"; force="$3"
base_abs="$(cs_rref "$base_rel")"; dest_abs="$(cs_rref "$dest_rel")"
if [ -d "$base_abs/.git" ]; then
	if [ -n "$force" ]; then
		git -C "$base_abs" worktree remove --force "$dest_abs" 2>/dev/null || rm -rf "$dest_abs"
	else
		git -C "$base_abs" worktree remove "$dest_abs"
	fi
else
	rm -rf "$dest_abs"
fi
REMOTE
	else
		# clone (or unknown kind) — just rm
		cs_ssh_script "$host" "$dest_rel" <<'REMOTE'
set -eu
dest_rel="$1"
rm -rf "$(cs_rref "$dest_rel")"
REMOTE
	fi

	rm -rf "$cs_path"
	>&2 echo "removed remote codespace: $host:~/$dest_rel (stub: $cs_path)"
	# silence shellcheck unused-var warnings (kept for future use / debug)
	: "$branch"
}
