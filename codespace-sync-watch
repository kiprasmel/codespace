#!/usr/bin/env bash

# codespace-sync-watch: persistent live uncommitted sync for `codespace sync`,
# powered by mutagen as an OPTIONAL, lazily-prompted dependency.
#
# Sourced by codespace-sync (only if present); assumes codespace-utils
# (+ codespace-remote) and the codespace-sync marker/commit helpers are loaded.
#
# Scope: this layer ONLY concerns the *uncommitted* working tree. Committed
# history always travels via codespace-sync-commit (pure git+ssh) and never
# needs mutagen -- so `codespace sync` syncs commits whether or not mutagen is
# installed. mutagen is engaged solely for the live "google-doc-for-files" form
# of [s]ync-uncommitted, and only after the user opts in.
#
# Model:
#   - a named mutagen session (two-way-safe) mirrors the working tree both ways,
#     ignoring VCS + gitignored heavy paths; its daemon keeps it alive across
#     terminal closes.
#   - commits never ride the working-tree mirror (a commit doesn't change file
#     contents on disk), so the watch carries them itself: a cheap HEAD poll
#     loop runs a commit-only integrate whenever HEAD moves (no post-commit
#     hooks). The loop runs in the foreground watch and, for --detach, as a
#     PID-tracked background process killed by --stop.
#   - simultaneous edits to the same file are flagged (not auto-merged); we
#     surface them and offer to escalate into git's conflict resolution.
#   - a commit during a live session is reconciled through the commit machinery
#     with the working tree frozen (pause) + the remainder stashed, so a partial
#     commit loses nothing.

if [ -n "${_CS_SYNC_WATCH_LOADED:-}" ]; then
	return 0 2>/dev/null || true
fi
_CS_SYNC_WATCH_LOADED=1


###################################
#                                 #
#  optional dependency (mutagen)  #
#                                 #
###################################

# True iff the mutagen CLI resolves on the remote. A non-interactive ssh shell
# skips .bashrc/.profile, so ~/.local/bin (where cs_sync_mutagen_install_remote
# drops the binary) isn't on PATH by default -- prepend it, mirroring the
# bootstrap/post-create scripts, so a freshly-installed mutagen is detectable.
# Args: host
cs_sync_remote_has_mutagen() {
	cs_ssh_script "$1" <<'REMOTE'
PATH="$HOME/.local/bin:$PATH"
command -v mutagen >/dev/null 2>&1
REMOTE
}

# True iff the mutagen CLI is usable locally. Honors CS_NO_MUTAGEN, a knob to
# force the whole live-sync layer off (keeps tests of the no-mutagen paths
# deterministic on machines that happen to have it installed; also lets a user
# opt out of live sync entirely).
cs_sync_mutagen_present() {
	[ -z "${CS_NO_MUTAGEN:-}" ] && command -v mutagen >/dev/null 2>&1
}

# Quiet probe: 0 iff mutagen is present on BOTH ends (local + host). Cheap-first:
# if it's missing locally we never pay the ssh round-trip. Used by the decision
# flow to know whether the live form is viable without prompting.
# Args: host
cs_sync_mutagen_available() {
	cs_sync_mutagen_present || return 1
	cs_sync_remote_has_mutagen "$1"
}

# Lazy dependency resolver. Probe local + each target host; if all have mutagen,
# return 0 silently. Otherwise report which sides lack it and (when interactive)
# ask first whether to sync uncommitted changes at all, then whether to install
# mutagen on every missing side; on accept install + re-probe.
# Returns: 0 ready (live); 1 use the dependency-free one-shot overlay (declined
# install / still-missing); 2 skip uncommitted entirely (commit-only sync).
# Args: host...
cs_sync_ensure_mutagen() {
	local hosts=("$@") missing=() h
	cs_sync_mutagen_present || missing+=("local")
	for h in "${hosts[@]}"; do
		cs_sync_remote_has_mutagen "$h" || missing+=("$h")
	done

	[ ${#missing[@]} -eq 0 ] && return 0

	>&2 echo "note: live-syncing uncommitted changes needs mutagen; missing on: ${missing[*]}"
	if [ -n "${CS_NO_INTERACTIVE:-}" ]; then
		>&2 echo "  install it (https://mutagen.io/documentation/introduction/installation) or use --once for a one-shot overlay."
		return 1
	fi

	# First gate: sync uncommitted changes at all? (kept separate from the
	# install choice so a "yes, but no install" still falls back to the overlay.)
	local ans=""
	>&2 printf '  sync uncommitted changes? [y/N] '
	read -r ans </dev/tty 2>/dev/null || ans=""
	case "$ans" in
		y|Y|yes|Yes) ;;
		*) >&2 echo "  ok, syncing committed history only."; return 2 ;;
	esac

	# Second gate: install mutagen now (live), or decline -> one-shot overlay.
	# Defaults to yes -- the user just opted into syncing uncommitted changes and
	# the live form needs mutagen, so installing is the expected next step.
	ans=""
	>&2 printf '  install mutagen on %s now? [Y/n] ' "${missing[*]}"
	read -r ans </dev/tty 2>/dev/null || ans=""
	case "$ans" in
		n|N|no|No) >&2 echo "  declined; falling back to a one-shot overlay."; return 1 ;;
		*) ;;
	esac

	local m
	for m in "${missing[@]}"; do
		if [ "$m" = "local" ]; then
			cs_sync_mutagen_install_local || >&2 echo "warn: local mutagen install failed"
		else
			cs_sync_mutagen_install_remote "$m" || >&2 echo "warn: [$m] mutagen install failed"
		fi
	done

	# re-probe; success only if every side now has it.
	cs_sync_mutagen_present || { >&2 echo "err: mutagen still missing locally; using overlay."; return 1; }
	for h in "${hosts[@]}"; do
		cs_sync_remote_has_mutagen "$h" || { >&2 echo "err: [$h] mutagen still missing; using overlay."; return 1; }
	done
	return 0
}

# Install mutagen locally (best-effort; brew on macOS, static release on Linux).
cs_sync_mutagen_install_local() {
	>&2 echo "==> installing mutagen locally"
	if [ "$(uname -s)" = "Darwin" ] && command -v brew >/dev/null 2>&1; then
		# Homebrew 5.1.15+ refuses untrusted third-party taps; trust mutagen's
		# tap first (no-op/ignored on older brew), then install.
		brew trust mutagen-io/mutagen >/dev/null 2>&1 || true
		brew install mutagen-io/mutagen/mutagen && return 0
		>&2 echo "warn: brew install failed; falling back to the static binary"
	fi
	cs_sync_mutagen_install_static "$(uname -s)" "$(uname -m)"
}

# Install mutagen on a remote host (best-effort; brew on macOS, static on Linux).
# Args: host
cs_sync_mutagen_install_remote() {
	local host="$1"
	>&2 echo "==> [$host] installing mutagen"
	cs_ssh_script "$host" <<'REMOTE'
set -eu
if [ "$(uname -s)" = "Darwin" ] && command -v brew >/dev/null 2>&1; then
	# Homebrew 5.1.15+ refuses untrusted third-party taps; trust then install,
	# falling through to the static binary if brew fails.
	brew trust mutagen-io/mutagen >/dev/null 2>&1 || true
	brew install mutagen-io/mutagen/mutagen && exit 0
	echo "warn: brew install failed; falling back to the static binary" >&2
fi
os="$(uname -s | tr '[:upper:]' '[:lower:]')"
arch="$(uname -m)"
case "$arch" in
	x86_64|amd64) arch=amd64 ;;
	aarch64|arm64) arch=arm64 ;;
esac
ver="$(curl -fsSL https://api.github.com/repos/mutagen-io/mutagen/releases/latest | sed -n 's/.*"tag_name": *"\([^"]*\)".*/\1/p' | head -n1)"
[ -n "$ver" ] || { echo "could not resolve latest mutagen version" >&2; exit 1; }
mkdir -p "$HOME/.local/bin"
url="https://github.com/mutagen-io/mutagen/releases/download/${ver}/mutagen_${os}_${arch}_${ver}.tar.gz"
# the release tarball ships the CLI *and* mutagen-agents.tar.gz; mutagen needs
# the bundle alongside the binary to deploy per-platform remote agents.
curl -fsSL "$url" | tar -xz -C "$HOME/.local/bin" mutagen mutagen-agents.tar.gz
chmod +x "$HOME/.local/bin/mutagen"
REMOTE
}

# Fallback static install for the local side. Args: os_uname arch_uname
cs_sync_mutagen_install_static() {
	local os arch ver url
	os="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"
	case "$2" in
		x86_64|amd64) arch=amd64 ;;
		aarch64|arm64) arch=arm64 ;;
		*) arch="$2" ;;
	esac
	ver="$(curl -fsSL https://api.github.com/repos/mutagen-io/mutagen/releases/latest \
		| sed -n 's/.*"tag_name": *"\([^"]*\)".*/\1/p' | head -n1)"
	[ -n "$ver" ] || { >&2 echo "err: could not resolve latest mutagen version"; return 1; }
	mkdir -p "$HOME/.local/bin"
	url="https://github.com/mutagen-io/mutagen/releases/download/${ver}/mutagen_${os}_${arch}_${ver}.tar.gz"
	# extract the CLI *and* mutagen-agents.tar.gz (mutagen needs the bundle next
	# to the binary to deploy remote agents over ssh).
	curl -fsSL "$url" | tar -xz -C "$HOME/.local/bin" mutagen mutagen-agents.tar.gz
	chmod +x "$HOME/.local/bin/mutagen"
}


###################################
#                                 #
#  session lifecycle              #
#                                 #
###################################

# Stable, mutagen-legal session name for a codespace (a-z0-9- only).
# Args: repo_id, branch
cs_sync_watch_session_name() {
	local repo_id="$1" branch="$2" slug
	slug="$(printf 'codespace-%s-%s' "$repo_id" "$branch" \
		| tr '[:upper:]' '[:lower:]' | tr -c 'a-z0-9-' '-' | sed 's/-\{2,\}/-/g; s/^-//; s/-$//')"
	echo "$slug"
}

# Emit `--ignore=<pat>` tokens (space-separated, unquoted-expanded by the
# caller) from the repo's effective gitignore patterns + the codespace control
# files. `--ignore-vcs` (passed by the caller) already covers .git, so we add
# the user's ignore patterns mutagen wouldn't otherwise know about.
# Args: repo_dir
cs_sync_mutagen_ignores() {
	local repo_dir="$1" f pat
	printf -- '--ignore=open --ignore=/.codespace/ '
	local files=()
	[ -f "$repo_dir/.gitignore" ] && files+=("$repo_dir/.gitignore")
	f="$(git -C "$repo_dir" rev-parse --git-path info/exclude 2>/dev/null)" || f=""
	[ -n "$f" ] && [ -f "$f" ] && files+=("$f")
	f="$(git -C "$repo_dir" config --get core.excludesFile 2>/dev/null)" || f=""
	[ -n "$f" ] && [ -f "$f" ] && files+=("$f")
	[ ${#files[@]} -gt 0 ] || return 0
	# strip comments/blank lines; pass patterns straight through to mutagen.
	sed -e 's/#.*$//' -e 's/[[:space:]]*$//' "${files[@]}" 2>/dev/null \
		| while IFS= read -r pat; do
			[ -n "$pat" ] || continue
			printf -- '--ignore=%s ' "$pat"
		done
}

# Is a live (mutagen) session running for this codespace? (requires mutagen
# present) Used to pause/resume the daemon around git history ops + to badge the
# marker. Args: repo_id, branch
cs_sync_watch_active() {
	cs_sync_mutagen_present || return 1
	local name; name="$(cs_sync_watch_session_name "$1" "$2")"
	mutagen sync list "$name" >/dev/null 2>&1
}

# True iff a single repo has a live mutagen session recorded + alive. Args: repo_dir
cs_sync_watch_session_alive() {
	local repo_dir="$1" sess
	sess="$(cs_sync_marker_get "$repo_dir" mutagen_session)"
	[ -n "$sess" ] && cs_sync_mutagen_present && mutagen sync list "$sess" >/dev/null 2>&1
}

# Is a watch running for this codespace? True iff a detached poll-loop PID
# (recorded path-level in the marker) is alive, OR a live mutagen session
# exists for any repo. Drives the "watch already running" guard + `open -r`.
# Args: path (repo dir or stack root)
cs_sync_watch_running() {
	local path="$1" pid d
	pid="$(cs_sync_marker_get "$path" watch_pid)"
	[ -n "$pid" ] && kill -0 "$pid" 2>/dev/null && return 0
	if cs_sync_is_stack "$path"; then
		for d in "$path"/*; do
			[ -e "$d/.git" ] || continue
			cs_sync_watch_session_alive "$d" && return 0
		done
		return 1
	fi
	cs_sync_watch_session_alive "$path"
}

# Ensure-or-create the live session (the working-tree mirror). The mutagen
# daemon keeps it alive across terminal closes; commit propagation rides the
# watch's poll loop, not a hook. Propagates cs_sync_ensure_mutagen's code: 0
# live; 1 mutagen unavailable (caller falls back to a one-shot overlay); 2 user
# declined syncing uncommitted (caller does a commit-only sync).
# Args: host, dest_rel, repo_dir, repo_id, branch
cs_sync_watch_start() {
	local host="$1" dest_rel="$2" repo_dir="$3" repo_id="$4" branch="$5"
	cs_sync_ensure_mutagen "$host" || return $?

	local name; name="$(cs_sync_watch_session_name "$repo_id" "$branch")"
	if mutagen sync list "$name" >/dev/null 2>&1; then
		>&2 echo "==> [$host] live sync already running ($name)"
	else
		>&2 echo "==> [$host] starting live sync ($name)"
		# mutagen uses scp-style `[user@]host:path` for ssh endpoints (NOT a
		# ssh:// scheme -- that gets misparsed as host "ssh"); the path is
		# home-relative, matching where the codespace lives (~/$dest_rel) and the
		# `$host:$dest_rel` form cs_rsync_to_remote already uses.
		# shellcheck disable=SC2046
		mutagen sync create --name="$name" --sync-mode=two-way-safe --ignore-vcs \
			$(cs_sync_mutagen_ignores "$repo_dir") \
			"$repo_dir" "$host:$dest_rel" || return 1
	fi
}

# Terminate the live session and clear the marker's live state. The detached
# poll-loop PID (if any) is killed separately by cs_sync_watch_stop_pid (it's
# recorded path-level, not per-repo). Args: repo_dir, repo_id, branch
cs_sync_watch_stop() {
	local repo_dir="$1" repo_id="$2" branch="$3"
	local name; name="$(cs_sync_watch_session_name "$repo_id" "$branch")"
	if cs_sync_mutagen_present && mutagen sync list "$name" >/dev/null 2>&1; then
		>&2 echo "==> terminating live sync ($name)"
		mutagen sync terminate "$name" 2>/dev/null || true
	fi
	if [ -f "$(cs_sync_marker_path "$repo_dir")" ]; then
		cs_sync_marker_set "$repo_dir" sync_mode commit
		cs_sync_marker_unset "$repo_dir" mutagen_session
	fi
	>&2 echo "==> live sync stopped for $branch"
}

# Kill a detached watch poller recorded for this path (repo or stack root) and
# clear its pid from the marker. No-op if none is recorded/alive. Args: path
cs_sync_watch_stop_pid() {
	local path="$1" pid
	pid="$(cs_sync_marker_get "$path" watch_pid)"
	if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
		>&2 echo "==> stopping background watch (pid $pid)"
		pkill -P "$pid" 2>/dev/null || true
		kill "$pid" 2>/dev/null || true
	fi
	[ -f "$(cs_sync_marker_path "$path")" ] && cs_sync_marker_unset "$path" watch_pid || true
}

# Legacy migration: older versions installed a tagged post-commit hook on BOTH
# ends to trigger commit syncs; the HEAD poll loop replaced them, but a hook
# already on disk survives and keeps firing. Detect + remove a stale local hook
# (restoring any pre-existing hook backed up as .precs), and -- only when we
# actually cleaned one locally -- the remote's too (they shared a lifecycle, so
# gating on the local one keeps this to a single extra ssh per migrated
# codespace, then never again). Args: host dest_rel repo_dir
_CS_SYNC_STALE_HOOK_TAG="# codespace-sync live-sync trigger"

cs_sync_migrate_purge_hooks() {
	local host="$1" dest_rel="$2" repo_dir="$3" hookdir hook found=""
	hookdir="$(git -C "$repo_dir" rev-parse --git-path hooks 2>/dev/null)" || return 0
	hook="$hookdir/post-commit"
	if [ -f "$hook" ] && grep -qF "$_CS_SYNC_STALE_HOOK_TAG" "$hook"; then
		if [ -f "$hook.precs" ]; then mv "$hook.precs" "$hook"; else rm -f "$hook"; fi
		found=1
		>&2 echo "note: removed a stale codespace-sync post-commit hook (now handled by --watch)."
	fi
	[ -n "$found" ] && [ -n "$host" ] && [ -n "$dest_rel" ] || return 0
	cs_ssh_script "$host" "$dest_rel" "$_CS_SYNC_STALE_HOOK_TAG" <<'REMOTE' || true
set -eu
dest_rel="$1"; tag="$2"
cd "$HOME/$dest_rel" 2>/dev/null || exit 0
hookdir="$(git rev-parse --git-path hooks 2>/dev/null)" || exit 0
hook="$hookdir/post-commit"
[ -f "$hook" ] && grep -qF "$tag" "$hook" || exit 0
if [ -f "$hook.precs" ]; then mv "$hook.precs" "$hook"; else rm -f "$hook"; fi
REMOTE
}

# Pause / resume / flush the working-tree sync (so git history ops don't race
# mutagen over the same files). No-ops if mutagen/session absent.
cs_sync_watch_pause()  { cs_sync_mutagen_present && mutagen sync pause  "$(cs_sync_watch_session_name "$1" "$2")" >/dev/null 2>&1 || true; }
cs_sync_watch_resume() { cs_sync_mutagen_present && mutagen sync resume "$(cs_sync_watch_session_name "$1" "$2")" >/dev/null 2>&1 || true; }

# Conflict count for the session (0 when absent). Args: repo_id, branch
cs_sync_watch_conflict_count() {
	cs_sync_mutagen_present || { echo 0; return 0; }
	local name; name="$(cs_sync_watch_session_name "$1" "$2")"
	local out
	out="$(mutagen sync list "$name" 2>/dev/null)" || { echo 0; return 0; }
	# mutagen prints a "Conflicts:" block when there are unresolved conflicts.
	printf '%s\n' "$out" | grep -ciE '^[[:space:]]*Conflicts:' || true
}


###################################
#                                 #
#  poll loop (commit propagation) #
#                                 #
###################################

# A commit doesn't change file contents on disk, so it never rides the mutagen
# working-tree mirror; some channel has to carry new commits. That channel is
# this loop: a cheap, ssh-free HEAD poll that, on change, runs a commit-only
# integrate (lock-protected, mutagen paused/resumed around the git ops). It is
# the single mechanism for both modes -- replacing the old post-commit hook --
# so commit-syncing lives and dies with an explicit --watch.
#
# Always runs its integrates non-interactively (a background/inattended watch
# must never block on a prompt): an ambiguous both-sides-advanced divergence is
# skipped until you resolve it with a manual sync. CS_WATCH_POLL_INTERVAL sets
# the cadence; CS_WATCH_POLL_MAX bounds the iteration count for tests (unset =
# forever). Args: path host sync_mode
cs_sync_watch_loop() {
	local path="$1" host="$2" sync_mode="$3"
	local interval="${CS_WATCH_POLL_INTERVAL:-5}" max="${CS_WATCH_POLL_MAX:-}" i=0
	local last cur
	last="$(cs_sync_watch_head_sig "$path")"
	while :; do
		[ -n "$max" ] && [ "$i" -ge "$max" ] && break
		sleep "$interval"
		i=$((i + 1))
		cur="$(cs_sync_watch_head_sig "$path")"
		if [ "$cur" != "$last" ]; then
			cs_sync_watch_integrate "$path" "$host"
			last="$(cs_sync_watch_head_sig "$path")"
		fi
	done
}

# Cheap signature of every repo HEAD under a codespace (no ssh). A change here
# is what wakes the poll loop. Args: path
cs_sync_watch_head_sig() {
	local path="$1" d
	if cs_sync_is_stack "$path"; then
		for d in "$path"/*; do
			[ -e "$d/.git" ] || continue
			printf '%s=%s\n' "$(basename "$d")" "$(git -C "$d" rev-parse HEAD 2>/dev/null)"
		done
	else
		git -C "$path" rev-parse HEAD 2>/dev/null
	fi
}

# Run one commit-only integrate for the codespace, holding the per-codespace
# lock for the duration (so it serializes against a manual sync). Best-effort:
# a failure (e.g. an ambiguous divergence) is swallowed; the next change retries.
# Args: path host
cs_sync_watch_integrate() {
	local path="$1" host="$2" lock
	lock="$(cs_sync_lock_acquire "$path")" || return 0     # busy; try next tick
	# integrates are commit-only + non-interactive (no tty in the background).
	local CS_NO_INTERACTIVE=1
	if cs_sync_is_stack "$path"; then
		cs_sync_stack "$path" "$host" commits "" "" "" "" "" >&2 || true
	else
		cs_sync_repo "$path" "$host" commits "" "" "" 1 "" "" >&2 || true
	fi
	rm -rf "$lock" 2>/dev/null || true
}


###################################
#                                 #
#  watch supervision (fg/detach)  #
#                                 #
###################################

# Manage the watch after the initial one-shot has integrated + (dirty) started
# the live session. --detach (or any non-interactive caller, e.g. an agent/CI
# that can't deliver a Ctrl-C) spawns a background poller and returns; an
# interactive foreground watch attaches + blocks until Ctrl-C.
# Args: path host sync_mode detach
cs_sync_watch_supervise() {
	local path="$1" host="$2" sync_mode="$3" detach="$4"
	if [ -n "$detach" ] || [ -n "${CS_NO_INTERACTIVE:-}" ]; then
		cs_sync_watch_detach "$path" "$host" "$sync_mode"
		return 0
	fi
	if cs_sync_is_stack "$path"; then
		cs_sync_watch_foreground_stack "$path" "$host" "$sync_mode"
	else
		cs_sync_watch_foreground_one "$path" "$host" "$sync_mode"
	fi
}

# Spawn the poll loop as a detached background process (survives the terminal via
# nohup), record its pid path-level in the marker, and return. --stop kills it.
# Args: path host sync_mode
cs_sync_watch_detach() {
	local path="$1" host="$2" sync_mode="$3" pid label
	# Re-enter the CLI's internal __watch_loop entrypoint so the child has the
	# full sourced environment; </dev/null + nohup detach it from this terminal.
	nohup codespace sync __watch_loop "$path" "$host" "$sync_mode" \
		>/dev/null 2>&1 </dev/null &
	pid=$!
	cs_sync_marker_set "$path" watch_pid "$pid"
	label="$(basename "$path")"; label="${label#stack_}"
	>&2 echo "==> watching '$label' in the background (pid $pid); stop with 'codespace sync --stop'."
}

# Single-repo foreground watch. Polls commits the whole time; for a dirty watch
# it also renders the live mutagen session's notices. Ctrl-C tears everything
# down. Args: repo_dir host sync_mode
cs_sync_watch_foreground_one() {
	local repo_dir="$1" host="$2" sync_mode="$3" name repo_id branch loop_pid=""
	name="$(cs_sync_marker_get "$repo_dir" mutagen_session)"
	repo_id="$(cs_sync_marker_get "$repo_dir" repo_id)"
	branch="$(cs_sync_marker_get "$repo_dir" branch)"

	trap 'if [ -n "${loop_pid:-}" ]; then kill "$loop_pid" 2>/dev/null || true; fi; cs_sync_watch_stop "$repo_dir" "$repo_id" "$branch"; exit 0' INT TERM
	if [ -n "$name" ] && cs_sync_mutagen_present; then
		# dirty watch: poll commits in the background, render notices in the fg.
		cs_sync_watch_loop "$repo_dir" "$host" "$sync_mode" & loop_pid=$!
		>&2 echo "==> live sync active for '$branch' ($name); watching commits. Ctrl-C to stop (terminates the session)."
		if command -v cs_sync_notify_watch >/dev/null 2>&1; then
			cs_sync_notify_watch "$name" "$branch" || true
		else
			mutagen sync monitor "$name" || true
		fi
		kill "$loop_pid" 2>/dev/null || true
		wait "$loop_pid" 2>/dev/null || true
	else
		# commits watch (or mutagen-less degrade): poll commits in the foreground.
		>&2 echo "==> watching '$branch' for commits. Ctrl-C to stop."
		cs_sync_watch_loop "$repo_dir" "$host" "$sync_mode"
	fi
	trap - INT TERM
}

# Stack foreground watch: same shape as the single-repo case but across every
# repo in the stack (one combined notice stream for the live sessions).
# Args: stack_dir host sync_mode
cs_sync_watch_foreground_stack() {
	local stack_dir="$1" host="$2" sync_mode="$3" d name branch loop_pid=""
	local -a names=() pairs=()
	for d in "$stack_dir"/*; do
		[ -e "$d/.git" ] || continue
		name="$(cs_sync_marker_get "$d" mutagen_session)"
		[ -n "$name" ] || continue
		branch="$(cs_sync_marker_get "$d" branch)"
		names+=("$name"); pairs+=("$name" "$branch")
	done

	local label; label="$(basename "$stack_dir")"; label="${label#stack_}"
	trap 'if [ -n "${loop_pid:-}" ]; then kill "$loop_pid" 2>/dev/null || true; fi; cs_sync_watch_stop_stack "$stack_dir"; exit 0' INT TERM
	if [ ${#names[@]} -gt 0 ] && cs_sync_mutagen_present; then
		cs_sync_watch_loop "$stack_dir" "$host" "$sync_mode" & loop_pid=$!
		>&2 echo "==> live sync active for stack '$label' (${#names[@]} session(s)); watching commits. Ctrl-C to stop (terminates the sessions)."
		if command -v cs_sync_notify_watch >/dev/null 2>&1; then
			cs_sync_notify_watch "${pairs[@]}" || true
		else
			mutagen sync monitor "${names[@]}" || true
		fi
		kill "$loop_pid" 2>/dev/null || true
		wait "$loop_pid" 2>/dev/null || true
	else
		>&2 echo "==> watching stack '$label' for commits. Ctrl-C to stop."
		cs_sync_watch_loop "$stack_dir" "$host" "$sync_mode"
	fi
	trap - INT TERM
}

# Tear down every live session in a stack (terminate + clear each repo marker).
# Re-reads markers so it stays correct as a trap action. The detached poller pid
# (stack-root) is killed separately by cs_sync_watch_stop_pid. Args: stack_dir
cs_sync_watch_stop_stack() {
	local stack_dir="$1" d repo_id branch
	for d in "$stack_dir"/*; do
		[ -e "$d/.git" ] || continue
		[ -n "$(cs_sync_marker_get "$d" mutagen_session)" ] || continue
		repo_id="$(cs_sync_marker_get "$d" repo_id)"
		branch="$(cs_sync_marker_get "$d" branch)"
		cs_sync_watch_stop "$d" "$repo_id" "$branch"
	done
}


###################################
#                                 #
#  conflict resolution            #
#                                 #
###################################

# If the live session has flagged conflicts, reconcile via the shared dirty
# content merge (granular 3-way) and flush so both endpoints match. No-op when
# there are no conflicts or we're non-interactive.
# Args: host, dest_rel, repo_dir, repo_id, branch, [resolve], [hard]
cs_sync_watch_resolve_conflicts() {
	local host="$1" dest_rel="$2" repo_dir="$3" repo_id="$4" branch="$5"
	local resolve="${6:-}" hard="${7:-}"
	local n; n="$(cs_sync_watch_conflict_count "$repo_id" "$branch")"
	[ "${n:-0}" -gt 0 ] 2>/dev/null || return 0

	local name; name="$(cs_sync_watch_session_name "$repo_id" "$branch")"
	>&2 echo "==> live sync flagged $n conflict(s) (simultaneous edits to the same file)"
	if [ -n "${CS_NO_INTERACTIVE:-}" ]; then
		>&2 echo "  reconcile via 'codespace sync --watch' interactively, or resolve manually then: mutagen sync flush $name"
		return 0
	fi
	mutagen sync list --long "$name" >&2 2>/dev/null || true
	>&2 printf '  [m]erge (granular 3-way)  [s]kip > '
	local ans=""; read -r ans </dev/tty 2>/dev/null || ans=s
	case "$ans" in
		m|merge)
			local local_dirty="" remote_dirty="" merged_tree marker_paths
			cs_sync_local_dirty "$repo_dir" && local_dirty=1
			cs_sync_remote_dirty "$host" "$dest_rel" && remote_dirty=1
			cs_sync_watch_pause "$repo_id" "$branch"
			merged_tree="$(cs_sync_merge_dirty "$host" "$dest_rel" "$repo_dir" "$branch" \
				"$resolve" "$hard" "$local_dirty" "$remote_dirty")" || {
				cs_sync_watch_resume "$repo_id" "$branch"
				return 1
			}
			marker_paths="$(cs_sync_dirty_merged_markers "$repo_dir" "$merged_tree")"
			cs_sync_overlay "$host" "$dest_rel" "$repo_dir"
			cs_sync_dirty_record_synced "$repo_dir" "$(git -C "$repo_dir" rev-parse HEAD)" \
				"$merged_tree" "$marker_paths"
			mutagen sync flush "$name" 2>/dev/null || true
			cs_sync_watch_resume "$repo_id" "$branch" ;;
		*) >&2 echo "  skipped; conflicts remain flagged." ;;
	esac
}
