#!/usr/bin/env bash

# codespace-sync: mirror a local codespace to a remote ssh host, re-runnably.
#
# Entry/dispatch + orchestrator + the .codespace/sync marker. The heavy lifting
# lives in focused siblings (sourced below):
#   codespace-sync-commit       -- commit-level integration (local is main)
#   codespace-sync-uncommitted  -- dirtiness, the decision, one-shot overlay
#   codespace-sync-watch        -- persistent live sync via mutagen (optional)
#
# Works at COMMIT granularity: committed work is the unit of sync; uncommitted
# work is a hazard resolved up front (commit / retry / sync-uncommitted).

set -euo pipefail

test -z "${DEBUG:-}" || set -x

DIRNAME="$(dirname "$(realpath "$0")")"

# shellcheck source=codespace-utils
source "$DIRNAME/codespace-utils"
# shellcheck source=codespace-sync-commit
source "$DIRNAME/codespace-sync-commit"
# shellcheck source=codespace-sync-uncommitted
source "$DIRNAME/codespace-sync-uncommitted"
# codespace-sync-watch is the optional phase-3 live-sync layer; load if present.
if [ -f "$DIRNAME/codespace-sync-watch" ]; then
	# shellcheck source=codespace-sync-watch
	source "$DIRNAME/codespace-sync-watch"
fi


###################################
#                                 #
#  marker file (.codespace/sync)  #
#                                 #
###################################

# Path of the .codespace/sync marker for a codespace root dir.
cs_sync_marker_path() {
	echo "${1:-$(pwd)}/.codespace/sync"
}

# Read a single key from a .codespace/sync marker. Args: dir, key
cs_sync_marker_get() {
	local dir="$1" key="$2" marker
	marker="$(cs_sync_marker_path "$dir")"
	[ -f "$marker" ] || return 0
	awk -F= -v k="$key" '$1 == k { sub(/^[^=]*=/, "", $0); print; exit }' "$marker"
}

# Write a .codespace/sync marker at <dir> with key=value pairs, and git-exclude
# it (it lives under a possibly-committed .codespace/, like .codespace/current).
# Args: dir, key=value...
cs_sync_marker_write() {
	local dir="$1"; shift
	mkdir -p "$dir/.codespace"
	local marker="$dir/.codespace/sync"
	: > "$marker"
	local kv
	for kv in "$@"; do
		echo "$kv" >> "$marker"
	done
	if [ -e "$dir/.git" ]; then
		( cd "$dir" && cs_git_exclude_add .codespace/sync )
	fi
}

# Set (insert or replace) a single key=value in an existing marker. Args: dir key value
cs_sync_marker_set() {
	local dir="$1" key="$2" value="$3" marker tmp
	marker="$(cs_sync_marker_path "$dir")"
	mkdir -p "$(dirname "$marker")"; : >> "$marker"
	tmp="$(mktemp)"
	awk -F= -v k="$key" -v v="$value" '
		$1 == k { print k"="v; seen=1; next }
		{ print }
		END { if (!seen) print k"="v }' "$marker" > "$tmp"
	mv "$tmp" "$marker"
}

# Remove a key line from a marker. Args: dir key
cs_sync_marker_unset() {
	local dir="$1" key="$2" marker tmp
	marker="$(cs_sync_marker_path "$dir")"
	[ -f "$marker" ] || return 0
	tmp="$(mktemp)"
	grep -v "^$key=" "$marker" > "$tmp" || true
	mv "$tmp" "$marker"
}


###################################
#                                 #
#  target resolution              #
#                                 #
###################################

# Resolve an arg (cwd / path / branch) to a codespace path. With no arg, targets
# the enclosing stack root if we're inside one, else cwd. A branch resolves via
# cs_find (which may return a stack dir). Args: [branch|path]
cs_sync_resolve_path() {
	local arg="${1:-}"
	if [ -z "$arg" ]; then
		local sd
		if sd="$(cs_stack_detect_current 2>/dev/null | sed -n '1p')" && [ -n "$sd" ]; then
			echo "$sd"
		else
			pwd
		fi
	elif [ -d "$arg" ]; then
		cs_abspath "$arg"
	else
		cs_find "$arg" || return 1
	fi
}

# Is <path> a stack root (a `stack_<branch>` directory)?
cs_sync_is_stack() {
	case "$(basename "$1")" in stack_*) [ -d "$1" ] ;; *) return 1 ;; esac
}

# First repo dir inside a stack (for repo-id-based host/config resolution).
cs_sync_stack_first_repo() {
	local d
	for d in "$1"/*; do
		if [ -e "$d/.git" ]; then echo "$d"; return 0; fi
	done
	return 1
}

# Validate a single-repo codespace dir and print its metadata as 4 lines:
# branch, repo_id, kind, dest_rel. Args: repo_dir
cs_sync_repo_meta() {
	local repo_dir="$1"
	if cs_remote_marker "$repo_dir"; then
		>&2 echo "err: '$repo_dir' is a remote codespace stub; nothing local to sync"
		return 1
	fi
	if ! git -C "$repo_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
		>&2 echo "err: '$repo_dir' is not a git working tree"
		return 1
	fi
	local branch repo_id kind dest_rel
	branch="$(git -C "$repo_dir" symbolic-ref --short HEAD 2>/dev/null)" || {
		>&2 echo "err: '$repo_dir' is not on a branch (detached HEAD)"
		return 1
	}
	repo_id="$(cd "$repo_dir" && cs_repo_id)" || return 1
	if [ -n "$(cs_clone_marker "$repo_dir")" ]; then kind="clone"; else kind="worktree"; fi
	dest_rel="$(cs_remote_relpath_for_local "$(cs_abspath "$repo_dir")")" || return 1
	printf '%s\n%s\n%s\n%s\n' "$branch" "$repo_id" "$kind" "$dest_rel"
}


###################################
#                                 #
#  first-sync provisioning        #
#                                 #
###################################

# Provision the remote codespace when it doesn't exist yet, reusing the create
# machinery (self-install + probe + config rsync + core + ship + bootstrap +
# post-create). Leaves a git checkout on the branch ready for commit alignment.
# Args: host, repo_id, branch, dest_rel, kind, base_rel, repo_dir
cs_sync_provision() {
	local host="$1" repo_id="$2" branch="$3" dest_rel="$4" kind="$5" base_rel="$6" repo_dir="$7"
	local base_repo cfg_rel clone_url manifest

	>&2 echo "==> [$host] remote codespace absent; provisioning ~/$dest_rel"
	# host-scoped steps run once per sync; a stack sets CS_SYNC_HOST_READY so the
	# per-repo loop doesn't reinstall/reprobe for every repo.
	if [ -z "${CS_SYNC_HOST_READY:-}" ]; then
		cs_remote_self_install "$host"
		cs_remote_probe "$host"
	fi
	cfg_rel="$(cs_rsync_config_to_remote "$host" "$repo_id" | head -n1)"

	if [ "$kind" = "clone" ]; then
		clone_url="$(git -C "$repo_dir" remote get-url origin 2>/dev/null)" || clone_url=""
		test -n "$clone_url" || { >&2 echo "err: cannot infer clone URL for '$repo_dir'"; return 1; }
		cs_create_remote_clone_core "$host" "$clone_url" "$dest_rel" "$branch"
	else
		cs_create_remote_worktree_core "$host" "$repo_id" "$branch" "$dest_rel"
	fi

	base_repo="$(cd "$repo_dir" && cs_abs_path_base_repo)"
	manifest="$(cs_collect_remote_files "$base_repo")"
	cs_ship_files_to_remote "$host" "$dest_rel" "$manifest" "$repo_id" "$base_repo"
	rm -f "$manifest"

	cs_remote_run_bootstrap "$host" "$repo_id" "$dest_rel" "$base_rel" "$branch" "$cfg_rel"
	cs_remote_run_post_create "$host" "$repo_id" "$dest_rel" "$cfg_rel"
}


###################################
#                                 #
#  uncommitted resolution         #
#                                 #
###################################

# Decide + enact how to handle uncommitted changes. May commit the dirty side(s)
# (basic message). Prints the resulting mode for the orchestrator: one of
# `proceed`, `overlay`, `watch`. Returns non-zero to abort.
# Args: host dest_rel repo_dir branch local_dirty remote_dirty want once commit_msg
cs_sync_resolve_uncommitted() {
	local host="$1" dest_rel="$2" repo_dir="$3" branch="$4"
	local local_dirty="$5" remote_dirty="$6" want="$7" once="$8" commit_msg="$9"
	local interactive=""; [ -z "${CS_NO_INTERACTIVE:-}" ] && interactive=1

	while :; do
		local mutagen_ok=""
		# probe for mutagen only when it can change the decision: a side is dirty,
		# or --watch (which may start/keep a session even on a clean tree). A
		# plain clean sync never pays the ssh round-trip.
		if { [ -n "$local_dirty" ] || [ -n "$remote_dirty" ] || [ "$want" = watch ]; } \
			&& command -v cs_sync_mutagen_available >/dev/null 2>&1 \
			&& cs_sync_mutagen_available "$host"; then
			mutagen_ok=1
		fi

		local decision
		decision="$(cs_sync_decide_uncommitted "$local_dirty" "$remote_dirty" \
			"$want" "$once" "$interactive" "$mutagen_ok")"

		case "$decision" in
			proceed) echo proceed; return 0 ;;
			overlay) echo overlay; return 0 ;;
			watch)   echo watch;   return 0 ;;
			commit)
				cs_sync_commit_dirty "$host" "$dest_rel" "$repo_dir" \
					"$local_dirty" "$remote_dirty" "$commit_msg" || return 1
				echo proceed; return 0 ;;
			abort)
				>&2 echo "err: uncommitted changes present; aborting."
				>&2 echo "  commit them, or pass --commit / --uncommitted (see 'codespace sync -h')."
				return 1 ;;
			prompt)
				local ans ld="no" rd="no"
				[ -n "$local_dirty" ] && ld="yes"
				[ -n "$remote_dirty" ] && rd="yes"
				>&2 echo "uncommitted changes detected (local:$ld remote:$rd)."
				>&2 printf '  [c]ommit  [r]etry  [s]ync-uncommitted  [a]bort > '
				read -r ans || ans=a
				case "$ans" in
					c|commit) want=commit ;;
					r|retry)
						cs_sync_local_dirty "$repo_dir" && local_dirty=1 || local_dirty=""
						cs_sync_remote_dirty "$host" "$dest_rel" && remote_dirty=1 || remote_dirty=""
						want="" ;;
					s|sync|sync-uncommitted) want=uncommitted ;;
					*) >&2 echo "aborted."; return 1 ;;
				esac ;;
		esac
	done
}

# Commit the dirty side(s) with a basic message (local via git, remote via ssh).
# Args: host dest_rel repo_dir local_dirty remote_dirty msg
cs_sync_commit_dirty() {
	local host="$1" dest_rel="$2" repo_dir="$3" local_dirty="$4" remote_dirty="$5" msg="$6"
	if [ -n "$local_dirty" ]; then
		>&2 echo "==> committing local changes"
		git -C "$repo_dir" add -A >&2
		git -C "$repo_dir" commit -m "$msg" >&2
	fi
	if [ -n "$remote_dirty" ]; then
		>&2 echo "==> [$host] committing remote changes"
		cs_ssh_script "$host" "$dest_rel" "$msg" <<'REMOTE'
set -eu
dest_rel="$1"; msg="$2"
cd "$HOME/$dest_rel"
git add -A
git commit -m "$msg"
REMOTE
	fi
}


###################################
#                                 #
#  orchestrator                   #
#                                 #
###################################

# Sync one single-repo codespace dir to host. Self-contained: resolves its own
# metadata, provisions if absent, resolves uncommitted, integrates commits,
# aligns the remote, overlays/watches per mode, ships config, records a marker.
# Return: 0 ok, 2 integration conflict (caller may report + continue), 1 error.
# Args: repo_dir host want once resolve dry_run commit_msg [quiet] [stop_watch]
cs_sync_repo() {
	local repo_dir="$1" host="$2" want="$3" once="$4" resolve="$5" \
		dry_run="$6" commit_msg="$7" quiet="${8:-}" stop_watch="${9:-}"

	local branch repo_id kind dest_rel meta
	meta="$(cs_sync_repo_meta "$repo_dir")" || return 1
	branch="$(echo "$meta" | sed -n '1p')"
	repo_id="$(echo "$meta" | sed -n '2p')"
	kind="$(echo "$meta" | sed -n '3p')"
	dest_rel="$(echo "$meta" | sed -n '4p')"

	local base_rel
	if [ "$kind" = "clone" ]; then base_rel="$dest_rel"; else base_rel="codespace/$repo_id"; fi

	if [ -n "$stop_watch" ]; then
		if command -v cs_sync_watch_stop >/dev/null 2>&1; then
			cs_sync_watch_stop "$repo_dir" "$repo_id" "$branch"
		else
			>&2 echo "err: live sync (--stop-watch) requires the codespace-sync-watch component"
			return 1
		fi
		return 0
	fi

	[ -n "$quiet" ] || >&2 echo "==> syncing $kind '$branch' ($repo_dir) -> $host:~/$dest_rel"

	# Ensure the remote exists (provision on first sync).
	if ! cs_sync_remote_exists "$host" "$dest_rel"; then
		if [ -n "$dry_run" ]; then
			>&2 echo "[dry-run] would provision remote codespace at ~/$dest_rel"
		else
			cs_sync_provision "$host" "$repo_id" "$branch" "$dest_rel" "$kind" "$base_rel" "$repo_dir"
		fi
	fi

	local local_dirty="" remote_dirty=""
	cs_sync_local_dirty "$repo_dir" && local_dirty=1
	if cs_sync_remote_exists "$host" "$dest_rel"; then
		cs_sync_remote_dirty "$host" "$dest_rel" && remote_dirty=1
	fi

	if [ -n "$dry_run" ]; then
		>&2 echo "[dry-run] $repo_id: local_dirty=${local_dirty:-no} remote_dirty=${remote_dirty:-no} resolve=${resolve:-auto}"
		>&2 echo "[dry-run] would integrate commits, align remote, write .codespace/sync"
		return 0
	fi

	local mode
	mode="$(cs_sync_resolve_uncommitted "$host" "$dest_rel" "$repo_dir" "$branch" \
		"$local_dirty" "$remote_dirty" "$want" "$once" "$commit_msg")" || return 1
	cs_sync_local_dirty "$repo_dir" && local_dirty=1 || local_dirty=""
	cs_sync_remote_dirty "$host" "$dest_rel" && remote_dirty=1 || remote_dirty=""

	# If a live (mutagen) session is running, freeze it so the git history ops
	# below don't race the filewatcher over the same files.
	local live="" remote_stashed=""
	if command -v cs_sync_watch_active >/dev/null 2>&1 && cs_sync_watch_active "$repo_id" "$branch"; then
		live=1
		cs_sync_watch_pause "$repo_id" "$branch"
	fi

	# Protect the remote's uncommitted remainder from being clobbered by an align
	# reset/rebase, then restore it after so the live session reconciles it. By
	# this point the remote is only dirty in watch mode (other modes resolve it
	# up front), so this also covers the very first --watch -- not just an
	# already-running session. (commit-during-live: a partial commit's remainder
	# is preserved on both ends.)
	[ -n "$remote_dirty" ] && cs_sync_remote_stash_push "$host" "$dest_rel" && remote_stashed=1 || true

	# Stash any remaining local uncommitted work so ff/rebase has a clean tree.
	local stashed=""
	if [ -n "$local_dirty" ]; then
		git -C "$repo_dir" stash push -u -q -m "cs-sync auto-stash" >&2 && stashed=1 || stashed=""
	fi
	# Integrate commits using the prior synced_commit as the fork point. When
	# both sides advanced the integrator prompts (if interactive); its stdout
	# carries the align token (`reset` -> align must hard-reset the remote to
	# local HEAD, backing up the old remote tip).
	local synced_prev interactive="" integ align_reset=""
	synced_prev="$(cs_sync_marker_get "$repo_dir" synced_commit)"
	[ -z "${CS_NO_INTERACTIVE:-}" ] && interactive=1
	if ! integ="$(cs_sync_integrate_local "$host" "$dest_rel" "$branch" "$repo_dir" \
		"$resolve" "$synced_prev" "$interactive")"; then
		[ -n "$stashed" ] && >&2 echo "note: your uncommitted changes are saved in 'git stash' (git stash pop)"
		[ -n "$live" ] && cs_sync_watch_resume "$repo_id" "$branch"
		return 2
	fi
	[ "$integ" = reset ] && align_reset=1
	[ -n "$stashed" ] && git -C "$repo_dir" stash pop -q >&2 || true

	cs_sync_align_remote "$host" "$dest_rel" "$branch" "$repo_dir" "$base_rel" "$align_reset"

	[ -n "$remote_stashed" ] && cs_sync_remote_stash_pop "$host" "$dest_rel"
	[ -n "$live" ] && cs_sync_watch_resume "$repo_id" "$branch"

	case "$mode" in
		overlay) cs_sync_overlay "$host" "$dest_rel" "$repo_dir" ;;
		watch)
			local wrc=0
			if command -v cs_sync_watch_start >/dev/null 2>&1; then
				cs_sync_watch_start "$host" "$dest_rel" "$repo_dir" "$repo_id" "$branch" || wrc=$?
			else
				wrc=1
			fi
			if [ "$wrc" = 0 ]; then
				cs_sync_watch_resolve_conflicts "$host" "$dest_rel" "$repo_dir" "$repo_id" "$branch" || true
			elif [ "$wrc" = 2 ]; then
				>&2 echo "note: leaving uncommitted changes local-only; committed history is synced."
				mode=commit
			elif [ -n "$local_dirty" ]; then
				>&2 echo "note: live sync unavailable; falling back to a one-shot overlay"
				cs_sync_overlay "$host" "$dest_rel" "$repo_dir"
				mode=overlay
			else
				>&2 echo "note: persistent watch needs mutagen; committed history synced (nothing uncommitted to mirror)."
				mode=commit
			fi ;;
	esac

	# Re-ship config files (gitignored symlinks) so edited sources propagate.
	local base_repo manifest
	base_repo="$(cd "$repo_dir" && cs_abs_path_base_repo)"
	manifest="$(cs_collect_remote_files "$base_repo")"
	cs_ship_files_to_remote "$host" "$dest_rel" "$manifest" "$repo_id" "$base_repo"
	rm -f "$manifest"

	# Record the mode: a still-running live session is sticky (implied --watch
	# next time); else overlay / plain commit sync.
	local synced_commit sync_mode="commit" mutagen_session=""
	synced_commit="$(git -C "$repo_dir" rev-parse HEAD)"
	case "$mode" in overlay) sync_mode="overlay" ;; watch) sync_mode="live" ;; esac
	if [ "$sync_mode" != "overlay" ] \
		&& command -v cs_sync_watch_active >/dev/null 2>&1 \
		&& cs_sync_watch_active "$repo_id" "$branch"; then
		sync_mode="live"
		mutagen_session="$(cs_sync_watch_session_name "$repo_id" "$branch")"
	fi

	local -a marker_kv=(
		"host=$host" "relpath=$dest_rel" "kind=$kind" "repo_id=$repo_id"
		"branch=$branch" "synced_commit=$synced_commit"
		"synced_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)" "sync_mode=$sync_mode"
	)
	[ -n "$mutagen_session" ] && marker_kv+=("mutagen_session=$mutagen_session")
	cs_sync_marker_write "$repo_dir" "${marker_kv[@]}"

	[ -n "$quiet" ] || >&2 echo "==> synced $branch -> $host:~/$dest_rel (commit ${synced_commit:0:9}, mode=$sync_mode)"
}

# Stash the remote worktree's uncommitted remainder (so an align reset/rebase
# doesn't clobber it). Returns 0 only if something was actually stashed.
# Args: host, dest_rel
cs_sync_remote_stash_push() {
	cs_ssh_script "$1" "$2" <<'REMOTE'
set -eu
cd "$HOME/$1"
before="$(git stash list 2>/dev/null | wc -l)"
git stash push -u -q -m "cs-sync auto-stash" >/dev/null 2>&1 || true
after="$(git stash list 2>/dev/null | wc -l)"
[ "$after" -gt "$before" ]
REMOTE
}

# Re-apply the remote worktree's stashed remainder. A plain 3-way `stash pop`
# works for the no-commit case; when a partial commit was just integrated, the
# committed subset collides with the stash's 3-way apply, so we fall back to
# overwriting tracked paths from the stash (committed-identical files are a
# no-op, the genuine remainder reapplies). Anything still unresolved stays
# recoverable in the stash and mutagen re-mirrors it from local. Args: host, dest_rel
cs_sync_remote_stash_pop() {
	cs_ssh_script "$1" "$2" <<'REMOTE'
set -eu
cd "$HOME/$1"
git rev-parse --verify --quiet refs/stash >/dev/null 2>&1 || exit 0
if git stash pop -q 2>/dev/null; then exit 0; fi
# 3-way pop collided with the just-integrated commit; restore the stash's
# tracked content directly (committed-identical paths are a no-op) and drop it.
git checkout stash@{0} -- . 2>/dev/null || true
git stash drop -q 2>/dev/null || true
REMOTE
}

# rsync the stack root's top-level loose files (regular files only -- repo dirs
# are synced via git; symlinks are re-created by the remote stack-post-create).
# Args: host, stack_dest_rel, stack_dir
cs_sync_stack_loose_files() {
	local host="$1" dest_rel="$2" stack_dir="$3" f base
	local files=()
	for f in "$stack_dir"/*; do
		[ -f "$f" ] && [ ! -L "$f" ] || continue
		base="$(basename "$f")"
		[ "$base" = "open" ] && continue
		files+=("$f")
	done
	[ ${#files[@]} -gt 0 ] || return 0
	>&2 echo "==> [$host] syncing ${#files[@]} stack-root file(s)"
	cs_rsync_to_remote "$host" "${files[@]}" "$dest_rel/"
}

# Sync a multi-repo stack: host prep once, then per-repo commit-sync, then the
# stack-root loose files + a stack-root marker. Per-repo conflicts are collected
# and reported without aborting the whole stack.
# Args: stack_dir host want once resolve dry_run commit_msg [stop_watch]
cs_sync_stack() {
	local stack_dir="$1" host="$2" want="$3" once="$4" resolve="$5" \
		dry_run="$6" commit_msg="$7" stop_watch="${8:-}"
	local branch stack_dest_rel
	branch="$(basename "$stack_dir")"; branch="${branch#stack_}"
	stack_dest_rel="$(cs_remote_relpath_for_local "$stack_dir")"

	>&2 echo "==> syncing stack '$branch' ($stack_dir) -> $host:~/$stack_dest_rel"

	if [ -z "$dry_run" ] && [ -z "$stop_watch" ]; then
		cs_remote_self_install "$host"
		cs_remote_probe "$host"
		export CS_SYNC_HOST_READY=1
		cs_ssh_script "$host" "$stack_dest_rel" <<'REMOTE'
set -eu
mkdir -p "$HOME/$1"
REMOTE
	fi

	local repos=() d
	for d in "$stack_dir"/*; do
		[ -e "$d/.git" ] || continue
		repos+=("$d")
	done

	local failures=() conflicts=() r rc
	for r in "${repos[@]}"; do
		if cs_sync_repo "$r" "$host" "$want" "$once" "$resolve" "$dry_run" "$commit_msg" 1 "$stop_watch"; then
			:
		else
			rc=$?
			if [ "$rc" = 2 ]; then conflicts+=("$(basename "$r")"); else failures+=("$(basename "$r")"); fi
		fi
	done
	unset CS_SYNC_HOST_READY

	[ -n "$stop_watch" ] && { >&2 echo "==> stopped live sync for stack '$branch'"; return 0; }

	if [ -z "$dry_run" ]; then
		cs_sync_stack_loose_files "$host" "$stack_dest_rel" "$stack_dir"
		cs_sync_marker_write "$stack_dir" \
			"host=$host" \
			"relpath=$stack_dest_rel" \
			"kind=stack" \
			"branch=$branch" \
			"synced_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
	fi

	if [ ${#conflicts[@]} -gt 0 ] || [ ${#failures[@]} -gt 0 ]; then
		>&2 echo "==> stack '$branch' synced with issues:"
		[ ${#conflicts[@]} -gt 0 ] && >&2 echo "  conflicts (resolve in the repo, then re-run): ${conflicts[*]}"
		[ ${#failures[@]} -gt 0 ] && >&2 echo "  failed: ${failures[*]}"
		return 1
	fi
	[ -n "$dry_run" ] || >&2 echo "==> stack synced: $branch -> $host:~/$stack_dest_rel (${#repos[@]} repos)"
}

cs_sync() {
	local arg="" host="" want="" commit_msg="" once="" resolve="" dry_run="" stop_watch="" detach=""
	while [ $# -gt 0 ]; do
		case "$1" in
			-h|--help) echo "$SYNC_HELP"; return 0 ;;
			-r|--remote)
				shift
				if [ $# -gt 0 ] && [ "${1#-}" = "$1" ]; then host="$1"; shift
				else host="$CS_REMOTE_USE_DEFAULT"; fi ;;
			--commit) want="commit"; shift ;;
			-m) shift; commit_msg="${1:-}"; want="commit"; [ $# -gt 0 ] && shift ;;
			--uncommitted) want="uncommitted"; shift ;;
			--once) once=1; shift ;;
			-w|--watch) want="watch"; shift ;;
			-d|--detach) detach=1; shift ;;
			--stop|--stop-watch) stop_watch=1; shift ;;
			--ours) resolve=ours; shift ;;
			--theirs) resolve=theirs; shift ;;
			--dry-run) dry_run=1; shift ;;
			-*) >&2 echo "err: unknown flag: $1"; return 1 ;;
			*) arg="$1"; shift ;;
		esac
	done
	: "${commit_msg:=wip: codespace sync $(date -u +%Y-%m-%dT%H:%M:%SZ)}"

	local path
	path="$(cs_sync_resolve_path "$arg")" || return 1

	# Resolve the target host: explicit value wins, else the prior marker at the
	# target, else $CS_DEFAULT_REMOTE / a .codespace/remote config file.
	if [ -z "$host" ] || [ "$host" = "$CS_REMOTE_USE_DEFAULT" ]; then
		local mh resolve_dir="$path"
		mh="$(cs_sync_marker_get "$path" host)"
		if [ -n "$mh" ]; then
			host="$mh"
		else
			cs_sync_is_stack "$path" && resolve_dir="$(cs_sync_stack_first_repo "$path")" || true
			host="$(cd "${resolve_dir:-$path}" 2>/dev/null && cs_resolve_remote "")" || {
				>&2 echo "err: no remote host (pass -r <host>, set \$CS_DEFAULT_REMOTE, or a .codespace/remote file)"
				return 1
			}
		fi
	fi

	# Serialize syncs of the same codespace so a post-commit-hook-triggered
	# background sync can't race a manual one (concurrent git stash/rebase on the
	# same tree would corrupt state). Read-only dry-runs don't need it.
	local lock=""
	if [ -z "$dry_run" ]; then
		lock="$(cs_sync_lock_acquire "$path")" || {
			>&2 echo "note: another 'codespace sync' is in progress for $path; skipping."
			return 0
		}
	fi

	local rc=0
	if cs_sync_is_stack "$path"; then
		cs_sync_stack "$path" "$host" "$want" "$once" "$resolve" "$dry_run" "$commit_msg" "$stop_watch" || rc=$?
	else
		cs_sync_repo "$path" "$host" "$want" "$once" "$resolve" "$dry_run" "$commit_msg" "" "$stop_watch" || rc=$?
	fi
	[ -n "$lock" ] && rm -rf "$lock" 2>/dev/null

	# Foreground watch: an explicit, non-detached `--watch` stays active until
	# stopped/killed. Run AFTER releasing the lock so it never blocks the
	# post-commit-hook background sync; it reads the just-written marker(s) for
	# the live session name(s), so it only blocks when a session exists.
	if [ "$want" = watch ] && [ -z "$detach" ] && [ -z "$dry_run" ] \
		&& [ -z "${CS_NO_INTERACTIVE:-}" ] && [ "$rc" -eq 0 ] \
		&& command -v cs_sync_watch_foreground >/dev/null 2>&1; then
		cs_sync_watch_foreground "$path"
	fi
	return $rc
}

# Per-codespace cross-process lock (mkdir is atomic). Waits up to ~30s for a
# held lock, stealing one left stale (>10min) by a crashed run. Stored outside
# the worktree (keyed by path checksum) so it never shows as untracked.
# Args: path  -> stdout: lock dir on success; returns 1 if it couldn't acquire.
cs_sync_lock_acquire() {
	local key lock canon
	# Canonicalize first: pwd / cs_find can hand us a logical path (e.g.
	# /var/folders vs /private/var/folders, a trailing slash, a symlink) that
	# would hash differently for the same codespace and so fail to serialize a
	# hook-triggered background sync against a manual one.
	canon="$(cs_abspath "$1" 2>/dev/null)" || canon=""
	[ -n "$canon" ] || canon="$1"
	key="$(printf '%s' "$canon" | cksum | cut -d' ' -f1)"
	lock="${TMPDIR:-/tmp}/cs-sync-lock-$key"
	for _ in $(seq 1 60); do
		if mkdir "$lock" 2>/dev/null; then echo "$lock"; return 0; fi
		if [ -d "$lock" ] && [ -n "$(find "$lock" -maxdepth 0 -mmin +10 2>/dev/null)" ]; then
			rm -rf "$lock" 2>/dev/null || true
			continue
		fi
		sleep 0.5
	done
	return 1
}

SYNC_HELP="\
Usage:
codespace sync [<branch>|<path>] [-r [host]] [--commit [-m <msg>] | --uncommitted [--once] | -w|--watch [-d|--detach] | --stop] [--ours | --theirs] [--dry-run]

Mirror a local codespace to a remote ssh host, re-runnably, at commit
granularity. Commits integrate using the last synced commit as the fork point:
when only one side moved since then it auto-picks that side; when both moved it
prompts (default rebase) interactively, else refuses. Uncommitted changes are
resolved up front.

args:
  <branch>|<path>   codespace to sync (default: the one at the current dir).

flags:
  -r, --remote [host]   target host. default: the prior target recorded in
                        .codespace/sync, else \$CS_DEFAULT_REMOTE / a
                        .codespace/remote config file.
  --commit [-m <msg>]   commit any uncommitted changes (basic message) and sync.
  --uncommitted         keep the uncommitted working tree mirrored (live mutagen
                        session if available, else a one-shot rsync overlay).
    --once              force the dependency-free one-shot overlay.
  -w, --watch           keep uncommitted changes mirrored via a persistent live
                        (mutagen) session, and stay active until stopped/killed
                        -- engaging even on a clean tree, so it waits for changes
                        (e.g. before an agent runs). Ctrl-C / kill terminates the
                        session. without mutagen it offers to install it
                        (interactive) or degrades to a one-shot.
  -d, --detach          with --watch: start the live session and return instead
                        of staying in the foreground (the mutagen daemon keeps
                        mirroring; end it later with --stop-watch).
  --stop, --stop-watch  terminate the live session for this codespace.
  --ours                local HEAD wins: reset the remote to it (old remote tip
                        backed up). resolves a both-sides-advanced divergence.
  --theirs              the remote tip wins: reset local to it (old local tip
                        backed up). uses the host resolved for this run.
  --dry-run             print the plan; mutate nothing.
"

cs_sync_main() {
	case "${1:-}" in
		-h|--help) echo "$SYNC_HELP"; return 0 ;;
	esac
	cs_sync "$@"
}

test -n "${CS_SYNC_NO_RUN:-}" || {
	cs_sync_main "$@"
	exit $?
}
