#!/usr/bin/env bash

# codespace-sync: mirror a local codespace to a remote ssh host, re-runnably.
#
# Entry/dispatch + orchestrator + the .codespace/sync marker. The heavy lifting
# lives in focused siblings (sourced below):
#   codespace-sync-commit       -- commit-level integration (local is main)
#   codespace-sync-uncommitted  -- dirtiness, the decision, one-shot overlay
#   codespace-sync-watch        -- persistent live sync via mutagen (optional)
#   codespace-sync-notify       -- debounced foreground sync notifications (optional)
#
# Works at COMMIT granularity: committed work is the unit of sync; uncommitted
# work is a hazard resolved up front (commit / retry / sync-uncommitted).

set -euo pipefail

test -z "${DEBUG:-}" || set -x

DIRNAME="$(dirname "$(realpath "$0")")"

# shellcheck source=codespace-utils
source "$DIRNAME/codespace-utils"
# shellcheck source=codespace-sync-commit
source "$DIRNAME/codespace-sync-commit"
# shellcheck source=codespace-sync-uncommitted
source "$DIRNAME/codespace-sync-uncommitted"
# codespace-sync-watch is the optional phase-3 live-sync layer; load if present.
if [ -f "$DIRNAME/codespace-sync-watch" ]; then
	# shellcheck source=codespace-sync-watch
	source "$DIRNAME/codespace-sync-watch"
fi
# codespace-sync-notify renders the foreground watch's debounced notifications;
# optional, load if present.
if [ -f "$DIRNAME/codespace-sync-notify" ]; then
	# shellcheck source=codespace-sync-notify
	source "$DIRNAME/codespace-sync-notify"
fi


###################################
#                                 #
#  marker file (.codespace/sync)  #
#                                 #
###################################

# Path of the .codespace/sync marker for a codespace root dir.
cs_sync_marker_path() {
	echo "${1:-$(pwd)}/.codespace/sync"
}

# Read a single key from a .codespace/sync marker. Args: dir, key
cs_sync_marker_get() {
	local dir="$1" key="$2" marker
	marker="$(cs_sync_marker_path "$dir")"
	[ -f "$marker" ] || return 0
	awk -F= -v k="$key" '$1 == k { sub(/^[^=]*=/, "", $0); print; exit }' "$marker"
}

# Write a .codespace/sync marker at <dir> with key=value pairs, and git-exclude
# it (it lives under a possibly-committed .codespace/, like .codespace/current).
# Args: dir, key=value...
cs_sync_marker_write() {
	local dir="$1"; shift
	mkdir -p "$dir/.codespace"
	local marker="$dir/.codespace/sync"
	: > "$marker"
	local kv
	for kv in "$@"; do
		echo "$kv" >> "$marker"
	done
	if [ -e "$dir/.git" ]; then
		( cd "$dir" && cs_git_exclude_add .codespace/sync )
	fi
}

# Set (insert or replace) a single key=value in an existing marker. Args: dir key value
cs_sync_marker_set() {
	local dir="$1" key="$2" value="$3" marker tmp
	marker="$(cs_sync_marker_path "$dir")"
	mkdir -p "$(dirname "$marker")"; : >> "$marker"
	tmp="$(mktemp)"
	awk -F= -v k="$key" -v v="$value" '
		$1 == k { print k"="v; seen=1; next }
		{ print }
		END { if (!seen) print k"="v }' "$marker" > "$tmp"
	mv "$tmp" "$marker"
}

# Remove a key line from a marker. Args: dir key
cs_sync_marker_unset() {
	local dir="$1" key="$2" marker tmp
	marker="$(cs_sync_marker_path "$dir")"
	[ -f "$marker" ] || return 0
	tmp="$(mktemp)"
	grep -v "^$key=" "$marker" > "$tmp" || true
	mv "$tmp" "$marker"
}


###################################
#                                 #
#  target resolution              #
#                                 #
###################################

# Resolve an arg (cwd / path / branch) to a codespace path. With no arg, targets
# the enclosing stack root if we're inside one, else cwd. A branch resolves via
# cs_find (which may return a stack dir). Args: [branch|path]
cs_sync_resolve_path() {
	local arg="${1:-}"
	if [ -z "$arg" ]; then
		local sd
		if sd="$(cs_stack_detect_current 2>/dev/null | sed -n '1p')" && [ -n "$sd" ]; then
			echo "$sd"
		else
			pwd
		fi
	elif [ -d "$arg" ]; then
		cs_abspath "$arg"
	else
		cs_find "$arg" || return 1
	fi
}

# Is <path> a stack root (a `stack_<branch>` directory)?
cs_sync_is_stack() {
	case "$(basename "$1")" in stack_*) [ -d "$1" ] ;; *) return 1 ;; esac
}

# First repo dir inside a stack (for repo-id-based host/config resolution).
cs_sync_stack_first_repo() {
	local d
	for d in "$1"/*; do
		if [ -e "$d/.git" ]; then echo "$d"; return 0; fi
	done
	return 1
}

# Validate a single-repo codespace dir and print its metadata as 4 lines:
# branch, repo_id, kind, dest_rel. Args: repo_dir
cs_sync_repo_meta() {
	local repo_dir="$1"
	if cs_remote_marker "$repo_dir"; then
		>&2 echo "err: '$repo_dir' is a remote codespace stub; nothing local to sync"
		return 1
	fi
	if ! git -C "$repo_dir" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
		>&2 echo "err: '$repo_dir' is not a git working tree"
		return 1
	fi
	local branch repo_id kind dest_rel
	branch="$(git -C "$repo_dir" symbolic-ref --short HEAD 2>/dev/null)" || {
		>&2 echo "err: '$repo_dir' is not on a branch (detached HEAD)"
		return 1
	}
	repo_id="$(cd "$repo_dir" && cs_repo_id)" || return 1
	if [ -n "$(cs_clone_marker "$repo_dir")" ]; then kind="clone"; else kind="worktree"; fi
	dest_rel="$(cs_remote_relpath_for_local "$(cs_abspath "$repo_dir")")" || return 1
	printf '%s\n%s\n%s\n%s\n' "$branch" "$repo_id" "$kind" "$dest_rel"
}


###################################
#                                 #
#  first-sync provisioning        #
#                                 #
###################################

# Provision (or re-provision) the remote codespace from the sync side: host prep
# (self-install + probe, once per stack) + config rsync, then delegate the
# create/repair + ship + bootstrap + post-create to the shared cs_remote_init_repo
# primitive. Leaves a git checkout on the branch ready for commit alignment.
# Args: host, repo_id, branch, dest_rel, kind, base_rel, repo_dir, [health]
#   health: ok|absent|broken, the classification the caller already made; passed
#           through so the primitive doesn't re-run the health round-trip.
cs_sync_provision() {
	local host="$1" repo_id="$2" branch="$3" dest_rel="$4" kind="$5" base_rel="$6" repo_dir="$7"
	local health="${8:-absent}"
	local base_repo cfg_rel clone_url=""

	case "$health" in
	absent) >&2 echo "==> [$host] remote codespace absent; provisioning ~/$dest_rel" ;;
	broken) : ;; # the primitive announces the repair
	*)      >&2 echo "==> [$host] re-running remote setup for ~/$dest_rel" ;;
	esac

	# host-scoped steps run once per sync; a stack sets CS_SYNC_HOST_READY so the
	# per-repo loop doesn't reinstall/reprobe for every repo.
	if [ -z "${CS_SYNC_HOST_READY:-}" ]; then
		cs_remote_self_install "$host"
		cs_remote_probe "$host"
	fi
	cfg_rel="$(cs_rsync_config_to_remote "$host" "$repo_id" | head -n1)"
	base_repo="$(cd "$repo_dir" && cs_abs_path_base_repo)"

	if [ "$kind" = "clone" ]; then
		clone_url="$(git -C "$repo_dir" remote get-url origin 2>/dev/null)" || clone_url=""
		test -n "$clone_url" || { >&2 echo "err: cannot infer clone URL for '$repo_dir'"; return 1; }
	fi

	cs_remote_init_repo "$host" "$repo_id" "$branch" "$dest_rel" "$kind" \
		"$base_rel" "$base_repo" "$cfg_rel" "$clone_url" "" "$health"
}

# init-local: materialize the LOCAL worktree for a codespace that so far exists
# only on the remote (a `create -r` .codespace-remote stub), so a normal sync has
# a local side to work with. Direction-aware counterpart of cs_sync_provision.
#
# Correctness hazard (why we seed from the remote, not origin): a create -r remote
# may hold commits/work that never reached origin. A fresh local worktree off
# origin/<branch> would be *behind*, and sync's "local is canonical" alignment
# would then reset the remote and LOSE those commits. So after materializing the
# worktree we fetch the remote's current branch tip and hard-reset the local
# worktree onto it -- local == remote before normal sync resumes.
# Args: stub_dir, host
cs_sync_init_local() {
	local stub_dir="$1" host="$2"
	local branch repo_id kind dest_rel base_repo clone_url

	branch="$(cs_remote_marker_get "$stub_dir" branch)"
	repo_id="$(cs_remote_marker_get "$stub_dir" repo_id)"
	kind="$(cs_remote_marker_get "$stub_dir" kind)"
	dest_rel="$(cs_remote_marker_get "$stub_dir" relpath)"
	[ -n "$kind" ] || kind=worktree
	[ -n "$dest_rel" ] || dest_rel="$(cs_remote_relpath_for_local "$(cs_abspath "$stub_dir")")"
	[ -n "$branch" ] && [ -n "$repo_id" ] || {
		>&2 echo "err: incomplete remote stub marker at $stub_dir (need branch + repo_id)"
		return 1
	}

	>&2 echo "==> [$host] bringing '$repo_id' local: materializing '$branch', seeding from the remote HEAD"

	# local base repo lives at $HOME/<repo_id> (the reverse of the relpath map).
	# For a create -r codespace it may not exist yet -> clone it from the remote's
	# origin URL.
	base_repo="$HOME/$repo_id"
	if [ ! -d "$base_repo/.git" ]; then
		clone_url="$(cs_ssh_script "$host" "codespace/$repo_id" <<'REMOTE'
git -C "$HOME/$1" remote get-url origin 2>/dev/null || true
REMOTE
)"
		[ -n "$clone_url" ] || {
			>&2 echo "err: cannot infer clone URL for '$repo_id' from the remote"
			return 1
		}
		>&2 echo "==> cloning local base repo: $clone_url -> $base_repo"
		mkdir -p "$(dirname "$base_repo")"
		git clone "$clone_url" "$base_repo" >&2 || return 1
	fi

	# the stub holds only markers (no code) -> clear it so the worktree can be
	# created in place, then materialize the worktree off the base repo.
	rm -rf "$stub_dir"
	cs_create_worktree_core "$branch" "$base_repo" "$stub_dir" >/dev/null || return 1

	# seed from the remote's current HEAD (see the hazard note above).
	if GIT_SSH_COMMAND="ssh $(cs_ssh_opts)" \
		git -C "$stub_dir" fetch --no-tags "$host:$dest_rel" \
			"+refs/heads/$branch:refs/cs-sync/seed" 2>/dev/null; then
		git -C "$stub_dir" reset --hard refs/cs-sync/seed >&2 || return 1
		git -C "$stub_dir" update-ref -d refs/cs-sync/seed 2>/dev/null || true
	else
		>&2 echo "note: no remote '$branch' to seed from; local starts at the base ref"
	fi

	# convert the remote-only stub into a synced local codespace: the fresh
	# worktree replaced the .codespace-remote marker, so record .codespace/sync
	# (local == remote, so this HEAD is the fork point for the next sync).
	cs_sync_marker_write "$stub_dir" \
		"host=$host" \
		"relpath=$dest_rel" \
		"kind=$kind" \
		"branch=$branch" \
		"synced_commit=$(git -C "$stub_dir" rev-parse HEAD)" \
		"synced_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}


###################################
#                                 #
#  uncommitted resolution         #
#                                 #
###################################

# Decide + enact how to handle uncommitted changes. Prints the resulting mode for
# the orchestrator: one of `proceed`, `overlay`, `watch`. Returns non-zero to
# abort. (No mutagen probe here: a plain sync never needs it -- only --watch
# does, and the watch layer ensures/installs mutagen itself, degrading to a
# one-shot if unavailable.)
# Args: host dest_rel repo_dir branch local_dirty remote_dirty sync_mode live
cs_sync_resolve_uncommitted() {
	local host="$1" dest_rel="$2" repo_dir="$3" branch="$4"
	local local_dirty="$5" remote_dirty="$6" sync_mode="$7" live="$8"
	local interactive=""; [ -z "${CS_NO_INTERACTIVE:-}" ] && interactive=1

	while :; do
		local decision
		decision="$(cs_sync_decide_uncommitted "$local_dirty" "$remote_dirty" \
			"$sync_mode" "$live" "$interactive")"

		case "$decision" in
			proceed) echo proceed; return 0 ;;
			overlay) echo overlay; return 0 ;;
			merge)   echo merge;   return 0 ;;
			watch)   echo watch;   return 0 ;;
		esac
	done
}


###################################
#                                 #
#  orchestrator                   #
#                                 #
###################################

# Describe (for --dry-run) what the init gate would do, given the mode + health.
# Args: init health host dest_rel
cs_sync_report_init_dryrun() {
	local init="$1" health="$2" host="$3" dest_rel="$4"
	case "$init" in
	no)
		[ "$health" = ok ] || >&2 echo "[dry-run] --no-init: remote at ~/$dest_rel not provisioned ($health) -> would error" ;;
	force)
		>&2 echo "[dry-run] --init: would (re-)run remote setup at ~/$dest_rel (health=$health)" ;;
	*)
		case "$health" in
			ok)     : ;;
			absent) >&2 echo "[dry-run] would provision remote codespace at ~/$dest_rel" ;;
			broken) >&2 echo "[dry-run] would repair + reprovision broken remote codespace at ~/$dest_rel" ;;
		esac ;;
	esac
}

# Sync one single-repo codespace dir to host. Self-contained: resolves its own
# metadata, provisions if absent, resolves uncommitted, integrates commits,
# aligns the remote, overlays/watches per mode, ships config, records a marker.
# Return: 0 ok, 2 integration conflict (caller may report + continue), 1 error.
# Args: repo_dir host sync_mode live resolve dry_run [quiet] [stop_watch] [hard] [init]
#   init: auto (default) / force / no -- see the provisioning gate below.
cs_sync_repo() {
	local repo_dir="$1" host="$2" sync_mode="$3" live="$4" resolve="$5" \
		dry_run="$6" quiet="${7:-}" stop_watch="${8:-}" hard="${9:-}" init="${10:-auto}"

	# A create -r codespace is remote-only: a .codespace-remote stub with no local
	# worktree. Bring it local (materialize + seed from the remote) before the
	# normal flow, so cs_sync_repo_meta below sees a real working tree.
	if cs_remote_marker "$repo_dir" && [ ! -e "$repo_dir/.git" ]; then
		if [ "$init" = no ]; then
			>&2 echo "err: '$repo_dir' is a remote-only codespace; drop --no-init to bring it local (or run 'codespace open -r')"
			return 1
		fi
		if [ -n "$dry_run" ]; then
			>&2 echo "[dry-run] would materialize + seed a local worktree for remote-only codespace at $repo_dir"
			return 0
		fi
		cs_sync_init_local "$repo_dir" "$host" || return 1
	fi

	local branch repo_id kind dest_rel meta
	meta="$(cs_sync_repo_meta "$repo_dir")" || return 1
	branch="$(echo "$meta" | sed -n '1p')"
	repo_id="$(echo "$meta" | sed -n '2p')"
	kind="$(echo "$meta" | sed -n '3p')"
	dest_rel="$(echo "$meta" | sed -n '4p')"

	local base_rel
	if [ "$kind" = "clone" ]; then base_rel="$dest_rel"; else base_rel="codespace/$repo_id"; fi

	# One-time migration off the legacy post-commit hooks (both ends) that older
	# versions installed; the poll loop owns commit propagation now. Cheap + self-
	# limiting (no ssh unless a stale local hook is found). Read-only dry-runs skip.
	if [ -z "$dry_run" ] && command -v cs_sync_migrate_purge_hooks >/dev/null 2>&1; then
		cs_sync_migrate_purge_hooks "$host" "$dest_rel" "$repo_dir"
	fi

	if [ -n "$stop_watch" ]; then
		if command -v cs_sync_watch_stop >/dev/null 2>&1; then
			cs_sync_watch_stop "$repo_dir" "$repo_id" "$branch"
		else
			>&2 echo "err: live sync (--stop-watch) requires the codespace-sync-watch component"
			return 1
		fi
		return 0
	fi

	[ -n "$quiet" ] || >&2 echo "==> syncing $kind '$branch' ($repo_dir) -> $host:~/$dest_rel"

	# Ensure a key is in the local ssh-agent so the remote can authenticate to
	# the code host (via forwarding) for clone/fetch. Best-effort; memoized so
	# it stays cheap across a stack's repos.
	[ -n "$dry_run" ] || cs_ensure_agent_key "$repo_id"

	# Ensure the remote is a healthy checkout before touching it, gated on the
	# requested init mode:
	#   auto  (default) -> init only when the remote is absent/broken (a routine
	#                      sync of a healthy remote skips setup, incl. dep install).
	#   force           -> re-run remote setup even when it's already healthy
	#                      (e.g. deps changed); create/repair still idempotent.
	#   no              -> never provision (code-only); error if it isn't ready.
	# A failed provision/repair (e.g. the base clone couldn't authenticate) aborts
	# this repo's sync here rather than cascading into ship/integrate/align/watch
	# against a missing/broken path. `broken` is repaired in place when possible,
	# else archived aside (never deleted) and reprovisioned -- all inside the
	# shared cs_remote_init_repo primitive.
	local health
	health="$(cs_sync_remote_health "$host" "$dest_rel" "$base_rel" "$kind")" || health=broken
	if [ -n "$dry_run" ]; then
		cs_sync_report_init_dryrun "$init" "$health" "$host" "$dest_rel"
	elif [ "$init" = no ]; then
		if [ "$health" != ok ]; then
			>&2 echo "err: [$host] remote codespace at ~/$dest_rel is not provisioned ($health);"
			>&2 echo "  drop --no-init (or run 'codespace open -r') to set it up first."
			return 1
		fi
	elif [ "$init" = force ] || [ "$health" != ok ]; then
		cs_sync_provision "$host" "$repo_id" "$branch" "$dest_rel" "$kind" "$base_rel" "$repo_dir" "$health" || return 1
	fi

	local local_dirty="" remote_dirty=""
	cs_sync_local_dirty "$repo_dir" && local_dirty=1
	if cs_sync_remote_exists "$host" "$dest_rel"; then
		cs_sync_remote_dirty "$host" "$dest_rel" && remote_dirty=1
	fi

	if [ -n "$dry_run" ]; then
		>&2 echo "[dry-run] $repo_id: local_dirty=${local_dirty:-no} remote_dirty=${remote_dirty:-no} resolve=${resolve:-auto}"
		>&2 echo "[dry-run] would integrate commits, align remote, write .codespace/sync"
		return 0
	fi

	local mode
	mode="$(cs_sync_resolve_uncommitted "$host" "$dest_rel" "$repo_dir" "$branch" \
		"$local_dirty" "$remote_dirty" "$sync_mode" "$live")" || return 1
	cs_sync_local_dirty "$repo_dir" && local_dirty=1 || local_dirty=""
	cs_sync_remote_dirty "$host" "$dest_rel" && remote_dirty=1 || remote_dirty=""

	# If a live (mutagen) session is running, freeze it so the git history ops
	# below don't race the filewatcher over the same files.
	local live_active="" remote_stashed=""
	if command -v cs_sync_watch_active >/dev/null 2>&1 && cs_sync_watch_active "$repo_id" "$branch"; then
		live_active=1
		cs_sync_watch_pause "$repo_id" "$branch"
	fi

	# Protect the remote's uncommitted remainder from being clobbered by an align
	# reset/rebase, then restore it after so the live session reconciles it. The
	# remote may be dirty under a live session (watch), under --mode=commits
	# (which leaves uncommitted work untouched), or on the very first --watch, so
	# stash it whenever present. (commit-during-live: a partial commit's
	# remainder is preserved on both ends.)
	[ -n "$remote_dirty" ] && cs_sync_remote_stash_push "$host" "$dest_rel" && remote_stashed=1 || true

	# Stash any remaining local uncommitted work so ff/rebase has a clean tree.
	local stashed=""
	if [ -n "$local_dirty" ]; then
		git -C "$repo_dir" stash push -u -q -m "cs-sync auto-stash" >&2 && stashed=1 || stashed=""
	fi
	# Integrate commits using the prior synced_commit as the fork point. When
	# both sides advanced the integrator prompts (if interactive); its stdout
	# carries the align token (`reset` -> align must hard-reset the remote to
	# local HEAD, backing up the old remote tip).
	local synced_prev interactive="" integ align_reset=""
	synced_prev="$(cs_sync_marker_get "$repo_dir" synced_commit)"
	[ -z "${CS_NO_INTERACTIVE:-}" ] && interactive=1
	if ! integ="$(cs_sync_integrate_local "$host" "$dest_rel" "$branch" "$repo_dir" \
		"$resolve" "$synced_prev" "$interactive" "$hard")"; then
		[ -n "$stashed" ] && >&2 echo "note: your uncommitted changes are saved in 'git stash' (git stash pop)"
		[ -n "$live_active" ] && cs_sync_watch_resume "$repo_id" "$branch"
		return 2
	fi
	[ "$integ" = reset ] && align_reset=1
	[ -n "$stashed" ] && git -C "$repo_dir" stash pop -q >&2 || true

	if ! cs_sync_align_remote "$host" "$dest_rel" "$branch" "$repo_dir" "$base_rel" "$align_reset"; then
		[ -n "$remote_stashed" ] && cs_sync_remote_stash_pop "$host" "$dest_rel"
		[ -n "$live_active" ] && cs_sync_watch_resume "$repo_id" "$branch"
		>&2 echo "err: [$host] failed to align remote '$repo_id' (remote not a healthy codespace); skipping watch/ship for it"
		return 1
	fi

	[ -n "$remote_stashed" ] && cs_sync_remote_stash_pop "$host" "$dest_rel"
	[ -n "$live_active" ] && cs_sync_watch_resume "$repo_id" "$branch"

	case "$mode" in
		merge)
			local merged_tree marker_paths
			merged_tree="$(cs_sync_merge_dirty "$host" "$dest_rel" "$repo_dir" "$branch" \
				"$resolve" "$hard" "$local_dirty" "$remote_dirty")" || return 1
			marker_paths="$(cs_sync_dirty_merged_markers "$repo_dir" "$merged_tree")"
			cs_sync_overlay "$host" "$dest_rel" "$repo_dir"
			cs_sync_dirty_record_synced "$repo_dir" "$(git -C "$repo_dir" rev-parse HEAD)" \
				"$merged_tree" "$marker_paths"
			mode=overlay ;;
		overlay) cs_sync_overlay "$host" "$dest_rel" "$repo_dir" ;;
		watch)
			local wrc=0 merged_tree marker_paths
			if command -v cs_sync_watch_start >/dev/null 2>&1; then
				cs_sync_watch_start "$host" "$dest_rel" "$repo_dir" "$repo_id" "$branch" || wrc=$?
			else
				wrc=1
			fi
			if [ "$wrc" = 0 ]; then
				cs_sync_watch_resolve_conflicts "$host" "$dest_rel" "$repo_dir" "$repo_id" \
					"$branch" "$resolve" "$hard" || true
			elif [ "$wrc" = 2 ]; then
				>&2 echo "note: leaving uncommitted changes local-only; committed history is synced."
				mode=commit
			elif [ -n "$local_dirty" ] || [ -n "$remote_dirty" ]; then
				if [ -n "$remote_dirty" ]; then
					>&2 echo "note: live sync unavailable; falling back to a one-shot dirty merge"
					merged_tree="$(cs_sync_merge_dirty "$host" "$dest_rel" "$repo_dir" "$branch" \
						"$resolve" "$hard" "$local_dirty" "$remote_dirty")" || return 1
					marker_paths="$(cs_sync_dirty_merged_markers "$repo_dir" "$merged_tree")"
					cs_sync_overlay "$host" "$dest_rel" "$repo_dir"
					cs_sync_dirty_record_synced "$repo_dir" "$(git -C "$repo_dir" rev-parse HEAD)" \
						"$merged_tree" "$marker_paths"
				else
					>&2 echo "note: live sync unavailable; falling back to a one-shot overlay"
					cs_sync_overlay "$host" "$dest_rel" "$repo_dir"
				fi
				mode=overlay
			else
				>&2 echo "note: persistent watch needs mutagen; committed history synced (nothing uncommitted to mirror)."
				mode=commit
			fi ;;
	esac

	# Re-ship config files (gitignored symlinks) so edited sources propagate.
	local base_repo manifest
	base_repo="$(cd "$repo_dir" && cs_abs_path_base_repo)"
	manifest="$(cs_collect_remote_files "$base_repo")"
	cs_ship_files_to_remote "$host" "$dest_rel" "$manifest" "$repo_id" "$base_repo"
	rm -f "$manifest"

	# Record the resulting mode in the marker (informational; `codespace ls`
	# shows a 'live' badge). `live` only ever appears under --watch -- a plain
	# sync is a one-shot, never sticky. (distinct from the `sync_mode` arg, which
	# is the requested dirty|commits.)
	local synced_commit record_mode="commit" mutagen_session=""
	synced_commit="$(git -C "$repo_dir" rev-parse HEAD)"
	case "$mode" in overlay) record_mode="overlay" ;; watch) record_mode="live" ;; esac
	if [ "$record_mode" != "overlay" ] \
		&& command -v cs_sync_watch_active >/dev/null 2>&1 \
		&& cs_sync_watch_active "$repo_id" "$branch"; then
		record_mode="live"
		mutagen_session="$(cs_sync_watch_session_name "$repo_id" "$branch")"
	fi

	local -a marker_kv=(
		"host=$host" "relpath=$dest_rel" "kind=$kind" "repo_id=$repo_id"
		"branch=$branch" "synced_commit=$synced_commit"
		"synced_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)" "sync_mode=$record_mode"
	)
	[ -n "$mutagen_session" ] && marker_kv+=("mutagen_session=$mutagen_session")
	# marker_write truncates+rewrites, so carry forward a detached watch's pid
	# (a commit integrate triggered by that watch's own poll loop runs through
	# here -- losing the pid would orphan it from --stop).
	local prev_watch_pid; prev_watch_pid="$(cs_sync_marker_get "$repo_dir" watch_pid)"
	[ -n "$prev_watch_pid" ] && marker_kv+=("watch_pid=$prev_watch_pid")
	cs_sync_marker_write "$repo_dir" "${marker_kv[@]}"

	[ -n "$quiet" ] || >&2 echo "==> synced $branch -> $host:~/$dest_rel (commit ${synced_commit:0:9}, mode=$record_mode)"
}

# Stash the remote worktree's uncommitted remainder (so an align reset/rebase
# doesn't clobber it). Returns 0 only if something was actually stashed.
# Args: host, dest_rel
cs_sync_remote_stash_push() {
	cs_ssh_script "$1" "$2" <<'REMOTE'
set -eu
cd "$HOME/$1"
before="$(git stash list 2>/dev/null | wc -l)"
git stash push -u -q -m "cs-sync auto-stash" >/dev/null 2>&1 || true
after="$(git stash list 2>/dev/null | wc -l)"
[ "$after" -gt "$before" ]
REMOTE
}

# Re-apply the remote worktree's stashed remainder. A plain 3-way `stash pop`
# works for the no-commit case; when a partial commit was just integrated, the
# committed subset collides with the stash's 3-way apply, so we fall back to
# overwriting tracked paths from the stash (committed-identical files are a
# no-op, the genuine remainder reapplies). Anything still unresolved stays
# recoverable in the stash and mutagen re-mirrors it from local. Args: host, dest_rel
cs_sync_remote_stash_pop() {
	cs_ssh_script "$1" "$2" <<'REMOTE'
set -eu
cd "$HOME/$1"
git rev-parse --verify --quiet refs/stash >/dev/null 2>&1 || exit 0
if git stash pop -q 2>/dev/null; then exit 0; fi
# 3-way pop collided with the just-integrated commit; restore the stash's
# tracked content directly (committed-identical paths are a no-op) and drop it.
git checkout stash@{0} -- . 2>/dev/null || true
git stash drop -q 2>/dev/null || true
REMOTE
}

# rsync the stack root's top-level loose files (regular files only -- repo dirs
# are synced via git; symlinks are re-created by the remote stack-post-create).
# Args: host, stack_dest_rel, stack_dir
cs_sync_stack_loose_files() {
	local host="$1" dest_rel="$2" stack_dir="$3" f base
	local files=()
	for f in "$stack_dir"/*; do
		[ -f "$f" ] && [ ! -L "$f" ] || continue
		base="$(basename "$f")"
		[ "$base" = "open" ] && continue
		files+=("$f")
	done
	[ ${#files[@]} -gt 0 ] || return 0
	>&2 echo "==> [$host] syncing ${#files[@]} stack-root file(s)"
	cs_rsync_to_remote "$host" "${files[@]}" "$dest_rel/"
}

# Sync a multi-repo stack: host prep once, then per-repo commit-sync, then the
# stack-root loose files + a stack-root marker. Per-repo conflicts are collected
# and reported without aborting the whole stack.
# Args: stack_dir host sync_mode live resolve dry_run [stop_watch] [hard] [init]
cs_sync_stack() {
	local stack_dir="$1" host="$2" sync_mode="$3" live="$4" resolve="$5" \
		dry_run="$6" stop_watch="${7:-}" hard="${8:-}" init="${9:-auto}"
	local branch stack_dest_rel
	branch="$(basename "$stack_dir")"; branch="${branch#stack_}"
	stack_dest_rel="$(cs_remote_relpath_for_local "$stack_dir")"

	>&2 echo "==> syncing stack '$branch' ($stack_dir) -> $host:~/$stack_dest_rel"

	if [ -z "$dry_run" ] && [ -z "$stop_watch" ]; then
		cs_remote_self_install "$host"
		cs_remote_probe "$host"
		export CS_SYNC_HOST_READY=1
		cs_ssh_script "$host" "$stack_dest_rel" <<'REMOTE'
set -eu
mkdir -p "$HOME/$1"
REMOTE
	fi

	# A create -r stack is remote-only: its repo dirs are .codespace-remote stubs
	# with no local worktree. Bring each one local (materialize + seed from the
	# remote) before syncing, so the loop below finds real working trees.
	if [ -z "$dry_run" ] && [ -z "$stop_watch" ]; then
		local sd stubbed=""
		for sd in "$stack_dir"/*; do
			[ -d "$sd" ] && cs_remote_marker "$sd" && [ ! -e "$sd/.git" ] && { stubbed=1; break; }
		done
		if [ -n "$stubbed" ]; then
			if [ "$init" = no ]; then
				>&2 echo "err: [$host] stack '$branch' is a remote-only codespace (no local worktrees);"
				>&2 echo "  drop --no-init to bring it local."
				return 1
			fi
			for sd in "$stack_dir"/*; do
				[ -d "$sd" ] && cs_remote_marker "$sd" && [ ! -e "$sd/.git" ] || continue
				cs_sync_init_local "$sd" "$host" || return 1
			done
			# the stack is now a synced local codespace; drop the stack-level stub
			# so opens/ls stop treating it as remote-only (sync writes .codespace/sync).
			rm -f "$stack_dir/.codespace-remote"
		fi
	fi

	local repos=() d
	for d in "$stack_dir"/*; do
		[ -e "$d/.git" ] || continue
		repos+=("$d")
	done

	local failures=() conflicts=() r rc
	for r in "${repos[@]}"; do
		if cs_sync_repo "$r" "$host" "$sync_mode" "$live" "$resolve" "$dry_run" 1 "$stop_watch" "$hard" "$init"; then
			:
		else
			rc=$?
			if [ "$rc" = 2 ]; then conflicts+=("$(basename "$r")"); else failures+=("$(basename "$r")"); fi
		fi
	done
	unset CS_SYNC_HOST_READY

	[ -n "$stop_watch" ] && { >&2 echo "==> stopped live sync for stack '$branch'"; return 0; }

	if [ -z "$dry_run" ]; then
		cs_sync_stack_loose_files "$host" "$stack_dest_rel" "$stack_dir"
		cs_sync_marker_write "$stack_dir" \
			"host=$host" \
			"relpath=$stack_dest_rel" \
			"kind=stack" \
			"branch=$branch" \
			"synced_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
	fi

	if [ ${#conflicts[@]} -gt 0 ] || [ ${#failures[@]} -gt 0 ]; then
		>&2 echo "==> stack '$branch' synced with issues:"
		[ ${#conflicts[@]} -gt 0 ] && >&2 echo "  conflicts (resolve in the repo, then re-run): ${conflicts[*]}"
		[ ${#failures[@]} -gt 0 ] && >&2 echo "  failed: ${failures[*]}"
		return 1
	fi
	[ -n "$dry_run" ] || >&2 echo "==> stack synced: $branch -> $host:~/$stack_dest_rel (${#repos[@]} repos)"
}

cs_sync() {
	# Internal entrypoint for a detached watch: `codespace sync __watch_loop
	# <path> <host> <mode>` re-enters here in the spawned background process and
	# runs the poll loop directly, bypassing arg-parsing + the watch-active guard.
	if [ "${1:-}" = __watch_loop ]; then
		shift
		command -v cs_sync_watch_loop >/dev/null 2>&1 || return 1
		cs_sync_watch_loop "$@"
		return $?
	fi

	local arg="" host="" sync_mode="dirty" live="" resolve="" dry_run="" stop_watch="" detach="" hard="" init="auto"
	while [ $# -gt 0 ]; do
		case "$1" in
			-h|--help) echo "$SYNC_HELP"; return 0 ;;
			-r|--remote)
				shift
				if [ $# -gt 0 ] && [ "${1#-}" = "$1" ]; then host="$1"; shift
				else host="$CS_REMOTE_USE_DEFAULT"; fi ;;
			-m|--mode) shift; sync_mode="${1:-}"; [ $# -gt 0 ] && shift ;;
			--mode=*) sync_mode="${1#--mode=}"; shift ;;
			-m=*) sync_mode="${1#-m=}"; shift ;;
			--once) >&2 echo "note: --once is the default now (a plain sync is one-shot); ignoring." ; shift ;;
			-w|--watch) live=1; shift ;;
			-d|--detach) detach=1; shift ;;
			--stop|--stop-watch) stop_watch=1; shift ;;
			--ours)   if [ -n "$resolve" ] && [ "$resolve" != ours ]; then >&2 echo "err: --ours and --theirs are mutually exclusive"; return 1; fi; resolve=ours; shift ;;
			--theirs) if [ -n "$resolve" ] && [ "$resolve" != theirs ]; then >&2 echo "err: --ours and --theirs are mutually exclusive"; return 1; fi; resolve=theirs; shift ;;
			--hard) hard=1; shift ;;
			--init) init="$(cs_parse_init_spec "")" || return 1; shift ;;
			--init=*) init="$(cs_parse_init_spec "${1#--init=}")" || return 1; shift ;;
			--no-init) init=no; shift ;;
			--dry-run) dry_run=1; shift ;;
			-*) >&2 echo "err: unknown flag: $1"; return 1 ;;
			*) arg="$1"; shift ;;
		esac
	done

	# validate + normalize the mode (accepting the d/c shorthands). --watch/
	# --detach work in BOTH modes (dirty: live working-tree + commit sync;
	# commits: continuously sync each new commit, leaving the tree local).
	case "$sync_mode" in
		d|dirty) sync_mode=dirty ;;
		c|commits) sync_mode=commits ;;
		*) >&2 echo "err: --mode must be 'dirty' (d) or 'commits' (c) (got '$sync_mode')"; return 1 ;;
	esac
	if [ -n "$hard" ] && [ -z "$resolve" ]; then
		>&2 echo "err: --hard only applies with --ours or --theirs."
		return 1
	fi
	if [ -n "$detach" ] && [ -z "$live" ]; then
		>&2 echo "note: --detach only applies with --watch; ignoring."
		detach=""
	fi

	local path
	path="$(cs_sync_resolve_path "$arg")" || return 1

	# Refuse to start a second sync/watch over a codespace that already has a
	# watch running (a live background poller or mutagen session) -- two syncs
	# racing the same tree would corrupt state. --stop is exempt (it's how you
	# clear it); dry-runs are read-only so they're fine.
	if [ -z "$stop_watch" ] && [ -z "$dry_run" ] \
		&& command -v cs_sync_watch_running >/dev/null 2>&1 \
		&& cs_sync_watch_running "$path"; then
		>&2 echo "err: a watch is already running for this codespace."
		>&2 echo "  stop it first: codespace sync --stop"
		return 1
	fi

	# Resolve the target host: explicit value wins, else the prior marker at the
	# target, else $CS_DEFAULT_REMOTE / a .codespace/remote config file.
	if [ -z "$host" ] || [ "$host" = "$CS_REMOTE_USE_DEFAULT" ]; then
		local mh resolve_dir="$path"
		mh="$(cs_sync_marker_get "$path" host)"
		# a remote-only stub (create -r, not yet brought local) records its host
		# in the .codespace-remote marker rather than .codespace/sync.
		[ -n "$mh" ] || mh="$(cs_remote_marker_get "$path" host)"
		if [ -n "$mh" ]; then
			host="$mh"
		else
			cs_sync_is_stack "$path" && resolve_dir="$(cs_sync_stack_first_repo "$path")" || true
			host="$(cd "${resolve_dir:-$path}" 2>/dev/null && cs_resolve_remote "")" || {
				>&2 echo "err: no remote host (pass -r <host>, set \$CS_DEFAULT_REMOTE, or a .codespace/remote file)"
				return 1
			}
		fi
	fi

	# --stop: kill any detached background poller recorded for this codespace
	# before the dispatch tears down its mutagen session(s) + clears the marker.
	if [ -n "$stop_watch" ] && command -v cs_sync_watch_stop_pid >/dev/null 2>&1; then
		cs_sync_watch_stop_pid "$path"
	fi

	# Serialize syncs of the same codespace so a watch-loop-triggered commit sync
	# can't race a manual one (concurrent git stash/rebase on the same tree would
	# corrupt state). Read-only dry-runs don't need it.
	local lock=""
	if [ -z "$dry_run" ]; then
		lock="$(cs_sync_lock_acquire "$path")" || {
			>&2 echo "note: another 'codespace sync' is in progress for $path; skipping."
			return 0
		}
	fi

	local rc=0
	if cs_sync_is_stack "$path"; then
		cs_sync_stack "$path" "$host" "$sync_mode" "$live" "$resolve" "$dry_run" "$stop_watch" "$hard" "$init" || rc=$?
	else
		cs_sync_repo "$path" "$host" "$sync_mode" "$live" "$resolve" "$dry_run" "" "$stop_watch" "$hard" "$init" || rc=$?
	fi
	[ -n "$lock" ] && rm -rf "$lock" 2>/dev/null

	# Watch lifecycle: AFTER releasing the lock (so the loop's own commit syncs
	# can take it). Foreground attaches + blocks until Ctrl-C; --detach spawns a
	# background poller and returns. Skipped for dry-runs / --stop / failures.
	if [ -n "$live" ] && [ -z "$dry_run" ] && [ -z "$stop_watch" ] && [ "$rc" -eq 0 ] \
		&& command -v cs_sync_watch_supervise >/dev/null 2>&1; then
		cs_sync_watch_supervise "$path" "$host" "$sync_mode" "$detach"
	fi
	return $rc
}

# Per-codespace cross-process lock (mkdir is atomic). Waits up to ~30s for a
# held lock, stealing one left stale (>10min) by a crashed run. Stored outside
# the worktree (keyed by path checksum) so it never shows as untracked.
# Args: path  -> stdout: lock dir on success; returns 1 if it couldn't acquire.
cs_sync_lock_acquire() {
	local key lock canon
	# Canonicalize first: pwd / cs_find can hand us a logical path (e.g.
	# /var/folders vs /private/var/folders, a trailing slash, a symlink) that
	# would hash differently for the same codespace and so fail to serialize a
	# hook-triggered background sync against a manual one.
	canon="$(cs_abspath "$1" 2>/dev/null)" || canon=""
	[ -n "$canon" ] || canon="$1"
	key="$(printf '%s' "$canon" | cksum | cut -d' ' -f1)"
	lock="${TMPDIR:-/tmp}/cs-sync-lock-$key"
	for _ in $(seq 1 60); do
		if mkdir "$lock" 2>/dev/null; then echo "$lock"; return 0; fi
		if [ -d "$lock" ] && [ -n "$(find "$lock" -maxdepth 0 -mmin +10 2>/dev/null)" ]; then
			rm -rf "$lock" 2>/dev/null || true
			continue
		fi
		sleep 0.5
	done
	return 1
}

SYNC_HELP="\
Usage:
codespace sync [<branch|path>] [-r [host]] [-m|--mode dirty|commits] [-w|--watch [-d|--detach] | --stop] [--ours | --theirs] [--hard] [--init[=force|auto|no] | --no-init] [--dry-run]

Mirror a local codespace to a remote ssh host. Safe to re-run: every sync
integrates commit history both ways (local is canonical on divergence) and, by
default, also mirrors the uncommitted working tree.

Commit history is reconciled against the last synced commit (the fork point):
if only one side advanced it's taken automatically; if both advanced you choose
the resolution (rebase by default, or --ours/--theirs). Pass --watch to keep
syncing continuously instead of just once.

args:
  <branch|path>    codespace to sync (default: the one at the current dir).

flags:
  -r, --remote [host]   target host. default: the prior target recorded in
                        .codespace/sync, else \$CS_DEFAULT_REMOTE / a
                        .codespace/remote config file.

  -m, --mode <mode>     what to sync (default: dirty). accepts a short alias:
                          dirty (d)    uncommitted working tree (live mutagen
                                       session if available, else a one-shot rsync
                                       overlay) + commit history.
                          commits (c)  commit history only; uncommitted work is
                                       left untouched (local-only).

  -w, --watch           keep syncing as you work, staying in the foreground until
                        stopped (Ctrl-C). engages even on a clean tree, so it
                        waits for changes (e.g. before letting an agent run). new
                        commits are carried by a cheap HEAD poll in either mode;
                        in --mode=dirty a live (mutagen) session additionally
                        mirrors the uncommitted tree both ways (offering to
                        install mutagen if missing, else degrading to a one-shot).
                        only one watch may run per codespace at a time.
  -d, --detach          with --watch: set it up and return instead of staying in
                        the foreground -- it keeps running as a background process
                        (end it with --stop).
  --stop, --stop-watch  stop watching this codespace: kill the background watch
                        process and terminate any live session.

  --init[=<mode>]       (re-)provision the remote (create + install deps) before
                        syncing. default: auto -- provision only when the remote
                        is absent/broken; a healthy remote is left as-is. bare
                        --init (== --init=force) re-runs remote setup even when
                        it's already healthy (e.g. deps changed); create/repair
                        stay idempotent. last occurrence wins.
  --no-init             don't provision: sync code only, and error clearly if the
                        remote isn't set up yet (alias for --init=no). pair with a
                        later plain sync to \"spin up deps later\".

  --dry-run             print the plan; mutate nothing.

resolving divergence (--ours / --theirs / --hard):
  used when both sides gained commits since the last sync. resolution is granular
  by default: a rebase that keeps BOTH sides' commits and auto-decides only the
  conflicting hunks toward your chosen side (nothing is discarded).
  --ours / --theirs   which side wins conflicts (mirror opposites): --ours keeps
                      local, --theirs keeps the remote tip. granular by default.
  --hard              wholesale instead of granular: the chosen side wins exactly
                      and the other side's divergent commits are backed up and
                      dropped.

uncommitted (dirty) work (--mode=dirty):
  reconciled at the CONTENT level via the same --ours/--theirs/--hard policy.
  different files or different hunks in the same file are kept from both sides;
  only a same-hunk clash needs a decision. with no policy, identical conflict
  markers are written to both working trees (non-fatal -- resolve on either side
  and re-run to propagate). works the same one-shot and under --watch (mutagen
  mirrors non-clashing files; same-file clashes route through the merge above).
  uncommitted work is never committed: it is stashed around commit integration
  and re-applied, never discarded. --mode=commits skips dirty reconciliation.
  residual edge: mutagen's whole-file mirror can differ from git's 3-way merge
  on renames, file modes/symlinks, and some modify/delete pairings.
"

cs_sync_main() {
	case "${1:-}" in
		-h|--help) echo "$SYNC_HELP"; return 0 ;;
	esac
	cs_sync "$@"
}

test -n "${CS_SYNC_NO_RUN:-}" || {
	cs_sync_main "$@"
	exit $?
}
