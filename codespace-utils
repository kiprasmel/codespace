#!/usr/bin/env bash

# shared utilities for codespace scripts
# this file should be sourced, not executed directly.

# auto-detect agent environments and disable interactive prompts
test -n "${CS_NO_INTERACTIVE:-}" || {
	test -n "${CURSOR_AGENT:-}" || test -n "${CI:-}" && {
		export CS_NO_INTERACTIVE=1
	}
}

# CS_NO_INTERACTIVE implies CS_NO_EDIT (no GUI editor in non-interactive contexts)
test -z "${CS_NO_INTERACTIVE:-}" || export CS_NO_EDIT=1

# sanitize string for use in directory/file names
cs_cleanpath() {
	echo "$1" | tr '/: ' '_'
}

# Extract repo name from clone URL
# git@github.com:org/repo.git -> repo
# https://github.com/org/repo.git -> repo
cs_repo_name_from_url() {
	url="$1"
	basename "$url" .git
}

# Extract a GitHub "owner/repo" slug from a remote URL. Returns non-zero for
# non-github.com remotes (callers fall back to local git heuristics).
# git@github.com:org/repo.git        -> org/repo
# https://github.com/org/repo.git    -> org/repo
# ssh://git@github.com/org/repo       -> org/repo
cs_gh_slug_from_url() {
	local url="${1%.git}"
	case "$url" in
		*github.com[:/]*) ;;
		*) return 1 ;;
	esac
	local rest owner repo
	rest="${url#*github.com}"
	rest="${rest#[:/]}"
	case "$rest" in */*) ;; *) return 1 ;; esac
	owner="${rest%%/*}"
	rest="${rest#*/}"
	repo="${rest%%/*}"
	[ -n "$owner" ] && [ -n "$repo" ] || return 1
	echo "$owner/$repo"
}

# Format a byte count as a short, human-friendly size (1.2G, 340M, 12K, 5B).
cs_format_size() {
	local bytes="${1:-0}"
	if   [ "$bytes" -ge 1073741824 ]; then awk -v b="$bytes" 'BEGIN{printf "%.1fG", b/1073741824}'
	elif [ "$bytes" -ge 1048576 ];    then awk -v b="$bytes" 'BEGIN{printf "%.1fM", b/1048576}'
	elif [ "$bytes" -ge 1024 ];       then awk -v b="$bytes" 'BEGIN{printf "%dK", b/1024}'
	else                                   echo "${bytes}B"
	fi
}

# Disk usage of a directory in bytes. `du -sk` is portable (BSD + GNU); we
# multiply KiB by 1024 so callers can sort/format on a single unit.
cs_dir_size_bytes() {
	local kb
	kb="$(du -sk "$1" 2>/dev/null | awk 'NR==1{print $1}')" || kb=0
	echo $(( ${kb:-0} * 1024 ))
}

# Directory for codespace's machine-local caches (safe to delete), kept under
# the user config root. Returns non-zero when $CODESPACE_CONFIG_ROOT is unset,
# in which case callers degrade to no persistent cache.
cs_cache_dir() {
	[ -n "${CODESPACE_CONFIG_ROOT:-}" ] || return 1
	echo "$CODESPACE_CONFIG_ROOT/.cache"
}

# Run FUNC once per NUL-delimited stdin record, capping concurrency at MAX live
# background jobs. Each record is passed to FUNC as a single argument (encode
# multiple fields with a separator and split inside FUNC). Workers run as
# background subshells, so they inherit the caller's variables for reads but
# must persist their own results (e.g. to files); per-job failures are ignored.
cs_run_bounded() {
	local max="$1" fn="$2" running=0 rec
	[ "${max:-1}" -ge 1 ] 2>/dev/null || max=1
	while IFS= read -r -d '' rec; do
		"$fn" "$rec" &
		running=$((running + 1))
		if [ "$running" -ge "$max" ]; then
			wait -n 2>/dev/null || true
			running=$((running - 1))
		fi
	done
	wait 2>/dev/null || true
	return 0
}

# Get default branch using git mechanisms
cs_get_default_branch() {
	# 1. Try remote HEAD symbolic ref
	default_branch="$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|^refs/remotes/origin/||')"
	test -n "$default_branch" && { echo "$default_branch"; return 0; }

	# 2. Try current branch (useful when in main repo clone)
	default_branch="$(git branch --show-current 2>/dev/null)"
	test -n "$default_branch" && { echo "$default_branch"; return 0; }

	# 3. Try git config init.defaultBranch
	default_branch="$(git config init.defaultBranch 2>/dev/null)"
	test -n "$default_branch" && { echo "$default_branch"; return 0; }

	>&2 echo "err: could not determine default branch"
	>&2 echo "configure with:"
	echo "git config --global init.defaultBranch master"
	return 1
}

# Infer clone URL for a repo name from sibling repos in the same org
# Args: repo_name, org_dir
cs_infer_clone_url() {
	target_repo="$1"
	org_dir="$2"

	# Find any sibling repo with a remote
	for sibling in "$org_dir"/*/.git; do
		test -d "$sibling" || continue
		sibling_repo="$(dirname "$sibling")"
		origin_url="$(git -C "$sibling_repo" remote get-url origin 2>/dev/null)" || continue

		# Derive URL by replacing repo name in the URL
		sibling_name="$(basename "$sibling_repo")"
		# Handle both SSH (git@host:org/repo.git) and HTTPS (https://host/org/repo.git) URLs
		echo "$origin_url" | sed "s|/$sibling_name\\.git\$|/$target_repo.git|; s|:$sibling_name\\.git\$|:$target_repo.git|"
		return 0
	done
	return 1
}

# Fetch remote branch if it looks like a remote ref
# Args: branch_ref (e.g., "origin/main", "refs/remotes/origin/main", "main")
cs_maybe_fetch_remote() {
	local ref="$1"
	local remote=""
	local ref_branch=""
	local remainder=""
	local tracking=""

	# Pattern: refs/remotes/<remote>/<branch>
	if [[ "$ref" == refs/remotes/* ]]; then
		remainder="${ref#refs/remotes/}"
		remote="${remainder%%/*}"
		ref_branch="${remainder#*/}"
	# Pattern: <remote>/<branch> (e.g., origin/main)
	elif [[ "$ref" == */* ]]; then
		remote="${ref%%/*}"
		ref_branch="${ref#*/}"
		# Verify it's actually a remote (not a local branch with slash)
		if ! git remote | grep -qx "$remote"; then
			remote=""
			ref_branch=""
		fi
	else
		# Local branch name - check if it has a remote-tracking branch
		tracking="$(git rev-parse --abbrev-ref "$ref@{upstream}" 2>/dev/null)" || true
		if [ -n "$tracking" ] && [[ "$tracking" == */* ]]; then
			remote="${tracking%%/*}"
			ref_branch="${tracking#*/}"
		elif git remote | grep -qx "origin"; then
			remote="origin"
			ref_branch="$ref"
		fi
	fi

	if [ -n "$remote" ] && [ -n "$ref_branch" ]; then
		>&2 echo "fetching $remote/$ref_branch..."
		git fetch "$remote" "$ref_branch" || {
			>&2 echo "warn: fetch failed, continuing with local state"
		}
	fi
}

# Ensure branch exists locally (fetch from remote if needed, or create new)
# Args: branch, [base_branch_for_new]
# Returns: 0 if branch now exists locally
cs_ensure_branch() {
	local branch="$1"
	local base_branch="${2:-}"

	# Check if branch exists locally
	if git show-ref --verify --quiet "refs/heads/$branch"; then
		return 0
	fi

	# Check if branch exists on remote
	if git ls-remote --exit-code --heads origin "$branch" >/dev/null 2>&1; then
		>&2 echo "branch '$branch' exists on remote, fetching..."
		git fetch origin "$branch"
		git branch --track "$branch" "origin/$branch"
		return 0
	fi

	# Branch doesn't exist anywhere - create from base if provided
	if [ -n "$base_branch" ]; then
		git branch --no-track "$branch" "$base_branch"
		return 0
	fi

	>&2 echo "err: branch '$branch' not found and no base branch provided"
	return 1
}

# Compute branch status for a repo.
# Args: repo_path, branch, [base_branch]
# Stdout: "<status>;<base>;<ahead>" (semicolon-separated)
#   status: remote | local | new
#     remote = upstream tracks origin/<branch> (cs_ensure_branch's fetch+track path)
#     local  = no upstream, but has commits beyond merge-base with base (pre-existing local work)
#     new    = no upstream, no commits ahead (freshly created from base)
#   base:   ref used for merge-base (e.g. "origin/master"); resolved from origin/HEAD if not provided
#   ahead:  commits in <branch> beyond merge-base with <base>
cs_branch_status() {
	local repo="$1" branch="$2" base="${3:-}"

	if [ -z "$base" ]; then
		base="$(git -C "$repo" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null)" || base="origin/master"
	elif [[ "$base" != */* ]] && git -C "$repo" show-ref --verify --quiet "refs/remotes/origin/$base"; then
		base="origin/$base"
	fi

	local upstream ahead=0 mb status
	upstream="$(git -C "$repo" rev-parse --abbrev-ref "$branch@{upstream}" 2>/dev/null)" || upstream=""

	if mb="$(git -C "$repo" merge-base "$branch" "$base" 2>/dev/null)"; then
		ahead="$(git -C "$repo" rev-list --count "$mb..$branch" 2>/dev/null)" || ahead=0
	fi

	if [ -n "$upstream" ] && [[ "$upstream" == origin/* ]]; then
		status="remote"
	elif [ "$ahead" -gt 0 ]; then
		status="local"
	else
		status="new"
	fi

	echo "$status;$base;$ahead"
}

# Core worktree creation (no path computation, no editor opening)
# Args: branch, base_repo_path, dest_path, [base_branch]
cs_create_worktree_core() {
	branch="$1"
	base_repo="$2"
	dest="$3"
	base_branch="${4:-}"

	(
		cd "$base_repo"
		test -n "$base_branch" || base_branch="$(cs_get_default_branch)"

		# Fetch remote branch before creating worktree (unless CS_NO_FETCH is set)
		if [ -z "${CS_NO_FETCH:-}" ]; then
			cs_maybe_fetch_remote "$base_branch"
		fi

		# Prefer remote ref for latest state after fetch
		if [[ "$base_branch" != */* ]] && git show-ref --verify --quiet "refs/remotes/origin/$base_branch"; then
			base_branch="origin/$base_branch"
		fi

		cs_ensure_branch "$branch" "$base_branch"
		git worktree add "$dest" "$branch"
	)
	echo "$dest"
}

# Core clone creation (no path computation, no editor opening)
# Args: clone_url, dest_path, branch
cs_create_clone_core() {
	clone_url="$1"
	dest="$2"
	branch="$3"

	git clone "$clone_url" "$dest"
	(cd "$dest" && cs_ensure_branch "$branch" && git checkout "$branch")
	echo "$dest"
}

# Get absolute path
cs_abspath() {
	realpath "$1"
}

# Get absolute path to base repository (resolves through worktrees)
cs_abs_path_base_repo() {
	realpath "$(git rev-parse --git-common-dir)/.." "$@"
}

# Check if we're in a checkout (not worktree) of the main repo
cs_are_we_in_checkout_not_worktree() {
	GIT_DIR="$(realpath "$(git rev-parse --git-dir)")"
	GIT_COMMON_DIR="$(realpath "$(git rev-parse --git-common-dir)")"
	test "$GIT_DIR" = "$GIT_COMMON_DIR" && echo 1 || echo 0
}

# Get path to clone marker file
cs_clone_marker_path() {
	if [ -n "${1:-}" ]; then
		echo "$1/.git/CODESPACE_IS_CLONE"
	else
		echo "$(git rev-parse --git-dir 2>/dev/null)/CODESPACE_IS_CLONE"
	fi
}

# Get clone marker content (repo name) if exists
cs_clone_marker() {
	MARKER_PATH="$(cs_clone_marker_path "${1:-}")"
	test -f "$MARKER_PATH" && cat "$MARKER_PATH"
}

# Get repo ID for clone (relative path)
cs_repo_id_of_clone() {
	clone_repo_name="$(cs_clone_marker)"
	realpath "$(pwd)/../$clone_repo_name" "$@"
}

# Get repo ID (for config path resolution)
cs_repo_id() {
	rel_to="${1:-$HOME}"
	if [ -n "$(cs_clone_marker)" ]; then
		cs_repo_id_of_clone --relative-to="$rel_to"
	else
		cs_abs_path_base_repo --relative-to="$rel_to"
	fi
}

# Get config path for current repo
cs_config_path() {
	echo "$CODESPACE_CONFIG_ROOT/$(cs_repo_id)"
}

# Get absolute path from repo name and branch
cs_abs_path_from_repo_name_and_branch() {
	branch="${1:-$(git branch --show-current)}"
	repo_name="$(basename "$(cs_abs_path_base_repo)")"
	path="$(cs_cleanpath "$repo_name/$branch")"
	cs_abspath "../$path"
}

# Find a config file under a config-dir base. Prefers the conventional
# <base>/.codespace/<name>, falling back to a root-level <base>/<name> so files
# (post-create, remote-bootstrap.sh, remote, ...) may live directly at the
# config-dir root instead of inside .codespace/.
# Only safe for the user-level config dir ($CODESPACE_CONFIG_ROOT/...), which
# holds nothing but codespace config; a repo root is too ambiguous (a file
# named `post-create` there may be unrelated to codespace), so repo-committed
# hooks must stay under .codespace/.
# Args: base_dir, name. Stdout: resolved path (empty if neither exists).
cs_find_in_config_dir() {
	local base="$1" name="$2"
	if [ -f "$base/.codespace/$name" ]; then
		echo "$base/.codespace/$name"
	elif [ -f "$base/$name" ]; then
		echo "$base/$name"
	fi
}

# Resolve which hook script (e.g. post-create, remote-bootstrap.sh) to use.
# Precedence (first non-empty wins):
#   1. $CS_POST_CREATE_CONFIG_DIR (used on the remote: pre-resolved by the
#      create flow so the remote needn't have $CODESPACE_CONFIG_ROOT set)
#   2. $CODESPACE_CONFIG_ROOT/<repo-id>/[.codespace/]<hook>  (user-level)
#   3. <wt_path>/.codespace/<hook>                           (repo-committed)
# In the user-level config dir the hook may live in .codespace/ or at the
# config-dir root (.codespace/<hook> wins; see cs_find_in_config_dir). A
# repo-committed hook must live under .codespace/.
# Args: wt_path, hook_name
# Stdout: two lines - <active_script> \n <active_config_base>; nothing if none found
# Stderr: notes about chosen/ignored paths
#
# The <active_config_base> is the dir `link-files-from-config` resolves against
# (independent of where the hook script itself was found):
#   - user-level: the config root ($CODESPACE_CONFIG_ROOT/<repo-id>/), where
#     linkable files (AGENTS.md, .env, etc.) sit alongside the .codespace/ subdir.
#   - repo-committed: the .codespace/ subdir itself, since the repo root holds
#     the committed code and linkable config files live under .codespace/.
cs_resolve_hook() {
	local wt_path="$1" hook_name="$2"
	local user_base="" repo_base="$wt_path/.codespace"
	local user_script="" repo_script=""

	if [ -n "${CS_POST_CREATE_CONFIG_DIR:-}" ]; then
		user_base="$CS_POST_CREATE_CONFIG_DIR"
	elif [ -n "${CODESPACE_CONFIG_ROOT:-}" ]; then
		user_base="$(cd "$wt_path" && cs_config_path)"
	fi
	[ -n "$user_base" ] && user_script="$(cs_find_in_config_dir "$user_base" "$hook_name")"
	[ -f "$repo_base/$hook_name" ] && repo_script="$repo_base/$hook_name"

	if [ -n "$user_script" ]; then
		>&2 echo "note: using $hook_name from: $user_script"
		[ -n "$repo_script" ] && >&2 echo "note: ignoring repo-committed $hook_name at: $repo_script"
		echo "$user_script"
		echo "$user_base"
		return 0
	fi
	if [ -n "$repo_script" ]; then
		>&2 echo "note: using $hook_name from: $repo_script"
		echo "$repo_script"
		echo "$repo_base"
		return 0
	fi
	return 1
}

# Backwards-compatible wrapper for `post-create` lookup.
cs_resolve_post_create() {
	cs_resolve_hook "$1" "post-create"
}

# Run post-create script for a codespace
cs_post_create() {
	WT_PATH="${1:-$(cs_abs_path_from_repo_name_and_branch)}"

	cd "$WT_PATH"

	local resolved active_script active_config_dir
	if resolved="$(cs_resolve_post_create "$WT_PATH")"; then
		active_script="$(echo "$resolved" | sed -n '1p')"
		active_config_dir="$(echo "$resolved" | sed -n '2p')"
	else
		local user_base=""
		if [ -n "${CS_POST_CREATE_CONFIG_DIR:-}" ]; then
			user_base="$CS_POST_CREATE_CONFIG_DIR"
		elif [ -n "${CODESPACE_CONFIG_ROOT:-}" ]; then
			user_base="$(cs_config_path)"
		fi
		>&2 echo "note: no post-create hook. tried (first hit wins):"
		if [ -n "$user_base" ]; then
			>&2 echo "  user: $user_base/.codespace/post-create"
			>&2 echo "        $user_base/post-create"
		else
			>&2 echo "  user: <none> (\$CODESPACE_CONFIG_ROOT unset)"
		fi
		>&2 echo "  repo: $WT_PATH/.codespace/post-create"
		return 0
	fi

	BASE_REPO_PATH="$(cs_abs_path_base_repo)"

	if [ "$(cs_are_we_in_checkout_not_worktree)" = "1" ]; then
		# we are NOT in a worktree; we're in the main repository, and just checked out the branch
		>&2 echo "note: you are in branch checkout, not in a worktree. post-create script will behave differently."
		(ARE_WE_IN_CHECKOUT_NOT_WORKTREE=1 CS_POST_CREATE_CONFIG_DIR="$active_config_dir" "$active_script" "$BASE_REPO_PATH")
	else
		(CS_POST_CREATE_CONFIG_DIR="$active_config_dir" "$active_script" "$BASE_REPO_PATH")
	fi
}



######################################
#                                    #
#  marker file (.codespace/current)  #
#                                    #
######################################

# Path of the .codespace/current marker for a given codespace dir (default: cwd).
cs_current_marker_path() {
	if [ -n "${1:-}" ]; then
		echo "$1/.codespace/current"
	else
		echo "$(pwd)/.codespace/current"
	fi
}

# Write a .codespace/current marker at <dir> with the given key=value pairs.
# Args: dir, key=value, [key=value]...
cs_current_marker_write() {
	local dir="$1"; shift
	mkdir -p "$dir/.codespace"
	local marker="$dir/.codespace/current"
	: > "$marker"
	local kv
	for kv in "$@"; do
		echo "$kv" >> "$marker"
	done
}

# Read a single key from a .codespace/current marker file.
# Args: dir, key
# Stdout: value, or empty if not set / file missing
cs_current_marker_get() {
	local dir="$1" key="$2"
	local marker
	marker="$(cs_current_marker_path "$dir")"
	[ -f "$marker" ] || return 0
	awk -F= -v k="$key" '$1 == k { sub(/^[^=]*=/, "", $0); print; exit }' "$marker"
}

# Walk up from <dir> (default: cwd) to the nearest dir holding .codespace/current.
# Stdout: that dir; returns 1 if none found. Uses logical cwd (no symlink resolve),
# matching cs_stack_detect_current.
cs_current_marker_find() {
	local dir="${1:-$(pwd)}"
	while true; do
		if [ -f "$dir/.codespace/current" ]; then
			echo "$dir"
			return 0
		fi
		[ "$dir" = "/" ] && break
		dir="$(dirname "$dir")"
	done
	return 1
}

# Print the .codespace/current marker of the codespace we're in (walks up).
# With a [key] arg, prints just that key's value.
cs_current() {
	local root
	root="$(cs_current_marker_find)" || {
		>&2 echo "err: no .codespace/current marker found (not inside a marked codespace)"
		>&2 echo "  hint: run 'codespace mark-current' from inside a codespace"
		return 1
	}
	if [ -n "${1:-}" ]; then
		cs_current_marker_get "$root" "$1"
	else
		cat "$root/.codespace/current"
	fi
}

# hide a file from git (adds to .git/info/exclude of the common dir).
cs_git_exclude_add() {
	file="$1"
	exclude_file="$(git rev-parse --git-common-dir)/info/exclude"

	# add to exclude if not already present (exact line match)
	if ! grep -qxF "$file" "$exclude_file"; then
		echo "$file" >> "$exclude_file"
	fi
}

# Write an executable ./open convenience script into a codespace root dir.
# Running it re-opens the codespace (local or remote) in $GUI_EDITOR/$EDITOR
# via `codespace open <its-own-dir>`. Idempotent.
# Args: dir
cs_write_open_script() {
	local dir="$1"
	cat > "$dir/open" <<'OPEN'
#!/usr/bin/env bash
exec codespace open "$(cd "$(dirname "$0")" && pwd)"
OPEN
	chmod +x "$dir/open"
	# local worktree/clone roots are git working trees: hide the script so it
	# doesn't show as untracked (which would also trip `codespace rm` safety).
	# remote stubs and stack roots have no .git, so they skip this (and the
	# `if` keeps the function's exit status 0 for them under `set -e`).
	if [ -e "$dir/.git" ]; then
		( cd "$dir" && cs_git_exclude_add open )
	fi
}


# remote-codespace helpers (-r/--remote flow). Lives in a sibling file so this
# core utils file stays focused on shared primitives. Sourced unconditionally
# so any caller of this file gets cs_remote_* / cs_create_via_remote_* / etc.
# shellcheck source=codespace-remote
source "$(dirname "$(realpath "${BASH_SOURCE[0]}")")/codespace-remote"
